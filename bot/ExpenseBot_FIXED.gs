  // EXACT dashboard bucket names _normalizeBizSub_ recognizes.
  var TOKEN_TO_CANON = {
    'Ч©ЧҷЧ•Ч•Ч§': 'ЧўЧңЧ•ЧӘ Ч©ЧҷЧ•Ч•Ч§', 'ЧӨЧЁЧЎЧ•Чқ': 'ЧўЧңЧ•ЧӘ Ч©ЧҷЧ•Ч•Ч§', 'Ч§ЧһЧӨЧҷЧҷЧҹ': 'ЧўЧңЧ•ЧӘ Ч©ЧҷЧ•Ч•Ч§',
    'ЧһЧ©ЧңЧ•Ч—': 'ЧһЧ©ЧңЧ•Ч—ЧҷЧқ Ч•Ч”ЧӘЧ§Ч Ч•ЧӘ', 'ЧһЧ©ЧңЧ•Ч—ЧҷЧқ': 'ЧһЧ©ЧңЧ•Ч—ЧҷЧқ Ч•Ч”ЧӘЧ§Ч Ч•ЧӘ',
    'Ч”ЧӘЧ§Ч Ч”': 'ЧһЧ©ЧңЧ•Ч—ЧҷЧқ Ч•Ч”ЧӘЧ§Ч Ч•ЧӘ', 'Ч”ЧӘЧ§Ч Ч•ЧӘ': 'ЧһЧ©ЧңЧ•Ч—ЧҷЧқ Ч•Ч”ЧӘЧ§Ч Ч•ЧӘ', 'ЧҗЧЁЧҷЧ–Ч”': 'ЧһЧ©ЧңЧ•Ч—ЧҷЧқ Ч•Ч”ЧӘЧ§Ч Ч•ЧӘ',
    'Ч—Ч•ЧһЧЁ': 'ЧўЧңЧ•ЧӘ Ч—Ч•ЧһЧЁЧҷ Ч’ЧңЧқ', 'Ч—Ч•ЧһЧЁЧҷЧқ': 'ЧўЧңЧ•ЧӘ Ч—Ч•ЧһЧЁЧҷ Ч’ЧңЧқ',
    'Ч—Ч•ЧһЧЁ Ч’ЧңЧқ': 'ЧўЧңЧ•ЧӘ Ч—Ч•ЧһЧЁЧҷ Ч’ЧңЧқ', 'Ч—Ч•ЧһЧЁЧҷ Ч’ЧңЧқ': 'ЧўЧңЧ•ЧӘ Ч—Ч•ЧһЧЁЧҷ Ч’ЧңЧқ', 'ЧЁЧӣЧ©': 'ЧўЧңЧ•ЧӘ Ч—Ч•ЧһЧЁЧҷ Ч’ЧңЧқ',
    // Labor + tax + generic ops all funnel to the operations overhead bucket,
    // the only catch-all the company dashboard actually sums.
    'ЧўЧ•Ч‘Ч“': 'Ч”Ч•ЧҰЧҗЧ•ЧӘ ЧӘЧӨЧўЧ•ЧңЧҷЧ•ЧӘ', 'ЧўЧ•Ч‘Ч“ЧҷЧқ': 'Ч”Ч•ЧҰЧҗЧ•ЧӘ ЧӘЧӨЧўЧ•ЧңЧҷЧ•ЧӘ', 'Ч©ЧӣЧЁ': 'Ч”Ч•ЧҰЧҗЧ•ЧӘ ЧӘЧӨЧўЧ•ЧңЧҷЧ•ЧӘ',
    'ЧӘЧӨЧўЧ•Чң': 'Ч”Ч•ЧҰЧҗЧ•ЧӘ ЧӘЧӨЧўЧ•ЧңЧҷЧ•ЧӘ', 'ЧӘЧӨЧўЧ•ЧңЧҷ': 'Ч”Ч•ЧҰЧҗЧ•ЧӘ ЧӘЧӨЧўЧ•ЧңЧҷЧ•ЧӘ', 'ЧӘЧӨЧўЧ•ЧңЧҷЧ•ЧӘ': 'Ч”Ч•ЧҰЧҗЧ•ЧӘ ЧӘЧӨЧўЧ•ЧңЧҷЧ•ЧӘ',
    'ЧһЧЎ': 'Ч”Ч•ЧҰЧҗЧ•ЧӘ ЧӘЧӨЧўЧ•ЧңЧҷЧ•ЧӘ', 'ЧһЧҷЧЎЧҷЧқ': 'Ч”Ч•ЧҰЧҗЧ•ЧӘ ЧӘЧӨЧўЧ•ЧңЧҷЧ•ЧӘ', 'ЧһЧЎЧҷЧқ': 'Ч”Ч•ЧҰЧҗЧ•ЧӘ ЧӘЧӨЧўЧ•ЧңЧҷЧ•ЧӘ',
    'ЧҷЧ•ЧўЧҘ': 'ЧҷЧ•ЧўЧҰЧҷЧқ', 'ЧҷЧ•ЧўЧҰЧҷЧқ': 'ЧҷЧ•ЧўЧҰЧҷЧқ'
  };

  var sub = null;

  // (1) Explicit token map on the CLEANED remainder, longest token first so
  // multi-word phrases like "Ч—Ч•ЧһЧЁ Ч’ЧңЧқ" beat the bare "Ч—Ч•ЧһЧЁ". This runs BEFORE
  // matchCategory on purpose: the cleaned remainder ("ЧўЧ•Ч‘Ч“ЧҷЧқ", "Ч©ЧӣЧЁ") is the
  // true subcategory phrase, whereas matchCategory scans the whole noisy string
  // and can mis-hit on a substring accident (e.g. the materials keyword "Ч‘Ч“ЧҷЧқ"
  // is a substring of "ЧўЧ•Ч‘Ч“ЧҷЧқ"). The token map is the precise authority for the
  // canonical business buckets.
  if (rest) {
    var lowRest = rest.toLowerCase();
    var toks = Object.keys(TOKEN_TO_CANON).sort(function (a, b) { return b.length - a.length; });
    for (var i = 0; i < toks.length; i++) {
      if (typeof _kflKwHit_ === 'function' ? _kflKwHit_(lowRest, toks[i].toLowerCase())
                                           : lowRest.indexOf(toks[i].toLowerCase()) >= 0) {
