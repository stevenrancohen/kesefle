// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Personal recurring expenses ("Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч§Ч‘Ч•ЧўЧ•ЧӘ") вҖ” templates stored in the
// Vercel KV via /api/recurring. The bot parses the Hebrew command, posts
// to the API, and a daily cron asks the API to log anything that is due.
// Mirrors the _remindersAPI_ helper pattern (single POST helper + the bot
// secret header), and reuses KESEFLE_API_BASE like _tenantWriteExpense_.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function _recurringAPI_(action, payload) {
  var secret = '';
  try { secret = String(PropertiesService.getScriptProperties().getProperty('KESEFLE_BOT_SECRET') || ''); } catch (_e) {}
  if (!secret) return { ok: false, error: 'bot_secret_not_set' };
  payload = payload || {};
  payload.action = action;
  payload.botSecret = secret;
  try {
    var resp = UrlFetchApp.fetch(KESEFLE_API_BASE + '/api/recurring', {
      method: 'post',
      contentType: 'application/json',
      headers: { 'x-kesefle-bot-secret': secret },
      payload: JSON.stringify(payload),
      muteHttpExceptions: true,
    });
    var code = resp.getResponseCode();
    var body = resp.getContentText();
    if (code < 200 || code >= 300) {
      Logger.log('_recurringAPI_ ' + action + ' HTTP ' + code + ': ' + body.slice(0, 200));
      try { return JSON.parse(body); } catch (_e) { return { ok: false, error: 'http_' + code }; }
    }
    return JSON.parse(body);
  } catch (e) {
    return { ok: false, error: 'fetch_threw', detail: e && e.message };
  }
}

// Hebrew day-of-week names вҶ’ getDay() index (0=Sunday вҖҰ 6=Saturday).
var _RECUR_DOW_ = {
  'ЧЁЧҗЧ©Ч•Чҹ': 0, 'Ч©Ч Чҷ': 1, 'Ч©ЧңЧҷЧ©Чҷ': 2, 'ЧЁЧ‘ЧҷЧўЧҷ': 3,
  'Ч—ЧһЧҷЧ©Чҷ': 4, 'Ч©ЧҷЧ©Чҷ': 5, 'Ч©Ч‘ЧӘ': 6,
};

// Parse a recurring-expense command body (the leading command word like
// "Ч§Ч‘Ч•Чў" is ALREADY stripped by the caller). Returns
// { amount, description, freq, category, startDate } or null when no
// amount is present. `text` example: "2500 Ч©ЧӣЧҷЧЁЧ•ЧӘ ЧӣЧң 1 ЧңЧ—Ч•Ч“Ч©".
function _parseRecurringCommand_(text) {
  if (!text) return null;
  var work = String(text).trim();
  if (!work) return null;

  // NOTE: JS \b word boundaries do NOT work around Hebrew letters (\w is
  // ASCII-only), so all Hebrew-adjacent anchors use whitespace/edge groups.

  // 1. Optional "Ч§ЧҳЧ’Ч•ЧЁЧҷЧ” X" вҖ” pull it out first so it never pollutes the
  //    description or the freq clause. Capture a single word as category.
  var category = null;
  work = work.replace(/(^|\s)Ч§ЧҳЧ’Ч•ЧЁЧҷЧ”\s+(\S+)/i, function(_m, _pre, cat) { category = cat; return ' '; });

  // 2. Optional "Ч”Ч—Чң Чһ-DD/MM/YYYY" or "Ч”Ч—Чң Чһ-DD/MM" anywhere вҶ’ startDate.
  var startDate = null;
  work = work.replace(/(^|\s)Ч”Ч—Чң\s*Чһ[-\s]*(\d{1,2})[\/.](\d{1,2})(?:[\/.](\d{2,4}))?/i,
    function(_m, _pre, dd, mm, yy) {
      var day = ('0' + parseInt(dd, 10)).slice(-2);
      var mon = ('0' + parseInt(mm, 10)).slice(-2);
      var year;
      if (yy) {
        year = parseInt(yy, 10);
        if (year < 100) year += 2000;
      } else {
        year = new Date().getFullYear();
      }
      startDate = year + '-' + mon + '-' + day;
      return ' ';
    });

  work = work.replace(/\s+/g, ' ').trim();

  // 3. amount = the first number in the remaining text.
  var amountM = work.match(/(\d+(?:[.,]\d+)?)/);
  if (!amountM) return null;
  var amount = parseFloat(amountM[1].replace(',', '.'));
  if (!isFinite(amount) || amount <= 0) return null;

  // 4. Split off the "ЧӣЧң ..." recurrence clause (if any). Everything between
  //    the amount and "ЧӣЧң" is the description. We anchor on a whitespace/edge
  //    boundary (not \b) because "ЧӣЧң" is Hebrew. The match captures the
  //    leading separator, so the clause itself starts after that group.
  var afterAmount = work.slice(amountM.index + amountM[1].length).trim();
  var freq = null;
  var description = afterAmount;
  var kolM = afterAmount.match(/(^|\s)(ЧӣЧң(?:\s|$))/);
  if (kolM) {
    var clauseStart = kolM.index + kolM[1].length;
    description = afterAmount.slice(0, clauseStart).trim();
    var clause = afterAmount.slice(clauseStart).trim();
    freq = _parseRecurFreqClause_(clause);
  }

  // Default: monthly on today's day-of-month when no "ЧӣЧң" clause is given.
  if (!freq) {
    freq = { type: 'monthly', day: new Date().getDate() };
  }

  description = description.replace(/\s+/g, ' ').trim();

  return {
    amount: amount,
    description: description,
    freq: freq,
    category: category,
    startDate: startDate,
  };
}

// Parse the "ЧӣЧң ..." recurrence clause into a freq object. Returns null on
// no match (caller then applies the monthly-today default).
function _parseRecurFreqClause_(clause) {
  if (!clause) return null;
  var c = String(clause).trim();
  var m;

  // "ЧӣЧң <D> ЧңЧ—Ч•Ч“Ч©ЧҷЧҷЧқ" вҶ’ every 2 months on day D.
  m = c.match(/^ЧӣЧң\s+(\d{1,2})\s+ЧңЧ—Ч•Ч“Ч©ЧҷЧҷЧқ/);
  if (m) return { type: 'months', n: 2, day: parseInt(m[1], 10) };

  // "ЧӣЧң <D> ЧңЧ—Ч•Ч“Ч©" вҶ’ monthly on day D.
  m = c.match(/^ЧӣЧң\s+(\d{1,2})\s+ЧңЧ—Ч•Ч“Ч©(?=\s|$)/);
  if (m) return { type: 'monthly', day: parseInt(m[1], 10) };

  // "ЧӣЧң <D> Чң-<N> Ч—Ч•Ч“Ч©ЧҷЧқ" вҶ’ every N months on day D.
  m = c.match(/^ЧӣЧң\s+(\d{1,2})\s+Чң[-\s]*(\d{1,2})\s+Ч—Ч•Ч“Ч©ЧҷЧқ/);
  if (m) return { type: 'months', n: parseInt(m[2], 10), day: parseInt(m[1], 10) };

  // "ЧӣЧң <N> Ч—Ч•Ч“Ч©ЧҷЧқ" (day optional, default 1).
  m = c.match(/^ЧӣЧң\s+(\d{1,2})\s+Ч—Ч•Ч“Ч©ЧҷЧқ/);
  if (m) return { type: 'months', n: parseInt(m[1], 10), day: 1 };

  // "ЧӣЧң Ч—Ч•Ч“Ч©ЧҷЧҷЧқ" (no day) вҶ’ every 2 months on day 1.
  if (/^ЧӣЧң\s+Ч—Ч•Ч“Ч©ЧҷЧҷЧқ/.test(c)) return { type: 'months', n: 2, day: 1 };

  // "ЧӣЧң Ч—Ч•Ч“Ч©" (no day) вҶ’ monthly on day 1.
  if (/^ЧӣЧң\s+Ч—Ч•Ч“Ч©(?=\s|$)/.test(c)) return { type: 'monthly', day: 1 };

  // "ЧӣЧң ЧҷЧ•Чқ <DOW>" / "ЧӣЧң <DOW>" вҶ’ weekly with that day-of-week.
  m = c.match(/^ЧӣЧң\s+(?:ЧҷЧ•Чқ\s+)?(ЧЁЧҗЧ©Ч•Чҹ|Ч©Ч Чҷ|Ч©ЧңЧҷЧ©Чҷ|ЧЁЧ‘ЧҷЧўЧҷ|Ч—ЧһЧҷЧ©Чҷ|Ч©ЧҷЧ©Чҷ|Ч©Ч‘ЧӘ)(?=\s|$)/);
  if (m) return { type: 'weekly', dow: _RECUR_DOW_[m[1]] };

  // "ЧӣЧң Ч©Ч‘Ч•Чў" вҶ’ weekly on today's day-of-week.
  if (/^ЧӣЧң\s+Ч©Ч‘Ч•Чў(?=\s|$)/.test(c)) return { type: 'weekly', dow: new Date().getDay() };

  // "ЧӣЧң <N> ЧҷЧһЧҷЧқ" вҶ’ every N days.
  m = c.match(/^ЧӣЧң\s+(\d{1,3})\s+ЧҷЧһЧҷЧқ/);
  if (m) return { type: 'days', n: parseInt(m[1], 10) };

  // "ЧӣЧң ЧҷЧ•Чқ" / "ЧӣЧң ЧҷЧ•ЧһЧҷЧҷЧқ" вҶ’ every 1 / 2 days.
  if (/^ЧӣЧң\s+ЧҷЧ•ЧһЧҷЧҷЧқ(?=\s|$)/.test(c)) return { type: 'days', n: 2 };
  if (/^ЧӣЧң\s+ЧҷЧ•Чқ(?=\s|$)/.test(c)) return { type: 'days', n: 1 };

  return null;
}

// Render a freq object as a short Hebrew phrase for list output.
function _recurFreqHuman_(freq) {
  if (!freq || !freq.type) return '';
  if (freq.type === 'monthly') return 'ЧӣЧң ' + freq.day + ' ЧңЧ—Ч•Ч“Ч©';
  if (freq.type === 'months') {
    if (freq.n === 2) return 'ЧӣЧң ' + (freq.day || 1) + ' ЧңЧ—Ч•Ч“Ч©ЧҷЧҷЧқ';
    return 'ЧӣЧң ' + (freq.day || 1) + ' Чң-' + freq.n + ' Ч—Ч•Ч“Ч©ЧҷЧқ';
  }
  if (freq.type === 'weekly') {
    var names = ['ЧЁЧҗЧ©Ч•Чҹ', 'Ч©Ч Чҷ', 'Ч©ЧңЧҷЧ©Чҷ', 'ЧЁЧ‘ЧҷЧўЧҷ', 'Ч—ЧһЧҷЧ©Чҷ', 'Ч©ЧҷЧ©Чҷ', 'Ч©Ч‘ЧӘ'];
    return 'ЧӣЧң ЧҷЧ•Чқ ' + (names[freq.dow] || '?');
  }
  if (freq.type === 'days') {
    if (freq.n === 1) return 'ЧӣЧң ЧҷЧ•Чқ';
    if (freq.n === 2) return 'ЧӣЧң ЧҷЧ•ЧһЧҷЧҷЧқ';
    return 'ЧӣЧң ' + freq.n + ' ЧҷЧһЧҷЧқ';
  }
  return '';
}

function _money_(n) {
  return 'вӮӘ' + Number(n || 0).toLocaleString('he-IL');
}

// в”Җв”Җв”Җ Recurring command handlers в”Җв”Җв”Җ
// "Ч§Ч‘Ч•Чў 2500 Ч©ЧӣЧҷЧЁЧ•ЧӘ ЧӣЧң 1 ЧңЧ—Ч•Ч“Ч©" вҶ’ add a template.
function _recurringAdd_(fromPhone, body) {
  var parsed = _parseRecurringCommand_(body);
  if (!parsed || !parsed.amount) {
    return 'рҹҳ• ЧңЧҗ Ч”Ч‘Ч ЧӘЧҷ. Ч ЧЎЧ”: "Ч§Ч‘Ч•Чў 2500 Ч©ЧӣЧҷЧЁЧ•ЧӘ ЧӣЧң 1 ЧңЧ—Ч•Ч“Ч©".';
  }
  var payload = {
    phone: String(fromPhone).replace(/[^0-9]/g, ''),
    amount: parsed.amount,
    description: parsed.description || 'Ч”Ч•ЧҰЧҗЧ” Ч§Ч‘Ч•ЧўЧ”',
    freq: parsed.freq,
  };
  if (parsed.category) payload.category = parsed.category;
  if (parsed.startDate) payload.startDate = parsed.startDate;
  var r = _recurringAPI_('add', payload);
  if (!r || !r.ok) return 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ”: ' + (r && r.error || 'unknown');
  return 'рҹ”Ғ Ч ЧЁЧ©ЧһЧ” Ч”Ч•ЧҰЧҗЧ” Ч§Ч‘Ч•ЧўЧ”: ' + _money_(parsed.amount) + ' ' + payload.description +
    ' вҖ” Ч”ЧЁЧҷЧ©Ч•Чқ Ч”Ч‘Чҗ: ' + (r.nextDue || '?') + '.\n' +
    'ЧЁЧ•ЧҰЧ” ЧңЧЁЧ©Ч•Чқ ЧңЧһЧӨЧЁЧў ЧһЧӘЧ—ЧҷЧңЧӘ Ч”Ч—Ч•Ч“Ч©? Ч©ЧңЧ—: *ЧЎЧ ЧӣЧЁЧҹ Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч§Ч‘Ч•ЧўЧ•ЧӘ*';
}

// "ЧЁЧ©ЧҷЧһЧӘ Ч§Ч‘Ч•ЧўЧ•ЧӘ" / "Ч§Ч‘Ч•ЧўЧ•ЧӘ" вҶ’ list all templates.
function _recurringList_(fromPhone) {
  var r = _recurringAPI_('list', { phone: String(fromPhone).replace(/[^0-9]/g, '') });
  if (!r || !r.ok) return 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ”: ' + (r && r.error || 'unknown');
  if (!r.templates || !r.templates.length) {
    return 'ЧҗЧҷЧҹ ЧңЧҡ Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч§Ч‘Ч•ЧўЧ•ЧӘ ЧўЧ“ЧҷЧҷЧҹ. Ч”Ч•ЧЎЧЈ ЧўЧқ: Ч§Ч‘Ч•Чў 2500 Ч©ЧӣЧҷЧЁЧ•ЧӘ ЧӣЧң 1 ЧңЧ—Ч•Ч“Ч©';
  }
  var lines = ['рҹ”Ғ *Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч§Ч‘Ч•ЧўЧ•ЧӘ*', 'в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ', ''];
  r.templates.forEach(function(t) {
    var line = 'вҖў ' + _money_(t.amount) + ' ' + (t.description || '') +
      ' вҖ” ' + _recurFreqHuman_(t.freq) +
      ' вҖ” Ч”Ч‘Чҗ: ' + (t.nextDue || '?');
    if (t.status === 'paused') line += ' (ЧһЧ•Ч©Ч”Ч”)';
    lines.push(line);
  });
  return lines.join('\n');
}

// "ЧһЧ—Ч§ Ч§Ч‘Ч•Чў <ref>" вҶ’ remove by id or a word from the description.
function _recurringRemove_(fromPhone, ref) {
  ref = String(ref || '').trim();
  if (!ref) return 'рҹҳ• ЧҰЧҷЧҷЧҹ ЧһЧ” ЧңЧһЧ—Ч•Ч§: "ЧһЧ—Ч§ Ч§Ч‘Ч•Чў Ч©ЧӣЧҷЧЁЧ•ЧӘ".';
  var r = _recurringAPI_('remove', { phone: String(fromPhone).replace(/[^0-9]/g, ''), ref: ref });
  if (!r || !r.ok) return 'ЧңЧҗ Ч ЧһЧҰЧҗ';
  return 'рҹ—‘ Ч ЧһЧ—Ч§Ч” Ч”Ч•ЧҰЧҗЧ” Ч§Ч‘Ч•ЧўЧ”: ' + (r.removed || ref);
}

// "ЧўЧ“ЧӣЧҹ Ч§Ч‘Ч•Чў <ref> ..." вҶ’ ref = first word, rest parsed for new fields.
function _recurringUpdate_(fromPhone, rest) {
  rest = String(rest || '').trim();
  var spaceIdx = rest.indexOf(' ');
  var ref = spaceIdx >= 0 ? rest.slice(0, spaceIdx) : rest;
  var changes = spaceIdx >= 0 ? rest.slice(spaceIdx + 1).trim() : '';
  if (!ref) return 'рҹҳ• ЧҰЧҷЧҷЧҹ ЧһЧ” ЧңЧўЧ“ЧӣЧҹ: "ЧўЧ“ЧӣЧҹ Ч§Ч‘Ч•Чў Ч©ЧӣЧҷЧЁЧ•ЧӘ 2700".';
  var payload = { phone: String(fromPhone).replace(/[^0-9]/g, ''), ref: ref };
  var parsed = _parseRecurringCommand_(changes);
  if (parsed) {
    if (parsed.amount) payload.amount = parsed.amount;
    if (parsed.category) payload.category = parsed.category;
    if (parsed.freq && /\bЧӣЧң\b/.test(changes)) payload.freq = parsed.freq;
    var desc = (parsed.description || '').trim();
    if (desc) payload.description = desc;
  }
  if (payload.amount == null && payload.freq == null &&
      payload.category == null && payload.description == null) {
    return 'рҹҳ• ЧңЧҗ Ч”Ч‘Ч ЧӘЧҷ ЧһЧ” ЧңЧўЧ“ЧӣЧҹ. Ч ЧЎЧ”: "ЧўЧ“ЧӣЧҹ Ч§Ч‘Ч•Чў Ч©ЧӣЧҷЧЁЧ•ЧӘ 2700".';
  }
  var r = _recurringAPI_('update', payload);
  if (!r || !r.ok) return 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ”: ' + (r && r.error || 'unknown');
  var t = r.template || {};
  return 'вңҸпёҸ ЧўЧ•Ч“ЧӣЧҹ: ' + _money_(t.amount) + ' ' + (t.description || '') +
    (t.freq ? ' вҖ” ' + _recurFreqHuman_(t.freq) : '') + '.';
}

// "Ч”Ч—ЧңЧЈ ЧһЧҰЧ‘ Ч§Ч‘Ч•Чў <ref>" / "Ч”Ч©Ч”Ч” Ч§Ч‘Ч•Чў <ref>" / "Ч”ЧӨЧўЧң Ч§Ч‘Ч•Чў <ref>" вҶ’ toggle.
function _recurringToggle_(fromPhone, ref, status) {
  ref = String(ref || '').trim();
  if (!ref) return 'рҹҳ• ЧҰЧҷЧҷЧҹ ЧҗЧҷЧ–Ч• Ч”Ч•ЧҰЧҗЧ” Ч§Ч‘Ч•ЧўЧ”.';
  var payload = { phone: String(fromPhone).replace(/[^0-9]/g, ''), ref: ref };
  if (status) payload.status = status;
  var r = _recurringAPI_('toggle', payload);
  if (!r || !r.ok) return 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ”: ' + (r && r.error || 'unknown');
  var stateTxt = r.status === 'paused' ? 'Ч”Ч•Ч©Ч”ЧӘЧ” вҸё' : 'Ч”Ч•ЧӨЧўЧңЧ” в–¶пёҸ';
  return 'Ч”Ч”Ч•ЧҰЧҗЧ” Ч”Ч§Ч‘Ч•ЧўЧ” "' + (r.description || ref) + '" ' + stateTxt + '.';
}

// "ЧЎЧ ЧӣЧЁЧҹ Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч§Ч‘Ч•ЧўЧ•ЧӘ" вҶ’ log everything due since the template start.
function _recurringSync_(fromPhone) {
  var r = _recurringAPI_('sync', { phone: String(fromPhone).replace(/[^0-9]/g, '') });
  if (!r || !r.ok) return 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ”: ' + (r && r.error || 'unknown');
  if (!r.count) return 'ЧҗЧҷЧҹ ЧһЧ” ЧңЧЎЧ ЧӣЧЁЧҹ.';
  return 'вң… Ч ЧЁЧ©ЧһЧ• ' + r.count + ' Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч§Ч‘Ч•ЧўЧ•ЧӘ ЧңЧһЧӨЧЁЧў (ЧЎЧ”"Чӣ ' + _money_(r.totalAmount) + ').';
}

// =====================================================================
// Personalization questionnaire (Hebrew "she'elon hat'amah ishit") вҖ” a
// 3-step flow driven by WhatsApp interactive replies + one free-text step.
//
// The user profile (trackingType / hasRecurring / autoLogPref) is stored
// server-side via /api/profile (see _profileAPI_ below вҖ” same shape and
// secret header as _recurringAPI_). Because each interactive reply arrives
// as a SEPARATE webhook event, we persist the current step in CacheService
// under survey_state:<phone>. Interactive row ids are namespaced
// (q1_*/q2_*/q3_*) so the webhook can route them; see
// _surveyHandleInteractive_ wired from handleInteractiveReply_.
// =====================================================================

// POST helper for the profile endpoint. Identical shape to _recurringAPI_:
// header x-kesefle-bot-secret = KESEFLE_BOT_SECRET, body { action, ... }.
// Actions: set { phone, fields:{trackingType,hasRecurring,autoLogPref} }
//          get { phone } вҶ’ both return { ok, profile }.
function _profileAPI_(action, payload) {
  var secret = '';
  try { secret = String(PropertiesService.getScriptProperties().getProperty('KESEFLE_BOT_SECRET') || ''); } catch (_e) {}
  if (!secret) return { ok: false, error: 'bot_secret_not_set' };
  payload = payload || {};
  payload.action = action;
  payload.botSecret = secret;
  try {
    var resp = UrlFetchApp.fetch(KESEFLE_API_BASE + '/api/profile', {
      method: 'post',
      contentType: 'application/json',
      headers: { 'x-kesefle-bot-secret': secret },
      payload: JSON.stringify(payload),
      muteHttpExceptions: true,
    });
    var code = resp.getResponseCode();
    var body = resp.getContentText();
    if (code < 200 || code >= 300) {
      Logger.log('_profileAPI_ ' + action + ' HTTP ' + code + ': ' + body.slice(0, 200));
      try { return JSON.parse(body); } catch (_e) { return { ok: false, error: 'http_' + code }; }
    }
    return JSON.parse(body);
  } catch (e) {
    return { ok: false, error: 'fetch_threw', detail: e && e.message };
  }
}

// --- Add a custom row to the user's "ЧһЧҗЧ–Чҹ ЧҗЧҷЧ©Чҷ" dashboard via the Vercel
// bridge. Used by:
//   (1) the "ЧҰЧ•ЧЁ Ч§ЧҳЧ’Ч•ЧЁЧҷЧ” X" command in processExpense,
//   (2) the onboarding questionnaire's kids step (one row per child).
// Accepts a comma-separated list of names so a single message like
// "ЧҰЧ•ЧЁ Ч§ЧҳЧ’Ч•ЧЁЧҷЧ” Ч“Ч ЧҷЧҗЧң, ЧһЧҷЧӣЧң, ЧҷЧ•ЧҗЧ‘" creates three rows.
// Returns a Hebrew reply string the caller passes back to WhatsApp.
function _addCategoryRows_(fromPhone, rawNames) {
  var clean = String(fromPhone || '').replace(/[^0-9]/g, '');
  if (!clean) return 'ЧңЧҗ Ч”ЧҰЧңЧ—ЧӘЧҷ ЧңЧ–Ч”Ч•ЧӘ ЧҗЧӘ Ч”ЧһЧЎЧӨЧЁ Ч©ЧңЧҡ. Ч ЧЎЧ” Ч©Ч•Ч‘.';
  var secret = '';
  try { secret = String(PropertiesService.getScriptProperties().getProperty('KESEFLE_BOT_SECRET') || ''); } catch (_e) {}
  if (!secret) return 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ” Ч‘Ч”Ч’Ч“ЧЁЧ•ЧӘ Ч”Ч‘Ч•Чҳ (KESEFLE_BOT_SECRET Ч—ЧЎЧЁ).';

  // Split on commas + Hebrew "Ч•" conjunction. Strip "ЧҷЧңЧ“ 1 " / "ЧҷЧңЧ“Ч” 2 "
  // prefixes so "ЧҷЧңЧ“ 1 Ч“Ч ЧҷЧҗЧң" gives just "Ч“Ч ЧҷЧҗЧң".
  var raw = String(rawNames || '').trim();
  if (!raw) return 'ЧҗЧ—ЧЁЧҷ "ЧҰЧ•ЧЁ Ч§ЧҳЧ’Ч•ЧЁЧҷЧ”" ЧҰЧЁЧҷЧҡ ЧңЧӣЧӘЧ•Ч‘ ЧҗЧӘ Ч”Ч©Чқ. ЧңЧ“Ч•Ч’ЧһЧ”:\n*ЧҰЧ•ЧЁ Ч§ЧҳЧ’Ч•ЧЁЧҷЧ” Ч“Ч ЧҷЧҗЧң*\nЧҗЧ• ЧңЧӣЧһЧ” ЧҷЧңЧ“ЧҷЧқ ЧҷЧ—Ч“:\n*ЧҰЧ•ЧЁ Ч§ЧҳЧ’Ч•ЧЁЧҷЧ” Ч“Ч ЧҷЧҗЧң, ЧһЧҷЧӣЧң, ЧҷЧ•ЧҗЧ‘*';
  var pieces = raw.split(/[,ШҢ;\n]+/).map(function (p) {
    return String(p || '')
      .replace(/^\s*(?:ЧҷЧңЧ“(?:Ч”|ЧҷЧқ|Ч•ЧӘ)?|Ч‘Чҹ|Ч‘ЧӘ|ЧӘЧҷЧ Ч•Ч§(?:ЧӘ)?|child)\s*\d*\s*[:\-]?\s*/i, '')
      .trim();
  }).filter(function (p) { return p && p.length >= 2; });
  if (!pieces.length) return 'ЧңЧҗ Ч”ЧҰЧңЧ—ЧӘЧҷ ЧңЧ–Ч”Ч•ЧӘ Ч©ЧһЧ•ЧӘ. ЧӘЧӣЧӘЧ•Ч‘ ЧңЧһЧ©Чң: *ЧҰЧ•ЧЁ Ч§ЧҳЧ’Ч•ЧЁЧҷЧ” Ч“Ч ЧҷЧҗЧң* ЧҗЧ• *ЧҰЧ•ЧЁ Ч§ЧҳЧ’Ч•ЧЁЧҷЧ” ЧҷЧңЧ“ 1 Ч“Ч ЧҷЧҗЧң, ЧҷЧңЧ“ 2 ЧһЧҷЧӣЧң*';
  if (pieces.length > 6) pieces = pieces.slice(0, 6);

  var ok = [], failed = [], duplicates = [], sheetUrl = '';
  // Default emoji: рҹ‘¶ for likely-kid names (short Hebrew first names).
  // Users can always rename the row in their sheet вҖ” col A is editable.
  var emoji = 'вңЁ';
  if (pieces.length > 1 || pieces.some(function (p) { return p.length <= 10 && !/[A-Za-z0-9]/.test(p); })) emoji = 'рҹ‘¶';

  for (var i = 0; i < pieces.length; i++) {
    var name = pieces[i];
    try {
      var resp = UrlFetchApp.fetch(KESEFLE_API_BASE + '/api/sheet/add-category-row', {
        method: 'post',
        contentType: 'application/json',
        headers: { 'x-kesefle-bot-secret': secret },
        payload: JSON.stringify({ phone: clean, name: name, emoji: emoji, botSecret: secret }),
        muteHttpExceptions: true,
      });
      var code = resp.getResponseCode();
      var body = resp.getContentText();
      var j; try { j = JSON.parse(body); } catch (_pe) { j = null; }
      if (code === 200 && j && j.ok) {
        if (j.duplicate) duplicates.push(name); else ok.push(name);
        if (j.sheetUrl) sheetUrl = j.sheetUrl;
      } else if (code === 404 && j && j.error === 'no_user') {
        return 'рҹҳ¬ Ч”ЧһЧЎЧӨЧЁ Ч”Ч–Ч” ЧңЧҗ ЧһЧ§Ч•Ч©ЧЁ ЧңЧ—Ч©Ч‘Ч•Чҹ. ЧӣЧ ЧЎ/Чҷ Чң-kesefle.com/account, Ч”ЧӘЧ—Ч‘ЧЁ ЧўЧқ Google Ч•ЧҗЧ– Ч©ЧңЧ— Ч©Ч•Ч‘.';
      } else if (code === 404 && j && j.error === 'no_sheet') {
        return 'рҹҳ¬ ЧўЧ“ЧҷЧҷЧҹ ЧҗЧҷЧҹ ЧңЧҡ Ч’ЧҷЧңЧҷЧ•Чҹ. ЧӣЧ ЧЎ/Чҷ Чң-kesefle.com/account ЧңЧ”Ч©ЧңЧҷЧқ ЧҗЧӘ Ч”Ч”Ч’Ч“ЧЁЧ”.';
      } else if (code === 409 && j && j.error === 'reauth_required') {
        return 'рҹ”‘ ЧҰЧЁЧҷЧҡ ЧңЧ”ЧӘЧ—Ч‘ЧЁ ЧһЧ—Ч“Ч©: kesefle.com/account';
      } else {
        Logger.log('_addCategoryRows_ HTTP ' + code + ': ' + body.slice(0, 200));
        failed.push(name);
      }
    } catch (e) {
      Logger.log('_addCategoryRows_ threw on "' + name + '": ' + (e && e.message));
      failed.push(name);
    }
  }

  var lines = [];
  if (ok.length) {
    lines.push('вң… Ч Ч•ЧЎЧӨЧ• ЧңЧ’ЧҷЧңЧҷЧ•Чҹ *ЧһЧҗЧ–Чҹ ЧҗЧҷЧ©Чҷ*: ' + ok.map(function (n) { return emoji + ' ' + n; }).join(', '));
  }
  if (duplicates.length) {
    lines.push('в„№пёҸ ЧӣЧ‘ЧЁ Ч§ЧҷЧҷЧқ: ' + duplicates.join(', '));
  }
  if (failed.length) {
    lines.push('рҹҳ¬ ЧңЧҗ Ч”ЧҰЧңЧҷЧ—: ' + failed.join(', '));
  }
  if (ok.length) {
    lines.push('');
    lines.push('ЧһЧўЧӣЧ©ЧҷЧ• ЧӣЧң Ч”Ч•ЧҰЧҗЧ” Ч©ЧһЧ–ЧӣЧҷЧЁЧ” ЧҗЧӘ Ч”Ч©Чқ ЧӘЧҷЧӣЧ ЧЎ ЧңЧ©Ч•ЧЁЧ” Ч”Ч–ЧҗЧӘ ЧҗЧ•ЧҳЧ•ЧһЧҳЧҷЧӘ.');
    lines.push('Ч“Ч•Ч’ЧһЧ”: *200 Ч“Ч ЧҷЧҗЧң Ч‘ЧҷЧӘ ЧЎЧӨЧЁ* вҶ’ Ч Ч•ЧЎЧЈ ЧңЧ“Ч ЧҷЧҗЧң.');
    if (sheetUrl) lines.push('рҹ“Ҡ ' + sheetUrl);
  }
  return lines.join('\n');
}

// --- Survey state helpers (CacheService, 1h TTL вҖ” long enough for a user
// to finish, short enough to self-clean if abandoned). ---
var _SURVEY_TTL_SEC_ = 3600;
function _surveyStateKey_(fromPhone) {
  return 'survey_state:' + String(fromPhone).replace(/[^0-9]/g, '');
}
function _surveyGetState_(fromPhone) {
  try { return CacheService.getScriptCache().get(_surveyStateKey_(fromPhone)); }
  catch (_e) { return null; }
}
function _surveySetState_(fromPhone, state) {
  try { CacheService.getScriptCache().put(_surveyStateKey_(fromPhone), String(state), _SURVEY_TTL_SEC_); }
  catch (_e) {}
}
function _surveyClearState_(fromPhone) {
  try { CacheService.getScriptCache().remove(_surveyStateKey_(fromPhone)); }
  catch (_e) {}
}
// Remember the user's autoLog preference (chosen in Q3) so that recurring
// items added during the freeform step inherit it. Stored alongside state.
function _surveyAutoLogKey_(fromPhone) {
  return 'survey_autolog:' + String(fromPhone).replace(/[^0-9]/g, '');
}
function _surveyGetAutoLogPref_(fromPhone) {
  try { return CacheService.getScriptCache().get(_surveyAutoLogKey_(fromPhone)); }
  catch (_e) { return null; }
}
function _surveySetAutoLogPref_(fromPhone, pref) {
  try { CacheService.getScriptCache().put(_surveyAutoLogKey_(fromPhone), String(pref), _SURVEY_TTL_SEC_); }
  catch (_e) {}
}

// --- Objective ("ЧҷЧўЧ“ Ч—Ч“Ч©") pending-state helpers (CacheService, 15-min TTL).
// 2026-06-01 FIX: the bare "ЧҷЧўЧ“ Ч—Ч“Ч©" prompt and the one-shot-missing-horizon
// prompt ask the user to "reply 1/2/3/4" but used to set NO pending state.
// The user's bare reply "1" then hit the doPost expense FAST-PATH (any text
// starting with a digit) and was written as a 1-shekel expense. We now stamp
// a short-lived pending-objective state when the prompt is shown, and a
// dispatcher (run BEFORE the expense fast-path) routes an END-ANCHORED reply
// of 1-4 into objective creation instead of processExpense. "1 Ч§ЧӨЧ”" still
// books an expense because it is not end-anchored ^[1-4]$.
//
// State value shapes (plain strings, stored in the same per-phone cache the
// rest of the bot uses):
//   "horizon"      -> prompt was shown, waiting for the 1/2/3/4 pick
//   "desc:<h>"     -> a horizon <h> was picked, waiting for the goal text
var _OBJ_PEND_TTL_SEC_ = 900; // 15 minutes
function _objPendKey_(fromPhone) {
  return 'objPend:' + String(fromPhone).replace(/[^0-9]/g, '');
}
function _objPendGet_(fromPhone) {
  try { return CacheService.getScriptCache().get(_objPendKey_(fromPhone)); }
  catch (_e) { return null; }
}
function _objPendSet_(fromPhone, state) {
  try { CacheService.getScriptCache().put(_objPendKey_(fromPhone), String(state), _OBJ_PEND_TTL_SEC_); }
  catch (_e) {}
}
function _objPendClear_(fromPhone) {
  try { CacheService.getScriptCache().remove(_objPendKey_(fromPhone)); }
  catch (_e) {}
}

// --- Gender + need (personal/business/both) вҖ” stored in Script Properties so
// they PERSIST per tenant beyond the 1h survey cache and need no api/profile
// change (api/profile.js whitelists fields and would silently drop a gender
// field). Keyed by phone digits only, fully bot-local. gender:'m'|'f',
// need:'personal'|'business'|'both'. Used to address the user with a gendered
// brother/sister + well-done encouragement, and (need) to note which tabs to
// provision.
function _genderKey_(fromPhone) { return 'gender:' + String(fromPhone).replace(/[^0-9]/g, ''); }
function _setGender_(fromPhone, g) {
  if (g !== 'm' && g !== 'f') return;
  try { PropertiesService.getScriptProperties().setProperty(_genderKey_(fromPhone), g); } catch (_e) {}
}
function _getGender_(fromPhone) {
  try { return PropertiesService.getScriptProperties().getProperty(_genderKey_(fromPhone)) || ''; }
  catch (_e) { return ''; }
}
function _needKey_(fromPhone) { return 'need:' + String(fromPhone).replace(/[^0-9]/g, ''); }
function _setNeed_(fromPhone, n) {
  if (n !== 'personal' && n !== 'business' && n !== 'both') return;
  try { PropertiesService.getScriptProperties().setProperty(_needKey_(fromPhone), n); } catch (_e) {}
}
function _getNeed_(fromPhone) {
  try { return PropertiesService.getScriptProperties().getProperty(_needKey_(fromPhone)) || ''; }
  catch (_e) { return ''; }
}

// Gendered second-person address: brother (m) / sister (f) / '' (unknown).
// Caller decides where to place it so we never double-gender a sentence.
function _addr_(fromPhone) {
  var g = _getGender_(fromPhone);
  if (g === 'm') return 'ЧҗЧ—Чҷ';
  if (g === 'f') return 'ЧҗЧ—Ч•ЧӘЧҷ';
  return '';
}
// A short, warm, gendered well-done tail (one emoji). Empty until we know
// the gender, so we never guess. Throttled to once per Israel-calendar-day
// per user (via CacheService) so confirmations stay warm, not spammy.
// Appended to expense confirmations.
function _kudosTail_(fromPhone) {
  var a = _addr_(fromPhone);
  if (!a) return '';
  try {
    var clean = String(fromPhone).replace(/[^0-9]/g, '');
    var dayKey = Utilities.formatDate(new Date(), 'Asia/Jerusalem', 'yyyy-MM-dd');
    var ck = 'kudos:' + clean + ':' + dayKey;
    var cache = CacheService.getScriptCache();
    if (cache.get(ck)) return '';        // already encouraged today
    cache.put(ck, '1', 86400);           // 24h
  } catch (_e) { /* on cache failure, allow the kudos rather than suppress it */ }
  // Rotate a few phrasings so it doesn't read like a canned string. Keep the
  // champion noun gender-correct using the stored gender.
  var champ = (_getGender_(fromPhone) === 'f') ? 'ЧҗЧңЧ•ЧӨЧ”' : 'ЧҗЧңЧ•ЧЈ';
  var lines = ['ЧӣЧң Ч”ЧӣЧ‘Ч•Ч“ ' + a + '! рҹ‘Ҹ', 'ЧҷЧӨЧ” ' + a + ', ЧӣЧӣЧ” ЧһЧһЧ©ЧҷЧӣЧҷЧқ! рҹ’Ә', champ + ' ' + a + '! рҹ‘Ҹ'];
  var idx = 0;
  try { idx = (new Date()).getDate() % lines.length; } catch (_e2) {}
  return '\n\n' + lines[idx];
}

// --- Interactive List sender for the questionnaire. Wraps the existing,
// proven low-level sender (sendWhatsAppInteractiveList) which already uses
// the right token / phoneId / Graph URL. Each row id is namespaced so the
// webhook can route the reply, e.g. q1_personal. `rows` =
// [{ id:'q1_personal', title:'...', description:'...' }, ...].
function _surveySendList_(fromPhone, bodyText, buttonText, rows, headerText) {
  var sections = [{ title: 'ЧҗЧӨЧ©ЧЁЧ•ЧҷЧ•ЧӘ', rows: (rows || []).map(function(r) {
    return {
      id: String(r.id),
      title: String(r.title).slice(0, 24),
      description: r.description ? String(r.description).slice(0, 72) : '',
    };
  }) }];
  return sendWhatsAppInteractiveList(
    fromPhone,
    headerText || 'Ч©ЧҗЧңЧ•Чҹ Ч”ЧӘЧҗЧһЧ” ЧҗЧҷЧ©ЧҷЧӘ',
    bodyText,
    'ЧҗЧӨЧ©ЧЁ ЧңЧ©Ч Ч•ЧӘ Ч‘ЧӣЧң ЧўЧӘ ЧўЧқ *Ч©ЧҗЧңЧ•Чҹ*',
    buttonText || 'Ч‘Ч—ЧЁ',
    sections
  );
}

