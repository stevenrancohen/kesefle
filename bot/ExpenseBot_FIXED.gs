// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Milestone celebrations вҖ” fire at meaningful moments to build emotional
// attachment. Hooked off processExpense so the celebration message
// piggybacks on the user's "вң… Ч ЧЁЧ©Чқ" reply rather than firing a
// separate cron.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function getMilestoneMessage_(fromPhone, totalExpensesAfter) {
  try {
    // 100 / 250 / 500 / 1000 / 2500 milestones.
    var thresholds = [100, 250, 500, 1000, 2500];
    for (var i = 0; i < thresholds.length; i++) {
      var th = thresholds[i];
      if (totalExpensesAfter === th) {
        // Milestone-fired flag now lives in KV (key unchanged:
        // 'milestone:'+phone+':'+threshold) with a legacy Script-Property read
        // fallback, so a milestone already celebrated before this migration is
        // never re-fired. Presence-only -> no TTL.
        var key = 'milestone:' + fromPhone + ':' + th;
        if (_seenFlag_(key, 0)) return null; // already fired
        _markFlag_(key, new Date().toISOString(), 0);
        if (th === 100) return '\n\nрҹҺү Ч”Ч•ЧҰЧҗЧ” ЧһЧЎЧӨЧЁ 100! ЧһЧӘЧ—ЧҷЧңЧ” ЧңЧ”ЧЁЧҗЧ•ЧӘ ЧӘЧһЧ•Ч Ч” ЧһЧңЧҗЧ”. Ч©ЧңЧ— "ЧЎЧҷЧӣЧ•Чқ" ЧңЧЁЧҗЧ•ЧӘ.';
        if (th === 250) return '\n\nрҹ“Ҳ 250 Ч”Ч•ЧҰЧҗЧ•ЧӘ. ЧҗЧӘЧ” Ч‘Ч§ЧҰЧ‘ ЧһЧҰЧ•ЧҷЧҹ.';
        if (th === 500) return '\n\nрҹҸҶ 500 Ч”Ч•ЧҰЧҗЧ•ЧӘ! Ч—ЧҰЧҷ Ч“ЧЁЧҡ ЧңЧҗЧңЧЈ.';
        if (th === 1000) return '\n\nрҹ‘‘ ЧҗЧңЧЈ Ч”Ч•ЧҰЧҗЧ•ЧӘ. ЧҗЧӘЧ” ЧҗЧңЧ•ЧЈ.';
        if (th === 2500) return '\n\nрҹҡҖ 2,500 Ч”Ч•ЧҰЧҗЧ•ЧӘ. Ч”Ч ЧӘЧ•Ч ЧҷЧқ Ч©ЧңЧҡ Ч©Ч•Ч•ЧҷЧқ Ч–Ч”Ч‘ вҖ” Ч‘-https://kesefle.com/dashboard ЧҷЧ© Ч“Ч‘ЧЁЧҷЧқ ЧһЧўЧ ЧҷЧҷЧ ЧҷЧқ.';
      }
    }
  } catch (e) {}
  return null;
}

