  '57':  'America/Bogota'
};

function _tzFromPhone_(phone) {
  if (!phone) return DEFAULT_TZ;
  var clean = String(phone).replace(/[^0-9]/g, '');
  if (!clean) return DEFAULT_TZ;
  var codes = ['972', '971', '966', '852', '358', '353', '351', '380', '420'];
  for (var i = 0; i < codes.length; i++) {
    if (clean.indexOf(codes[i]) === 0 && COUNTRY_TZ_MAP[codes[i]]) {
      return COUNTRY_TZ_MAP[codes[i]];
    }
  }
  var lens = [3, 2, 1];
  for (var j = 0; j < lens.length; j++) {
    var prefix = clean.slice(0, lens[j]);
    if (COUNTRY_TZ_MAP[prefix]) return COUNTRY_TZ_MAP[prefix];
  }
  return DEFAULT_TZ;
}

function _getUserTz_(fromPhone) {
  if (!fromPhone) return DEFAULT_TZ;
  try {
    if (typeof kvGet === 'function') {
      var stored = kvGet('tz:' + fromPhone);
      if (stored && typeof stored === 'string') return stored;
    }
  } catch (_e) {}
  var detected = _tzFromPhone_(fromPhone);
  try {
    if (typeof kvSet === 'function') kvSet('tz:' + fromPhone, detected, 0);
  } catch (_e2) {}
  return detected;
}

function _setUserTz_(fromPhone, tz) {
  if (!fromPhone || !tz) return false;
  try {
    if (typeof kvSet === 'function') return kvSet('tz:' + fromPhone, tz, 0);
  } catch (_e) {}
  return false;
}

function _isValidTz_(tz) {
  if (!tz || typeof tz !== 'string') return false;
  try {
    Utilities.formatDate(new Date(), tz, 'yyyy');
    return true;
  } catch (_e) { return false; }
}

function _handleTimezoneCommand_(fromPhone, text) {
  var raw = String(text == null ? '' : text).trim();
  if (!raw) return { handled: false };
  var norm = raw.replace(/^\//, '').trim();
  var m = norm.match(/^(?:ЧҗЧ–Ч•ЧЁ\s*Ч–ЧһЧҹ|timezone|tz)(?:\s+(.+))?$/i);
  if (!m) return { handled: false };
  var arg = (m[1] || '').trim();
  if (!arg) {
    var cur = _getUserTz_(fromPhone);
    return { handled: true, replyText:
      'рҹҢҚ *ЧҗЧ–Ч•ЧЁ Ч”Ч–ЧһЧҹ Ч©ЧңЧҡ*\n' +
      'в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n' +
      cur + '\n\n' +
      'рҹ’Ў ЧңЧ©ЧҷЧ Ч•Чҷ: "ЧҗЧ–Ч•ЧЁ Ч–ЧһЧҹ America/Los_Angeles"\n' +
      'ЧЁЧ©ЧҷЧһЧ”: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones'
    };
  }
  if (!_isValidTz_(arg)) {
    return { handled: true, replyText:
      'рҹҳ¬ ЧҗЧ–Ч•ЧЁ Ч–ЧһЧҹ ЧңЧҗ ЧӘЧ§ЧҷЧҹ: ' + arg + '\n' +
      'рҹ’Ў Ч”Ч©ЧӘЧһЧ© Ч‘ЧӨЧ•ЧЁЧһЧҳ IANA, ЧңЧһЧ©Чң "America/Los_Angeles" ЧҗЧ• "Europe/London"'
    };
  }
  var ok = _setUserTz_(fromPhone, arg);
  if (!ok) {
    return { handled: true, replyText:
      'рҹҳ¬ ЧңЧҗ Ч”ЧҰЧңЧ—ЧӘЧҷ ЧңЧ©ЧһЧ•ЧЁ ЧҗЧӘ ЧҗЧ–Ч•ЧЁ Ч”Ч–ЧһЧҹ\n' +
      'рҹ’Ў Ч Ч ЧЎЧ” Ч©Ч•Ч‘ Ч‘ЧўЧ•Ч“ Ч“Ч§Ч”?'
    };
  }
  return { handled: true, replyText:
    'вң… ЧҗЧ–Ч•ЧЁ Ч”Ч–ЧһЧҹ ЧўЧ•Ч“ЧӣЧҹ Чң-' + arg + '\n' +
    'ЧһЧўЧӣЧ©ЧҷЧ• ЧӘЧҗЧЁЧҷЧӣЧҷЧқ Ч‘ЧӘЧ’Ч•Ч‘Ч•ЧӘ ЧҷЧ•ЧҰЧ’Ч• ЧңЧӨЧҷ Ч”Ч©ЧўЧ•Чҹ Ч”Ч–Ч”.'
  };
}

// ============================================================
// рҹ’° ЧңЧ•Ч’ЧҷЧ§ЧӘ ЧўЧҷЧ‘Ч•Ч“ Ч”Ч•ЧҰЧҗЧ”
// ============================================================

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Rich business-order parser
//
// Handles messages like:
//   "ЧўЧЎЧ§ 880 Ч©Чқ ЧңЧ§Ч•Ч— ЧҗЧ‘ЧҷЧ–ЧӣЧЁ Ч’Ч•Ч“Чң ЧӘЧһЧ•Ч Ч” 120-80 Ч§Ч Ч‘ЧЎ ЧўЧңЧ•ЧӘ ЧҷЧҷЧҰЧ•ЧЁ 240 ЧўЧңЧ•ЧӘ ЧһЧӣЧҷЧЁЧ” 880 ЧһЧ©ЧңЧ•Ч— 45"
//   "ЧўЧЎЧ§ 1200 ЧңЧ§Ч•Ч— Ч©ЧЁЧ•Чҹ 50x70 Ч‘Ч“ ЧўЧңЧ•ЧӘ 400 ЧһЧ©ЧңЧ•Ч— 30"
//   "ЧўЧЎЧ§ 880 ЧҗЧ‘ЧҷЧ–ЧӣЧЁ 120-80 Ч§Ч Ч‘ЧЎ ЧҷЧҷЧҰЧ•ЧЁ 240 ЧһЧӣЧҷЧЁЧ” 880 ЧһЧ©ЧңЧ•Ч— 45"
//
// Extracts the labeled fields (customer, size, material, production cost,
// sale price, shipping) so we can write a structured row into the Ч”Ч–ЧһЧ Ч•ЧӘ
// tab and compute profit, rather than dumping the whole string into the
// flat ЧӘЧ Ч•ЧўЧ•ЧӘ sheet. Returns null if the message doesn't look like a
// rich order (so the caller falls back to the existing one-line flow).
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
var _ORDER_MATERIALS_ = ['Ч§Ч Ч‘ЧЎ','Ч‘Ч“','Ч ЧҷЧҷЧЁ','ЧҗЧ§ЧЁЧҷЧңЧҷЧ§','ЧўЧҘ','Ч–ЧӣЧ•ЧӣЧҷЧӘ','ЧһЧӘЧӣЧӘ','PVC','Ч§ЧЁЧҳЧ•Чҹ','ЧһЧ©Чҷ','ЧўЧ•ЧЁ','ЧӨЧ•ЧңЧҷЧҗЧЎЧҳЧЁ'];

function parseBusinessOrder_(text) {
  if (!text) return null;
  var s = String(text).trim();
  // Must start with the ЧўЧЎЧ§ / ЧўЧЎЧ§Ч” / ЧўЧЎЧ§ЧӘ / biz / business prefix;
  // otherwise treat as personal.
  //
  // 2026-05-28 B2 fix (PR audit Agent 4): also accept "ЧўЧЎЧ§Ч”" (deal) and
  // "ЧўЧЎЧ§ЧӘ" (construct state) вҖ” Steven naturally writes
  //   "ЧўЧЎЧ§Ч” ЧҷЧ•ЧЎЧҷ Ч”ЧӣЧ ЧЎЧ” 10000 ЧўЧ•Ч‘Ч“ЧҷЧқ 2500 Ч—Ч•ЧһЧЁЧҷЧқ 1200"
  // which was silently dropped by the old prefix regex because the
  // lookahead required a non-Hebrew-letter immediately after "ЧўЧЎЧ§"
  // (so the Ч” or ЧӘ suffix failed the test).
  // ORDER MATTERS: ЧўЧЎЧ§Ч” / ЧўЧЎЧ§ЧӘ before ЧўЧЎЧ§ so the longer prefix matches
  // first and gets stripped fully.
  //
  // 2026-06-02 NL-income fix: the original gate ONLY fired when the message
  // STARTED with ЧўЧЎЧ§/ЧўЧЎЧ§Ч”/biz, so a natural sentence like
  //   "ЧҷЧ© ЧңЧҷ Ч”ЧӣЧ ЧЎЧ” Ч‘ЧўЧЎЧ§ Ч©Чң Ч”ЧӘЧһЧ•Ч Ч•ЧӘ ... Ч”ЧңЧ§Ч•Ч—Ч” Ч©ЧҷЧңЧһЧ” 1700 ... + 450 ЧңЧ”ЧӘЧ§Ч Ч”"
  // was dropped (it starts with "ЧҷЧ©", and "Ч‘ЧўЧЎЧ§" is the clitic Ч‘+ЧўЧЎЧ§ form
  // that the standalone gate never recognised) вҖ” it fell to the PERSONAL
  // classifier. We now ALSO accept the order shape when a business marker
  // appears ANYWHERE in the text, in standalone OR clitic form
  // ([Ч‘ЧңЧһ]?ЧўЧЎЧ§ with an optional Ч”/ЧӘ suffix вҶ’ covers ЧўЧЎЧ§ / Ч‘ЧўЧЎЧ§ / ЧңЧўЧЎЧ§ /
  // ЧһЧўЧЎЧ§ / ЧўЧЎЧ§Ч” / ЧўЧЎЧ§ЧӘ / Ч‘ЧўЧЎЧ§Ч”). This is ANCHORED on the ЧўЧЎЧ§ token by
  // design: an income verb alone ("Ч§ЧҷЧ‘ЧңЧӘЧҷ 1700 ЧһЧӘЧ Ч”") must NOT enter the
  // order path. The existing fieldsFound<2 guard below still protects a
  // bare chat line that merely mentions the business but carries no order
  // fields (size/material/cost/labelled-sale) from becoming a spurious
  // order. We deliberately exclude the bare adjective/list forms
  // ЧўЧЎЧ§Чҷ/ЧўЧЎЧ§ЧҷЧқ from the anywhere-trigger to avoid false positives.
  var _bizStartsPrefix = /^(ЧўЧЎЧ§Ч”|ЧўЧЎЧ§ЧӘ|ЧўЧЎЧ§|biz|business)(?=$|[\s:\-,0-9])/i.test(s);
  var _bizMarkerAnywhere = /(^|\s)[Ч‘ЧңЧһ]?ЧўЧЎЧ§(Ч”|ЧӘ)?(\s|$|[:,\-])/.test(s) ||
                           /(^|\s)(biz|business)(\s|$|[:,\-])/i.test(s);
  if (!_bizStartsPrefix && !_bizMarkerAnywhere) return null;
  // Strip a LEADING prefix only (no-op for the NL form, where the marker is
  // mid-sentence вҖ” there we keep the full text so the field parsers below
  // can read the headline amount, size, material and shipping in place).
  s = s.replace(/^(ЧўЧЎЧ§Ч”|ЧўЧЎЧ§ЧӘ|ЧўЧЎЧ§|biz|business)\s*[:\-]?\s*/i, '');

  function _num(re) {
    var m = s.match(re);
    if (!m) return null;
    var raw = m[1].replace(/,/g, '');
    var n = parseFloat(raw);
    return isFinite(n) && n > 0 ? n : null;
  }
  function _word(re) {
    var m = s.match(re);
    return m ? m[1].trim() : null;
  }

  // Numeric fields вҖ” each label has multiple Hebrew + English aliases so
  // the user can write fluidly. "ЧўЧңЧ•ЧӘ ЧһЧ•ЧҰЧЁ" (product cost) and "ЧўЧңЧ•ЧӘ
  // ЧӨЧЁЧҷЧҳ" (item cost) are treated as production cost, matching how
  // Steven uses them in practice. Order matters: specific multi-word
  // labels must come BEFORE the bare "ЧўЧңЧ•ЧӘ" fallback so we never
  // mistake "ЧўЧңЧ•ЧӘ ЧһЧӣЧҷЧЁЧ” 880" for productionCost=880.
  //
  // 2026-05-28 expansion (Steven's actual messages):
  //   productionCost: also accept bare "Ч—Ч•ЧһЧЁ Ч’ЧңЧқ"/"Ч—Ч•ЧһЧЁЧҷ Ч’ЧңЧқ"/"Ч—Ч•ЧһЧЁЧҷЧқ" without
  //                   the "ЧўЧңЧ•ЧӘ" prefix (he writes "Ч—Ч•ЧһЧЁ Ч’ЧңЧқ 375", not "ЧўЧңЧ•ЧӘ
  //                   Ч—Ч•ЧһЧЁ 375"). Also raw_materials English. The pattern
  //                   allows up to 2 words between the keyword and the number
  //                   so "ЧўЧңЧ•ЧӘ Ч—Ч•ЧһЧЁ Ч’ЧңЧқ 0" still captures the 0.
  //   salePrice: also accept "ЧһЧӣЧҷЧЁЧӘ" (construct state вҖ” "ЧһЧӣЧҷЧЁЧӘ ЧӘЧһЧ•Ч Ч” 850"
  //              is the natural Hebrew form). Allow up to 2 words between
  //              "ЧһЧӣЧҷЧЁЧӘ"/"ЧһЧӣЧҷЧЁЧ”" and the number.
  //   shipping: also accept "ЧһЧ©ЧңЧ•Ч— Ч•Ч”ЧӘЧ§Ч Ч”" / "ЧһЧ©ЧңЧ•Ч— Ч•Ч”Ч•Ч‘ЧңЧ”" / "Ч”ЧӘЧ§Ч Ч”" вҖ” Steven
  //             often groups shipping + install in one number. Allow up to 2
  //             words between the keyword and the number.
  // Non-greedy `{0,1}?` вҖ” try 0 skip-words FIRST, then 1. Greedy `{0,2}`
  // captured the WRONG number when keywords stacked like "Ч—Ч•ЧһЧЁ Ч’ЧңЧқ 375 ЧһЧ©ЧңЧ•Ч— 50"
  // (was capturing 50 for productionCost because it skipped "375 ЧһЧ©ЧңЧ•Ч—").
  var productionCost = _num(/(?:ЧўЧңЧ•ЧӘ\s+ЧҷЧҷЧҰЧ•ЧЁ|ЧўЧңЧ•ЧӘ\s+ЧҷЧҰЧ•ЧЁ|ЧўЧңЧ•ЧӘ\s+ЧһЧ•ЧҰЧЁ|ЧўЧңЧ•ЧӘ\s+ЧӨЧЁЧҷЧҳ|ЧўЧңЧ•ЧӘ\s+Ч—Ч•ЧһЧЁ(?:\s+Ч’ЧңЧқ)?|Ч—Ч•ЧһЧЁЧҷ?\s+Ч’ЧңЧқ|Ч—Ч•ЧһЧЁЧҷЧқ|ЧҷЧҷЧҰЧ•ЧЁ|ЧҷЧҰЧ•ЧЁ|raw\s+materials?|production|ЧўЧңЧ•ЧӘ)(?:\s+\S+){0,1}?\s*[:=]?\s*(\d+(?:[.,]\d+)?)/i);
  // Track salePrice provenance: a LABELED match counts as a field in
  // fieldsFound; a bare-amount headline fallback does NOT (else every
  // single-number message parses as a "rich order").
  var salePriceLabeled = _num(/(?:ЧўЧңЧ•ЧӘ\s+ЧһЧӣЧҷЧЁЧ”|ЧһЧ—ЧҷЧЁ\s+ЧһЧӣЧҷЧЁЧ”|ЧһЧӣЧҷЧЁЧӘ|ЧһЧӣЧҷЧЁЧ”|ЧһЧ—ЧҷЧЁ|sold|sale)(?:\s+\S+){0,1}?\s*[:=]?\s*(\d+(?:[.,]\d+)?)/i);
  var salePrice      = salePriceLabeled;
  // Shipping/installation has TWO distinct meanings depending on who paid:
  //   вҖў A COST Steven incurred ("ЧһЧ©ЧңЧ•Ч— 45", "Ч©ЧҷЧңЧһЧӘЧҷ 80 ЧһЧ©ЧңЧ•Ч—") вҖ” reduces profit
  //     and feeds the company dashboard's ЧһЧ©ЧңЧ•Ч—ЧҷЧқ Ч•Ч”ЧӘЧ§Ч Ч•ЧӘ EXPENSE row.
  //   вҖў REVENUE the customer paid ("...Ч©ЧҷЧңЧһЧ” 1700 ... + 450 ЧңЧ”ЧӘЧ§Ч Ч”") вҖ” part of
  //     the sale, must NOT be booked as a cost.
  // The keyword-FIRST labeled form ("ЧһЧ©ЧңЧ•Ч— 45" / "Ч”ЧӘЧ§Ч Ч” 450" / "Ч©ЧҷЧңЧһЧӘЧҷ 80
  // ЧһЧ©ЧңЧ•Ч—") is treated as a stated cost (unchanged behaviour, covers the
  // prefix-order path). The reverse NL form ("<amount> [Ч©Ч—] Чң<keyword>",
  // e.g. "+ 450 Ч©Ч— ЧңЧ”ЧӘЧ§Ч Ч”") is captured SEPARATELY as `installReverse` and
  // its destination (revenue vs cost) is decided below by _customerPaidOrder.
  var shipping       = _num(/(?:Ч“ЧһЧҷ\s+ЧһЧ©ЧңЧ•Ч—|ЧһЧ©ЧңЧ•Ч—\s+(?:Ч•Ч”ЧӘЧ§Ч Ч”|Ч•Ч”Ч•Ч‘ЧңЧ”|Ч•Ч”ЧӘЧ§Ч Ч•ЧӘ)|ЧһЧ©ЧңЧ•Ч—|Ч©ЧҷЧңЧ•Ч—|Ч”ЧӘЧ§Ч Ч”|Ч”ЧӘЧ§Ч Ч•ЧӘ|shipping|delivery)(?:\s+\S+){0,1}?\s*[:=]?\s*(\d+(?:[.,]\d+)?)/i);
  var installReverse = _num(/(\d+(?:[.,]\d+)?)\s*(?:Ч©["Чі']?Ч—|Ч©Ч§Чң(?:ЧҷЧқ)?|nis|вӮӘ)?\s*Чң?(?:ЧһЧ©ЧңЧ•Ч—|Ч©ЧҷЧңЧ•Ч—|Ч”ЧӘЧ§Ч Ч”|Ч”ЧӘЧ§Ч Ч•ЧӘ|Ч”Ч•Ч‘ЧңЧ”)(?:\s|$|[.,])/i);
  // 2026-06-02 money-semantics fix: detect a CUSTOMER-paid / income order.
  // Fires only on the new NL trigger (business marker mid-sentence, not the
  // ЧўЧЎЧ§-prefix form) with an income/customer-payment signal, and only when
  // Steven did NOT explicitly say HE paid the shipping/installation.
  var _stevenPaidShip = /Ч©ЧҷЧңЧһЧӘЧҷ(?:\s+\S+){0,3}?\s*(?:ЧўЧң\s+)?(?:ЧһЧ©ЧңЧ•Ч—|Ч©ЧҷЧңЧ•Ч—|Ч”ЧӘЧ§Ч Ч”|Ч”ЧӘЧ§Ч Ч•ЧӘ|Ч”Ч•Ч‘ЧңЧ”)/.test(s);
  var _incomeSignal   = /(?:Ч”ЧӣЧ ЧЎЧ”|Ч”ЧӣЧ ЧЎЧ•ЧӘ|Ч©ЧҷЧңЧһ(?:Ч”|Ч•|ЧӘЧқ)?|Ч©ЧҷЧңЧқ|ЧһЧӣЧЁ(?:ЧӘЧҷ|Ч Ч•|Ч”)?|ЧһЧӣЧҷЧЁЧ”|Ч§ЧҷЧ‘ЧңЧӘЧҷ\s+ЧӘЧ©ЧңЧ•Чқ|ЧңЧ§Ч•Ч—[Ч”]?\s+Ч©ЧҷЧңЧһ)/.test(s);
  var _customerPaidOrder = _bizMarkerAnywhere && !_bizStartsPrefix && _incomeSignal && !_stevenPaidShip;
  var _installAsRevenue = false; // set true below when we fold the add-on into the sale
  if (!_customerPaidOrder) {
    // Cost-phrasing path (prefix orders, or Steven explicitly paid): the
    // reverse NL form is also a shipping COST when the keyword-first pass
    // found nothing. Preserves the prior behaviour for "+ 450 ЧңЧ”ЧӘЧ§Ч Ч”" in a
    // Steven-paid / prefix context.
    if (shipping == null && installReverse != null) shipping = installReverse;
  }

  // Customer name: try the explicit label first ("Ч©Чқ ЧңЧ§Ч•Ч— X" / "ЧңЧ§Ч•Ч— X").
  //
  // 2026-06-02: anchor the ЧңЧ§Ч•Ч— label on a word boundary ((^|\s) before, and a
  // space/colon after) so it does NOT match the substring "ЧңЧ§Ч•Ч—" inside the
  // NL word "Ч”ЧңЧ§Ч•Ч—Ч”" ("the customer paid"), which used to capture a junk
  // customer of "Ч” Ч©ЧҷЧңЧһЧ”". A genuine "ЧңЧ§Ч•Ч— Ч“Ч Чҷ" (space-separated) still
  // matches. The capture must also start with a Hebrew/Latin letter so we
  // never grab a stray verb fragment.
  var customer = _word(/(?:^|\s)(?:Ч©Чқ\s+ЧңЧ§Ч•Ч—|ЧңЧ§Ч•Ч—|customer)\s*[:=]?\s+([A-Za-zЦҗ-Чҝ][^\d\n]*?)(?=\s*(?:Ч’Ч•Ч“Чң|ЧӘЧһЧ•Ч Ч”|Ч§Ч Ч‘ЧЎ|Ч‘Ч“|Ч ЧҷЧҷЧЁ|ЧҗЧ§ЧЁЧҷЧңЧҷЧ§|ЧўЧҘ|Ч–ЧӣЧ•ЧӣЧҷЧӘ|ЧһЧӘЧӣЧӘ|PVC|Ч§ЧЁЧҳЧ•Чҹ|ЧўЧңЧ•ЧӘ|ЧһЧ—ЧҷЧЁ|ЧһЧӣЧҷЧЁЧ”|ЧҷЧҷЧҰЧ•ЧЁ|ЧҷЧҰЧ•ЧЁ|ЧһЧ•ЧҰЧЁ|ЧӨЧЁЧҷЧҳ|ЧһЧ©ЧңЧ•Ч—|Ч©ЧҷЧңЧ•Ч—|\d{2,})|$)/i);
  // Fallback: if no explicit label, grab the leading Hebrew text right
  // after the "ЧўЧЎЧ§" prefix up to the first labelled field or number.
  // Lets the user write "ЧўЧЎЧ§ ЧңЧҷЧ” ЧһЧЁЧһЧӘ Ч’Чҹ Ч’Ч•Ч“Чң ..." without forcing the
  // "ЧңЧ§Ч•Ч—" keyword. Capped at 40 chars to avoid grabbing the whole
  // message when no labelled field appears later.
  //
  // 2026-06-02: ONLY apply this leading-text heuristic for the prefix form
  // (message STARTED with ЧўЧЎЧ§). In the NL form the marker sits mid-sentence
  // ("ЧҷЧ© ЧңЧҷ Ч”ЧӣЧ ЧЎЧ” Ч‘ЧўЧЎЧ§ ... Ч”ЧңЧ§Ч•Ч—Ч” Ч©ЧҷЧңЧһЧ” 1700"), so the leading words are
  // narration, not a name вҖ” grabbing them produced a junk customer like
  // "Ч” Ч©ЧҷЧңЧһЧ”". For NL we leave customer blank (the explicit "ЧңЧ§Ч•Ч— X" label
  // above still works) and let the reply invite the user to add a name.
  if (!customer && _bizStartsPrefix) {
    var leadM = s.match(/^([^\d\n]+?)(?=\s*(?:Ч’Ч•Ч“Чң|ЧӘЧһЧ•Ч Ч”|Ч§Ч Ч‘ЧЎ|Ч‘Ч“|Ч ЧҷЧҷЧЁ|ЧҗЧ§ЧЁЧҷЧңЧҷЧ§|ЧўЧҘ|Ч–ЧӣЧ•ЧӣЧҷЧӘ|ЧһЧӘЧӣЧӘ|PVC|Ч§ЧЁЧҳЧ•Чҹ|ЧўЧңЧ•ЧӘ|ЧһЧ—ЧҷЧЁ|ЧһЧӣЧҷЧЁЧ”|ЧҷЧҷЧҰЧ•ЧЁ|ЧҷЧҰЧ•ЧЁ|ЧһЧ•ЧҰЧЁ|ЧӨЧЁЧҷЧҳ|ЧһЧ©ЧңЧ•Ч—|Ч©ЧҷЧңЧ•Ч—|\d{2,}))/);
    if (leadM) {
      var lead = leadM[1].trim();
      // Skip bare prefixes like "biz:" or "business" that the strip-
      // regex above already consumed, plus single-token noise.
      if (lead.length >= 2 && lead.length <= 40 && !/^(?:biz|business)\b/i.test(lead)) {
        customer = lead;
      }
    }
  }

  // Size: accepts "120-80", "120x80", "120Г—80", optional "ЧЎ\"Чһ" / "cm".
  var sizeRaw = _word(/(?:Ч’Ч•Ч“Чң(?:\s+ЧӘЧһЧ•Ч Ч”)?|size)\s*[:=]?\s*([0-9]+\s*[-xXГ—]\s*[0-9]+(?:\s*(?:cm|ЧЎ["Чі']?Чқ))?)/i);
  if (!sizeRaw) {
    // Fall back: any bare "NxN" / "N-N" pattern (e.g. user wrote
    // "ЧҗЧ‘ЧҷЧ–ЧӣЧЁ 120-80 Ч§Ч Ч‘ЧЎ" without the "Ч’Ч•Ч“Чң" label).
    var sizeMatch = s.match(/(?:^|\s)([0-9]{2,4}\s*[-xXГ—]\s*[0-9]{2,4})(?=\s|$)/);
    if (sizeMatch) sizeRaw = sizeMatch[1];
  }
  var size = sizeRaw ? sizeRaw.replace(/\s+/g, '').replace(/[xXГ—]/, 'Г—') : null;

  // Material: look for any of the known material tokens. First hit wins.
  var material = null;
  for (var i = 0; i < _ORDER_MATERIALS_.length; i++) {
    var mat = _ORDER_MATERIALS_[i];
    if (new RegExp('(?:^|\\s)' + mat + '(?:\\s|$)', 'i').test(s)) { material = mat; break; }
  }

  // Headline amount вҖ” first standalone number that ISN'T already eaten
  // by one of the labelled fields. Used as a fallback for salePrice and
  // for the ЧӘЧ Ч•ЧўЧ•ЧӘ "amount" column.
  var headline = null;
  var allNums = s.match(/\d+(?:[.,]\d+)?/g) || [];
  for (var j = 0; j < allNums.length; j++) {
    var n = parseFloat(allNums[j].replace(',', ''));
    if (!isFinite(n) || n <= 0) continue;
    // Skip if this number is the only digit in a size like "120-80"
    if (/-\s*\d/.test(allNums[j]) || /Г—|x/i.test(allNums[j])) continue;
    headline = n;
    break;
  }
  if (salePrice == null && headline != null) salePrice = headline;

  // 2026-06-02 money-semantics fix вҖ” CUSTOMER-paid / income order.
  // Every amount the customer paid is REVENUE, so the sale price is the
  // headline/labeled product price PLUS any "+ X" add-on like installation.
  // The add-on (installReverse) is folded into salePrice and shipping(cost)
  // is forced to 0 вҖ” it must never reduce revenue or profit. The add-on
  // label is remembered so the description reads e.g. "ЧӘЧһЧ•Ч Ч” 80Г—120 Ч–ЧӣЧ•ЧӣЧҷЧӘ
  // + Ч”ЧӘЧ§Ч Ч”". Example: "Ч”ЧңЧ§Ч•Ч—Ч” Ч©ЧҷЧңЧһЧ” 1700 ... + 450 Ч©Ч— ЧңЧ”ЧӘЧ§Ч Ч”"
  //   вҶ’ salePrice 2150, shipping 0, profit 2150 (no cost stated).
  var _installLabelHe = '';
  if (_customerPaidOrder) {
    if (installReverse != null && installReverse > 0) {
      // Identify what the add-on was called (installation vs shipping) for
      // the description note.
      if (/(?:Ч”ЧӘЧ§Ч Ч”|Ч”ЧӘЧ§Ч Ч•ЧӘ)/.test(s))      _installLabelHe = 'Ч”ЧӘЧ§Ч Ч”';
      else if (/(?:ЧһЧ©ЧңЧ•Ч—|Ч©ЧҷЧңЧ•Ч—|Ч”Ч•Ч‘ЧңЧ”)/.test(s)) _installLabelHe = 'ЧһЧ©ЧңЧ•Ч—';
      // Fold the add-on into the sale (revenue). salePrice here is the
      // product headline (or a labeled ЧһЧӣЧҷЧЁЧ” price); the add-on is a
      // distinct number captured by installReverse, so summing is correct.
      var _base = (salePrice != null) ? salePrice : 0;
      salePrice = _base + installReverse;
      _installAsRevenue = true;
    }
    // Customer-paid orders never carry a shipping COST inferred from the
    // customer's payment. (An explicit Steven-paid cost would have set
    // _customerPaidOrder=false above.)
    shipping = null;
  }

  // Only treat as a "rich order" when we got at least 2 distinct fields
  // beyond a bare amount. Otherwise the caller falls back to the existing
  // dropdown flow (which serves "ЧўЧЎЧ§ 24 Ч©ЧҷЧ•Ч•Ч§" style messages).
  // 2026-05-28: a LABELED salePrice ("ЧһЧӣЧҷЧЁЧӘ ЧӘЧһЧ•Ч Ч” 300") now counts as a
  // field. Previously only counted if `headline !== salePrice`, which
  // meant "ЧһЧӣЧҷЧЁЧӘ ЧӘЧһЧ•Ч Ч” 300 ЧЁЧ•Ч•Ч— Ч ЧҳЧ• 300" (where salePrice == headline)
  // didn't parse as an order.
  var fieldsFound = 0;
  if (customer)         fieldsFound++;
  if (size)             fieldsFound++;
  if (material)         fieldsFound++;
  if (productionCost)   fieldsFound++;
  if (shipping)         fieldsFound++;
  if (salePriceLabeled != null) fieldsFound++;
  // 2026-06-02: a customer-paid income order counts its add-on (installation/
  // shipping the customer paid) as a field, and a customer-payment signal
  // together with a sale price is itself a strong order signal. This keeps a
  // genuine NL income order (e.g. "...Ч©ЧҷЧңЧһЧ” 1700 ... + 450 Ч”ЧӘЧ§Ч Ч”") from
  // failing the вүҘ2-fields gate when it lacks an explicit size/material. It
  // does NOT affect the prefix path (_customerPaidOrder is false there).
  if (_installAsRevenue) fieldsFound++;
  if (_customerPaidOrder && salePrice != null) fieldsFound++;
  if (fieldsFound < 2) return null;

  var profit = null;
  if (salePrice != null) {
    profit = salePrice - (productionCost || 0) - (shipping || 0);
  }

  // Build a human description that carries the product + the customer-paid
  // add-on (e.g. "ЧӘЧһЧ•Ч Ч” 80Г—120 Ч–ЧӣЧ•ЧӣЧҷЧӘ + Ч”ЧӘЧ§Ч Ч”"), so the order row and the
  // reply both spell out what the revenue covered.
  var _prodBits = [];
  if (size || material) _prodBits.push('ЧӘЧһЧ•Ч Ч”');
  if (size)     _prodBits.push(size);
  if (material) _prodBits.push(material);
  var descNote = _prodBits.join(' ');
  if (_installAsRevenue && _installLabelHe) {
    descNote = (descNote ? descNote + ' + ' : '+ ') + _installLabelHe;
  }

  return {
    customer:       customer || '',
    size:           size || '',
    material:       material || '',
    productionCost: productionCost,
    salePrice:      salePrice,
    shipping:       shipping,
    profit:         profit,
    rawText:        text,
    amount:         salePrice || headline || 0,
    // 2026-06-02 customer-paid breakdown fields (empty/false on the
    // prefix-order path, so it is unchanged):
    installRevenue: _installAsRevenue ? installReverse : null,
    installLabel:   _installAsRevenue ? _installLabelHe : '',
    productPrice:   _installAsRevenue ? (salePrice - installReverse) : null,
    descNote:       descNote || '',
  };
}

// Append a parsed order to the Ч”Ч–ЧһЧ Ч•ЧӘ tab on the company sheet. Columns
// (A-L) match the existing year-tab order log we already maintain:
//   A: timestamp
//   B: month (yyyy-MM)
//   C: customer
//   D: size
//   E: material
//   F: production cost
//   G: sale price
//   H: shipping
//   I: profit
//   J: source ('WhatsApp')
//   K: raw text
//   L: status ('paid' assumed; user can edit)
function _writeOrderRow_(parsed) {
  try {
    var ss = SpreadsheetApp.openById(SHEET_ID);
    var sheet = ss.getSheetByName(ORDERS_TAB_NAME);
    if (!sheet) {
      Logger.log('_writeOrderRow_: orders tab "' + ORDERS_TAB_NAME + '" not found');
      return { ok: false, error: 'orders_tab_not_found' };
    }
    var now = new Date();
    var month = Utilities.formatDate(now, 'Asia/Jerusalem', 'yyyy-MM');
    // Column D (size/description): for a customer-paid income order we write
    // the full human breakdown ("ЧӘЧһЧ•Ч Ч” 80Г—120 Ч–ЧӣЧ•ЧӣЧҷЧӘ + Ч”ЧӘЧ§Ч Ч”") so the order
    // log spells out what the revenue covered. For the prefix-order path
    // parsed.descNote is just the size/material, and we keep the plain size
    // here to avoid changing that column's prior content.
    var _sizeCol = (parsed.installRevenue && parsed.descNote)
      ? parsed.descNote
      : (parsed.size || '');
    var row = [
      now,
      month,
      sanitizeForSheet(parsed.customer),
      sanitizeForSheet(_sizeCol),
      sanitizeForSheet(parsed.material),
      parsed.productionCost || 0,
      parsed.salePrice || 0,
      parsed.shipping || 0,
      parsed.profit != null ? parsed.profit : '',
      'WhatsApp',
      sanitizeForSheet(parsed.rawText),
      'paid',
    ];
    sheet.appendRow(row);
    // Also push the gross revenue into the ЧһЧҗЧ–Чҹ Ч—Ч‘ЧЁЧ” dashboard so the
    // monthly ЧһЧ—Ч–Ч•ЧЁ Ч‘ЧЁЧ•ЧҳЧ• cell reflects the new order immediately.
    try {
      if (typeof _updateBusinessDashboard_ === 'function' && parsed.salePrice) {
        _updateBusinessDashboard_('ЧўЧЎЧ§', 'ЧһЧ—Ч–Ч•ЧЁ', month, parsed.salePrice);
      }
    } catch (_dashErr) { Logger.log('_writeOrderRow_ dashboard err: ' + (_dashErr && _dashErr.message)); }
    return { ok: true, rowNumber: sheet.getLastRow() };
  } catch (e) {
    Logger.log('_writeOrderRow_ THREW: ' + (e && e.stack || e));
    return { ok: false, error: 'append_threw', detail: e && e.message };
  }
}

// Aggregate the Ч”Ч–ЧһЧ Ч•ЧӘ tab for the current calendar month and return a
// human-readable Hebrew summary. Designed for the "Ч”Ч–ЧһЧ Ч•ЧӘ" / "orders"
// WhatsApp command вҖ” fits inside a single message and gives the owner
// a quick "how am I doing this month" snapshot without opening Sheets.
function getOrdersSummary() {
  try {
    var ss = SpreadsheetApp.openById(SHEET_ID);
    var sheet = ss.getSheetByName(ORDERS_TAB_NAME);
    if (!sheet) {
      return 'рҹҳ¬ ЧңЧҗ ЧһЧҰЧҗЧӘЧҷ ЧҗЧӘ ЧңЧ©Ч•Ч ЧҷЧӘ "' + ORDERS_TAB_NAME + '". Ч Ч ЧЎЧ” Ч©Ч•Ч‘ Ч‘ЧўЧ•Ч“ Ч“Ч§Ч”?';
    }
    var last = sheet.getLastRow();
    if (last < 2) {
      return 'рҹ“Ұ *Ч”Ч–ЧһЧ Ч•ЧӘ Ч”Ч—Ч•Ч“Ч©*\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\nЧҗЧҷЧҹ Ч”Ч–ЧһЧ Ч•ЧӘ ЧўЧ“ЧҷЧҷЧҹ Ч”Ч—Ч•Ч“Ч©.\nЧ©ЧңЧ— ЧңЧҷ Ч”Ч–ЧһЧ Ч” ЧӣЧ“Чҷ ЧңЧ”ЧӘЧ—ЧҷЧң вҖ” ЧңЧ“Ч•Ч’ЧһЧ”:\n"ЧўЧЎЧ§ 880 ЧңЧ§Ч•Ч— ЧңЧҷЧ” Ч’Ч•Ч“Чң 50-70 Ч§Ч Ч‘ЧЎ ЧўЧңЧ•ЧӘ ЧһЧ•ЧҰЧЁ 240 ЧһЧ©ЧңЧ•Ч— 45"';
    }
    var thisMonth = Utilities.formatDate(new Date(), 'Asia/Jerusalem', 'yyyy-MM');
    // Columns A-L: timestamp, month, customer, size, material, prod, sale, ship, profit, source, raw, status
    var rng = sheet.getRange(2, 1, last - 1, 12).getValues();
    var count = 0, revenue = 0, productionCost = 0, shipping = 0, profit = 0;
    var lastFive = [];
    for (var i = rng.length - 1; i >= 0; i--) {
      var r = rng[i];
      var rowMonth = String(r[1] || '');
      if (rowMonth !== thisMonth) continue;
      count++;
      revenue        += Number(r[6]) || 0;
      productionCost += Number(r[5]) || 0;
      shipping       += Number(r[7]) || 0;
      profit         += Number(r[8]) || 0;
      if (lastFive.length < 5) {
        var when = r[0] instanceof Date
          ? Utilities.formatDate(r[0], 'Asia/Jerusalem', 'dd/MM')
          : String(r[0]).slice(0, 5);
        var who = String(r[2] || '?');
        var sale = Number(r[6]) || 0;
        lastFive.push('  вҖў ' + when + ' В· ' + who + ' В· вӮӘ' + sale.toLocaleString('he-IL'));
      }
    }
    var out = [];
    out.push('рҹ“Ұ *Ч”Ч–ЧһЧ Ч•ЧӘ Ч”Ч—Ч•Ч“Ч© (' + thisMonth + ')*');
    out.push('в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ');
    out.push('');
    out.push('ЧЎЧ”"Чӣ Ч”Ч–ЧһЧ Ч•ЧӘ: ' + count);
    out.push('рҹ’° ЧһЧ—Ч–Ч•ЧЁ: вӮӘ' + revenue.toLocaleString('he-IL'));
    out.push('рҹҸӯ ЧўЧңЧ•ЧӘ ЧһЧ•ЧҰЧЁ: вӮӘ' + productionCost.toLocaleString('he-IL'));
    out.push('рҹҡҡ ЧһЧ©ЧңЧ•Ч—: вӮӘ' + shipping.toLocaleString('he-IL'));
    out.push('рҹ“Ҳ ЧЁЧ•Ч•Ч—: вӮӘ' + profit.toLocaleString('he-IL'));
    if (revenue > 0) {
      out.push('   (' + Math.round((profit / revenue) * 100) + '% ЧЁЧ•Ч•Ч—ЧҷЧ•ЧӘ)');
    }
    if (lastFive.length) {
      out.push('');
      out.push('рҹ•’ *ЧҗЧ—ЧЁЧ•Ч Ч•ЧӘ:*');
      lastFive.forEach(function(l){ out.push(l); });
    }
    return out.join('\n');
  } catch (e) {
    Logger.log('getOrdersSummary err: ' + (e && e.stack || e));
    return 'рҹҳ¬ ЧңЧҗ Ч”ЧҰЧңЧ—ЧӘЧҷ ЧңЧ§ЧЁЧ•Чҗ ЧҗЧӘ Ч”Ч–ЧһЧ Ч•ЧӘ Ч”Ч—Ч•Ч“Ч©: ' + (e && e.message || '');
  }
}

// Remove the most recent row from the Ч”Ч–ЧһЧ Ч•ЧӘ tab and reverse its impact
// on the ЧһЧҗЧ–Чҹ Ч—Ч‘ЧЁЧ” dashboard. Used by the "ЧһЧ—Ч§ Ч”Ч–ЧһЧ Ч”" / "undo order"
// command. We compare against the Ч‘ЧўЧңЧ•ЧӘ-of-this-script user, which for
// the Apps Script bot is the owner вҖ” tenants don't have orders-tab
// access yet so this is owner-only behaviour for now.
function deleteLastOrder() {
  try {
    var ss = SpreadsheetApp.openById(SHEET_ID);
    var sheet = ss.getSheetByName(ORDERS_TAB_NAME);
    if (!sheet) return 'рҹҳ¬ ЧңЧҗ ЧһЧҰЧҗЧӘЧҷ ЧҗЧӘ ЧңЧ©Ч•Ч ЧҷЧӘ "' + ORDERS_TAB_NAME + '".';
    var last = sheet.getLastRow();
    if (last < 2) return 'рҹ“ӯ ЧҗЧҷЧҹ Ч”Ч–ЧһЧ Ч•ЧӘ ЧңЧһЧ—ЧҷЧ§Ч”.';
    var row = sheet.getRange(last, 1, 1, 12).getValues()[0];
    var when = row[0] instanceof Date
      ? Utilities.formatDate(row[0], 'Asia/Jerusalem', 'dd/MM HH:mm')
      : String(row[0]);
    var customer = String(row[2] || '?');
    var sale = Number(row[6]) || 0;
    var month = String(row[1] || '');
    sheet.deleteRow(last);
    // Reverse the dashboard impact if we can.
    try {
      if (typeof _updateBusinessDashboard_ === 'function' && sale > 0 && month) {
        _updateBusinessDashboard_('ЧўЧЎЧ§', 'ЧһЧ—Ч–Ч•ЧЁ', month, -sale);
      }
    } catch (_dErr) { Logger.log('deleteLastOrder dashboard reverse err: ' + (_dErr && _dErr.message)); }
    return 'рҹ—‘ Ч”Ч–ЧһЧ Ч” Ч ЧһЧ—Ч§Ч”:\n  ' + when + ' В· ' + customer + ' В· вӮӘ' + sale.toLocaleString('he-IL');
  } catch (e) {
    Logger.log('deleteLastOrder err: ' + (e && e.stack || e));
    return 'рҹҳ¬ ЧһЧ©Ч”Ч• Ч”Ч©ЧӘЧ‘Ч© Ч‘ЧһЧ—ЧҷЧ§Ч”: ' + (e && e.message || '');
  }
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Group expense commands ("ЧӣЧЎЧӨЧңЧ” ...") вҖ” Splitwise-style ledger
//
// WhatsApp Cloud API doesn't deliver group-chat webhooks, so we
// implement "groups" as virtual ledgers anyone can join with a 6-char
// invite code. Each member texts the bot 1:1 with "ЧӣЧЎЧӨЧңЧ” <command>"
// and the bot routes everything by the member's active group pointer
// (stored in KV via the Vercel /api/group endpoint).
//
// Supported sub-commands (all in Hebrew, English aliases where useful):
//   ЧӣЧЎЧӨЧңЧ” ЧҰЧ•ЧЁ <name>           Create a new group, return invite code
//   ЧӣЧЎЧӨЧңЧ” Ч”ЧҰЧҳЧЁЧЈ <code>          Join an existing group by code
//   ЧӣЧЎЧӨЧңЧ” ЧһЧҰЧ‘                  Show current active group + member list
//   ЧӣЧЎЧӨЧңЧ” Ч”Ч—ЧңЧЈ <code>           Switch active group
//   ЧӣЧЎЧӨЧңЧ” ЧўЧ–Ч•Ч‘                 Leave (clear active group pointer)
//   ЧӣЧЎЧӨЧңЧ” <amount> <desc>      Record an expense, split equally among members
//   ЧӣЧЎЧӨЧңЧ” ЧҷЧӘЧЁЧ•ЧӘ                Show net balance per member + suggested transfers
//   ЧӣЧЎЧӨЧңЧ” ЧЎЧҷЧ“Ч•ЧЁ                Same as ЧҷЧӘЧЁЧ•ЧӘ, focused on transfers only
//   ЧӣЧЎЧӨЧңЧ” Ч”Ч•ЧҰЧҗЧ•ЧӘ               Show the 5 most recent expenses
//   ЧӣЧЎЧӨЧңЧ” Ч”Ч•ЧЎЧЈ <name> <phone>  Add a member manually
//   ЧӣЧЎЧӨЧңЧ” Ч”ЧЎЧЁ <phone>          Remove a member
//   ЧӣЧЎЧӨЧңЧ” ЧһЧ—Ч§                  Undo the last expense (payer/creator only)
//   ЧӣЧЎЧӨЧңЧ” ЧўЧ–ЧЁЧ”                 This help
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function _handleGroupCommand_(fromPhone, text) {
  if (!text) return { handled: false };
  // Strip the trigger word + optional separator.
  var body = String(text).replace(/^\s*ЧӣЧЎЧӨЧңЧ”\s*[:\-]?\s*/i, '').trim();

  // No body вҶ’ show help.
  if (!body || /^(ЧўЧ–ЧЁЧ”|help|\?)$/i.test(body)) {
    return { handled: true, replyText: _groupHelp_() };
  }

  // Sub-command parsing. We try the keyword commands first; anything
  // starting with a digit is treated as a "record an expense" message.

  // Create a new group: "ЧҰЧ•ЧЁ [name]" / "create [name]" / "Ч”ЧӘЧ—Чң [name]".
  // REQUIRE a word boundary after the keyword (whitespace or end), not
  // \s* вҖ” otherwise "ЧӣЧЎЧӨЧңЧ” ЧҰЧ•ЧЁЧ” ЧҷЧӨЧ”" (a sentence about a shape) would
  // match "ЧҰЧ•ЧЁ" as a prefix and create a group named "Ч” ЧҷЧӨЧ”". The
  // mandatory \s+ (or $) means the keyword must be a standalone word.
  var mCreate = body.match(/^(?:ЧҰЧ•ЧЁ|create|Ч”ЧӘЧ—Чң|start|Ч”Ч§Чқ)(?:\s+(.*))?$/i);
  if (mCreate) return _groupCreate_(fromPhone, (mCreate[1] || '').trim());

  // Join: "Ч”ЧҰЧҳЧЁЧЈ <code>" / "join <code>" / "Ч§Ч•Ч“ <code>" вҖ” code is 6-8
  // chars (8 for new CSPRNG codes, 6 for legacy). The mandatory \s+
  // already prevents prefix-matching here.
  var mJoin = body.match(/^(?:Ч”ЧҰЧҳЧЁЧЈ|join|Ч§Ч•Ч“\s+Ч§Ч‘Ч•ЧҰЧ”|Ч§Ч•Ч“)\s+([A-Z0-9]{6,8})\b/i);
  if (mJoin) return _groupJoin_(fromPhone, mJoin[1].toUpperCase());

  // Switch active group: "Ч”Ч—ЧңЧЈ <code>" / "switch <code>"
  var mSwitch = body.match(/^(?:Ч”Ч—ЧңЧЈ|switch|ЧһЧҰЧ‘\s+Ч§Ч‘Ч•ЧҰЧ”|Ч”ЧӨЧўЧң)\s+([A-Z0-9]{6,8})\b/i);
  if (mSwitch) return _groupSetActive_(fromPhone, mSwitch[1].toUpperCase());

  // Leave the current group.
  if (/^(?:ЧўЧ–Ч•Ч‘|leave|ЧҷЧҰЧҷЧҗЧ”)$/i.test(body)) return _groupLeave_(fromPhone);

  // Status: "ЧһЧҰЧ‘" / "info" / "ЧӨЧЁЧҳЧҷЧқ"
  if (/^(?:ЧһЧҰЧ‘|info|ЧӨЧЁЧҳЧҷЧқ|status)$/i.test(body)) return _groupInfo_(fromPhone);

  // Context: show "active group" + all groups the user belongs to.
  if (/^(?:Ч”Ч§Ч©ЧЁ|context|ЧЁЧ©ЧҷЧһЧ”|Ч”Ч§Ч‘Ч•ЧҰЧ•ЧӘ Ч©ЧңЧҷ|my groups)$/i.test(body)) return _groupContext_(fromPhone);

  // Personal mode: clear the active-group pointer so plain expenses
  // (without a "ЧӣЧЎЧӨЧңЧ”" prefix) go to the personal sheet again.
  if (/^(?:ЧҗЧҷЧ©Чҷ|personal|ЧһЧҰЧ‘ ЧҗЧҷЧ©Чҷ)$/i.test(body)) return _groupLeave_(fromPhone, /*personal*/ true);

  // Quick switch to a specific group by code.
  var mSwitchTo = body.match(/^(?:ЧўЧ‘Ч•ЧЁ\s+Чң|switch\s+to|Ч”ЧӨЧўЧң\s+Ч§Ч‘Ч•ЧҰЧ”)\s+([A-Z0-9]{6,8})\b/i);
  if (mSwitchTo) return _groupSetActive_(fromPhone, mSwitchTo[1].toUpperCase());

  // Force a sheet provision / resync for the active group.
  if (/^(?:ЧЎЧ ЧӣЧЁЧҹ|resync|ЧЁЧўЧ Чҹ)$/i.test(body)) return _groupResync_(fromPhone);

  // Group report (alias for balances, kept for family-mode parity).
  if (/^(?:Ч“Ч•(?:["Чі']*?)Ч—|Ч“Ч•Ч—|report)$/i.test(body)) return _groupBalances_(fromPhone, 'full');

  // Recurring expense management.
  var mRecur = body.match(/^(?:Ч§Ч‘Ч•Чў|recurring|Ч—Ч•Ч–ЧЁ)\s+(.+)$/i);
  if (mRecur) return _groupAddRecurring_(fromPhone, mRecur[1]);
  if (/^(?:Ч§Ч‘Ч•ЧўЧҷЧқ|recurring list|ЧЁЧ©ЧҷЧһЧӘ Ч—Ч•Ч–ЧЁЧҷЧқ)$/i.test(body)) return _groupListRecurring_(fromPhone);

  // Export вҖ” email a CSV of the group's expenses.
  if (/^(?:ЧҷЧҷЧҰЧҗ|export|csv|Ч”Ч•ЧЁЧ“)$/i.test(body)) return _groupExport_(fromPhone);

  // Balances + settlements
  if (/^(?:ЧҷЧӘЧЁЧ•ЧӘ|balances?|Ч—Ч•Ч‘)$/i.test(body)) return _groupBalances_(fromPhone, 'full');
  if (/^(?:ЧЎЧҷЧ“Ч•ЧЁ|settle|Ч”ЧўЧ‘ЧЁЧ•ЧӘ)$/i.test(body)) return _groupBalances_(fromPhone, 'settle');

  // Recent expenses
  if (/^(?:Ч”Ч•ЧҰЧҗЧ•ЧӘ|expenses|ЧҗЧ—ЧЁЧ•Ч Ч•ЧӘ|recent)$/i.test(body)) return _groupRecent_(fromPhone);

  // Add / remove members
  var mAdd = body.match(/^(?:Ч”Ч•ЧЎЧЈ|add)\s+(.+)$/i);
  if (mAdd) return _groupAddMember_(fromPhone, mAdd[1]);
  var mRm = body.match(/^(?:Ч”ЧЎЧЁ|remove|delete)\s+(.+)$/i);
  if (mRm) return _groupRemoveMember_(fromPhone, mRm[1]);

  // Undo
  if (/^(?:ЧһЧ—Ч§|undo|Ч‘ЧҳЧң)$/i.test(body)) return _groupUndo_(fromPhone);

  // Otherwise: treat as expense entry вҖ” must start with an amount.
  if (/^\d/.test(body)) return _groupRecordExpense_(fromPhone, body);

  return { handled: true, replyText: 'рҹҳ¬ ЧңЧҗ Ч”Ч‘Ч ЧӘЧҷ. Ч©ЧңЧ— "ЧӣЧЎЧӨЧңЧ” ЧўЧ–ЧЁЧ”" ЧңЧЁЧ©ЧҷЧһЧӘ Ч”ЧӨЧ§Ч•Ч“Ч•ЧӘ.' };
}

