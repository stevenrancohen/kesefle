function _groupAddMember_(fromPhone, rest) {
  var a = _groupAPI_('getactive', { phone: fromPhone });
  if (!a || !a.ok || !a.active) {
    return { handled: true, replyText: 'ЧҗЧӘЧ” ЧңЧҗ Ч‘Ч§Ч‘Ч•ЧҰЧ”. Ч©ЧңЧ— "ЧӣЧЎЧӨЧңЧ” ЧҰЧ•ЧЁ".' };
  }
  // Accept "name 972XXX" or just "972XXX". Phone must be present.
  var m = rest.match(/(\+?\d[\d\-\s]{6,15})/);
  if (!m) return { handled: true, replyText: 'рҹҳ¬ ЧҰЧЁЧҷЧҡ ЧһЧЎЧӨЧЁ ЧҳЧңЧӨЧ•Чҹ. Ч“Ч•Ч’ЧһЧ”: "ЧӣЧЎЧӨЧңЧ” Ч”Ч•ЧЎЧЈ ЧҷЧ•ЧЎЧҷ 972526003090"' };
  var phone = m[1].replace(/\D+/g, '');
  var name = rest.replace(m[0], '').trim() || phone;
  var r = _groupAPI_('addmember', { code: a.active, phone: phone, name: name, requesterPhone: fromPhone });
  if (!r || !r.ok) return { handled: true, replyText: 'рҹҳ¬ Ч”Ч•ЧЎЧӨЧ” Ч ЧӣЧ©ЧңЧ”: ' + (r && r.error || 'unknown') };
  return { handled: true, replyText: 'вң… Ч”Ч•ЧЎЧЈ ' + name + ' (' + r.members + ' Ч—Ч‘ЧЁЧҷЧқ Ч‘ЧЎЧ”"Чӣ).' };
}

