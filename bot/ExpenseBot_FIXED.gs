  } catch (e) {
    Logger.log('_handleVoiceMessage_: processExpense err: ' + (e && e.stack || e));
    return { replyText: heard + '\n\nрҹҳ¬ ЧһЧ©Ч”Ч• Ч”Ч©ЧӘЧ‘Ч© Ч‘ЧЁЧҷЧ©Ч•Чқ: ' + (e && e.message || '') + '\nрҹ’Ў Ч Ч ЧЎЧ” Ч©Ч•Ч‘ Ч‘ЧўЧ•Ч“ Ч“Ч§Ч”?' };
  }

  var procReply = (procRes && procRes.reply) || '';
  // "Ч©ЧңЧ— Ч‘ЧӨЧ•ЧЁЧһЧҳ" / "вқҢ ЧңЧҗ Ч–ЧҷЧ”ЧҷЧӘЧҷ ЧЎЧӣЧ•Чқ" both mean processExpense couldn't
  // pull an amount from the transcript вҖ” guide the user to dictate
  // amount-first instead of relaying the generic help message.
  var failedParse = !procReply || /^Ч©ЧңЧ— Ч‘ЧӨЧ•ЧЁЧһЧҳ/.test(procReply) || /ЧңЧҗ Ч–ЧҷЧ”ЧҷЧӘЧҷ ЧЎЧӣЧ•Чқ/.test(procReply);
  if (failedParse) {
    return { replyText: 'рҹҺҷпёҸ Ч©ЧһЧўЧӘЧҷ "' + safeTranscribed + '" вҖ” ЧҗЧ‘Чң Ч–Ч” ЧңЧҗ Ч ЧЁЧҗЧ” ЧӣЧһЧ• Ч”Ч•ЧҰЧҗЧ”\nрҹ’Ў Ч“Ч‘ЧЁ ЧһЧ©Ч”Ч• ЧӣЧһЧ• "ЧһЧҗЧӘЧҷЧҷЧқ Ч©Ч§Чң ЧЎЧ•ЧӨЧЁ" (ЧЎЧӣЧ•Чқ Ч§Ч•Ч“Чқ)' };
  }

  // Append a voice-source line to the row note that processExpense just wrote.
  // We can't get the row number back from processExpense directly so we use
  // sheet.getLastRow() вҖ” safe because the bot serializes one message at a time.
  // SECURITY: only annotate the OWNER's sheet. A non-owner's voice expense
  // was already written to THEIR own sheet via the tenant bridge inside
  // processExpense above вҖ” we must never touch SHEET_ID for them.
  try {
    if (_isOwnerPhone_(fromPhone)) {
      var __vSheet = SpreadsheetApp.openById(SHEET_ID).getSheetByName(TRANSACTIONS_SHEET);
      if (__vSheet) {
        _kfl_appendOriginalNoteLine(__vSheet, __vSheet.getLastRow(), 'Voice transcript: "' + transcribed + '"');
      }
    }
  } catch (__vNoteErr) { Logger.log('voice note tail err: ' + (__vNoteErr && __vNoteErr.message)); }

  return { replyText: heard + '\n\n' + procReply };
}

// Turn a free-form correction string into a {category, subcategory} pair.
// Accepts:
//   "Ч‘ЧҷЧ’Ч•Ч“"                       вҶ’ use matchCategory to find a known cat/sub
//   "Ч§Ч ЧҷЧ•ЧӘ / Ч‘ЧҷЧ’Ч•Ч“"  / "Ч§Ч ЧҷЧ•ЧӘ/Ч‘ЧҷЧ’Ч•Ч“" вҶ’ split on `/`
//   anything unknown              вҶ’ put in subcategory, leave category 'ЧҗЧ—ЧЁ'
// Never returns category === subcategory.
function _resolveCorrectionPair_(raw) {
  var s = String(raw || '').trim();
  if (!s) return { category: 'ЧҗЧ—ЧЁ', subcategory: '' };
  if (s.indexOf('/') >= 0) {
    var parts = s.split('/').map(function(p){ return p.trim(); }).filter(Boolean);
    if (parts.length >= 2) return { category: parts[0], subcategory: parts.slice(1).join(' / ') };
  }
  try {
    if (typeof matchCategory === 'function') {
      var m = matchCategory(s);
      if (m && m.category) {
        var sub = (m.subcategory && m.subcategory !== m.category) ? m.subcategory : '';
        return { category: m.category, subcategory: sub };
      }
    }
  } catch (_e) { /* fall through */ }
  return { category: 'ЧҗЧ—ЧЁ', subcategory: s };
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// SMART BUDGET GOALS вҖ” PR-1 (data + commands only, no alerts yet)
// See docs/SMART_BUDGET_GOALS_DESIGN.md. PR-2 wires post-write alerts,
// PR-3 wires the pre-write block + dashboard widget.
//
// Commands recognized:
//   "Ч§Ч‘Чў ЧҷЧўЧ“ <category> <amount>"  -> POST /api/goals/upsert (spend_cap)
//   "Ч§Ч‘Чў ЧҷЧўЧ“ <amount>"              -> POST /api/goals/upsert (savings)
//   "ЧҷЧўЧ“ЧҷЧқ"                         -> GET  /api/goals/list
//   "ЧһЧ—Ч§ ЧҷЧўЧ“ <category>"            -> POST /api/goals/delete
//   "ЧҷЧўЧ“ЧҷЧқ ЧӣЧ‘Ч•Чҷ"                    -> placeholder for PR-2 alert mute
//
// Always returns {handled:false} for non-matches so other routers run.
// All calls go through KESEFLE_API_BASE + KESEFLE_BOT_SECRET (same pattern
// as _tenantWriteExpense_), so the tenant-isolation invariant is preserved
// by the API endpoint, not by the bot.
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// SMART BUDGET GOALS v2 вҖ” OBJECTIVES (PR-G2-mini, 2026-05-26)
// A user's LONG-HORIZON goal in plain language ("save 5K for a trip in June").
// Distinct from "goals" (monthly category caps from PR #72). One per user.
//
// Commands:
//   "ЧҷЧўЧ“ Ч©ЧңЧҷ"                         -> get + show
//   "ЧҷЧўЧ“ Ч—Ч“Ч©"                         -> 2-step flow: ask horizon, then desc
//   "ЧҷЧўЧ“ Ч—Ч“Ч© <horizon> <desc>"        -> one-shot create
//   "Ч”Ч©Ч’ЧӘЧҷ ЧҷЧўЧ“"                       -> mark achieved
//   "Ч”Ч©ЧӘЧ§ ЧҷЧўЧ“" / "Ч“Чҷ" / "ЧҗЧң ЧӘЧ–ЧӣЧҷЧЁ"   -> mute reminders
//   "Ч©Ч Ч” ЧҷЧўЧ“ <desc>"                  -> rename
//
// All calls route through /api/objectives/action with the bot-secret. The
// API enforces tenant isolation (phone -> userSub -> objective:{userSub}).
// Reminder cron + onboarding-question integration come in PR-G2-cron /
// PR-G2-onboarding once Steven answers Q6-Q10 from the design doc.
function _handleObjectiveCommand_(fromPhone, text) {
  if (!fromPhone || !text) return { handled: false };
  var t = String(text).trim();

  // Quick reject. Recognized triggers all contain one of these.
  if (!/(ЧҷЧўЧ“\s+Ч©ЧңЧҷ|ЧҷЧўЧ“\s+Ч—Ч“Ч©|Ч”Ч©Ч’ЧӘЧҷ\s+ЧҷЧўЧ“|Ч”Ч©ЧӘЧ§\s+ЧҷЧўЧ“|Ч©Ч Ч”\s+ЧҷЧўЧ“|^Ч“Чҷ$|^ЧҗЧң\s+ЧӘЧ–ЧӣЧҷЧЁ)/.test(t)) {
    return { handled: false };
  }

  var base = (typeof KESEFLE_API_BASE !== 'undefined') ? KESEFLE_API_BASE : '';
  var secret = '';
  try { secret = String(PropertiesService.getScriptProperties().getProperty('KESEFLE_BOT_SECRET') || ''); } catch (_se) {}
  if (!base || !secret) {
    return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧӘ Ч§Ч•Ч ЧӨЧҷЧ’Ч•ЧЁЧҰЧҷЧ” (ЧҷЧўЧ“ЧҷЧқ).' };
  }
  var clean = String(fromPhone).replace(/[^0-9]/g, '');

  function _api_(body) {
    try {
      var resp = UrlFetchApp.fetch(base + '/api/objectives/action', {
        method: 'post', contentType: 'application/json',
        headers: { 'x-kesefle-bot-secret': secret },
        payload: JSON.stringify(body),
        muteHttpExceptions: true,
      });
      return { code: resp.getResponseCode(), body: resp.getContentText() };
    } catch (e) { return { code: 0, body: '', err: e && e.message }; }
  }
  function _parseJ_(resp) {
    try { return JSON.parse(resp.body || '{}'); } catch (_) { return {}; }
  }

  // в”Җв”Җ "ЧҷЧўЧ“ Ч©ЧңЧҷ" вҖ” show current в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if (/^ЧҷЧўЧ“\s+Ч©ЧңЧҷ$/.test(t)) {
    var r1 = _api_({ phone: clean, action: 'get' });
    if (r1.code !== 200) return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ” Ч–ЧһЧ ЧҷЧӘ.' };
    var j1 = _parseJ_(r1);
    var o = j1 && j1.objective;
    if (!o) {
      return { handled: true, replyText:
        'рҹҺҜ ЧҗЧҷЧҹ ЧңЧҡ ЧҷЧўЧ“ ЧӨЧўЧҷЧң.\n\nЧңЧ§Ч‘Ч•Чў ЧҷЧўЧ“:\nвҖў "ЧҷЧўЧ“ Ч—Ч“Ч©" вҖ” ЧһЧӘЧ—ЧҷЧң Ч©ЧҷЧ—Ч” ЧҗЧҷЧӘЧҷ\nвҖў "ЧҷЧўЧ“ Ч—Ч“Ч© Ч—Ч•Ч“Ч© ЧңЧ—ЧЎЧ•Чҡ 1000 ЧңЧҳЧҷЧ•Чң" вҖ” Ч‘Ч©Ч•ЧЁЧ” ЧҗЧ—ЧӘ'
      };
    }
    return { handled: true, replyText: _formatObjectiveReply_(o) };
  }

  // в”Җв”Җ "Ч”Ч©Ч’ЧӘЧҷ ЧҷЧўЧ“" в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if (/^Ч”Ч©Ч’ЧӘЧҷ\s+ЧҷЧўЧ“$/.test(t)) {
    var r2 = _api_({ phone: clean, action: 'achieve' });
    if (r2.code === 404) return { handled: true, replyText: 'рҹӨ” ЧҗЧҷЧҹ ЧҷЧўЧ“ ЧӨЧўЧҷЧң. Ч©ЧңЧ— "ЧҷЧўЧ“ Ч—Ч“Ч©" ЧӣЧ“Чҷ ЧңЧ§Ч‘Ч•Чў ЧҗЧ—Ч“.' };
    if (r2.code !== 200) return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ” Ч–ЧһЧ ЧҷЧӘ.' };
    return { handled: true, replyText:
      'рҹҸҶ *ЧһЧ–Чң ЧҳЧ•Ч‘!* Ч”ЧҷЧўЧ“ ЧһЧЎЧ•ЧһЧҹ ЧӣЧ”Ч•Ч©Ч’.\n\nрҹ’Ў ЧЁЧ•ЧҰЧ” ЧҷЧўЧ“ Ч—Ч“Ч©? Ч©ЧңЧ— "ЧҷЧўЧ“ Ч—Ч“Ч©".'
    };
  }

  // в”Җв”Җ mute (explicit or natural-language) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if (/^Ч”Ч©ЧӘЧ§\s+ЧҷЧўЧ“$/.test(t) || /^Ч“Чҷ$/i.test(t) || /^ЧҗЧң\s+ЧӘЧ–ЧӣЧҷЧЁ(Чҷ)?$/.test(t)) {
    var r3 = _api_({ phone: clean, action: 'mute' });
    if (r3.code === 404) return { handled: true, replyText: 'рҹӨ” ЧҗЧҷЧҹ ЧҷЧўЧ“ ЧӨЧўЧҷЧң ЧңЧ”Ч©ЧӘЧҷЧ§.' };
    if (r3.code !== 200) return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ” Ч–ЧһЧ ЧҷЧӘ.' };
    return { handled: true, replyText: 'рҹ”• Ч”Ч©ЧӘЧ§ЧӘЧҷ ЧӘЧ–ЧӣЧ•ЧЁЧ•ЧӘ ЧҷЧўЧ“. Ч©ЧңЧ— "ЧҷЧўЧ“ Ч—Ч“Ч©" ЧӣЧ“Чҷ ЧңЧ”ЧӨЧўЧҷЧң Ч©Ч•Ч‘.' };
  }

  // в”Җв”Җ "Ч©Ч Ч” ЧҷЧўЧ“ <desc>" в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  var renM = t.match(/^Ч©Ч Ч”\s+ЧҷЧўЧ“\s+(.+)$/);
  if (renM) {
    var newDesc = renM[1].trim().slice(0, 200);
    if (!newDesc) return { handled: true, replyText: 'рҹӨ” ЧӘЧҷЧҗЧ•ЧЁ Ч—Ч“Ч© Ч—ЧЎЧЁ. Ч ЧЎЧ”: "Ч©Ч Ч” ЧҷЧўЧ“ <ЧӘЧҷЧҗЧ•ЧЁ>".' };
    var r4 = _api_({ phone: clean, action: 'rename', description: newDesc });
    if (r4.code === 404) return { handled: true, replyText: 'рҹӨ” ЧҗЧҷЧҹ ЧҷЧўЧ“ ЧӨЧўЧҷЧң ЧңЧ©Ч Ч•ЧӘ.' };
    if (r4.code !== 200) return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ” Ч–ЧһЧ ЧҷЧӘ.' };
    var j4 = _parseJ_(r4);
    return { handled: true, replyText: 'вң… ЧўЧ•Ч“ЧӣЧҹ:\n"' + (j4.objective && j4.objective.description) + '"' };
  }

  // в”Җв”Җ "ЧҷЧўЧ“ Ч—Ч“Ч© [horizon desc]" вҖ” one-shot OR 2-step в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  // One-shot first (parse horizon keyword off the front)
  var newM = t.match(/^ЧҷЧўЧ“\s+Ч—Ч“Ч©\s+(.+)$/);
  if (newM) {
    var tail = newM[1].trim();
    var horizon = null, rest = tail;
    var words = [
      { he: 'Ч—ЧҰЧҷ Ч©Ч Ч”', h: 'six_months' },
      { he: 'Ч—ЧҰЧҷ-Ч©Ч Ч”', h: 'six_months' },
      { he: 'Ч—Ч•Ч“Ч©',    h: 'month' },
      { he: 'ЧңЧ—Ч•Ч“Ч©',   h: 'month' },
      { he: 'Ч—Ч•Ч“Ч©Чҷ',   h: 'month' },
      { he: 'Ч©Ч Ч”',     h: 'year' },
      { he: 'ЧңЧ©Ч Ч”',    h: 'year' },
      { he: 'Ч©Ч ЧӘЧҷ',    h: 'year' },
    ];
    for (var i = 0; i < words.length; i++) {
      if (tail === words[i].he || tail.indexOf(words[i].he + ' ') === 0) {
        horizon = words[i].h;
        rest = tail.slice(words[i].he.length).trim();
        break;
      }
    }
    if (!horizon || !rest) {
      // 2026-06-01 FIX: stamp pending-objective state so the user's bare
      // "1/2/3/4" reply routes to objective-creation (see
      // _handleObjectivePendingReply_) instead of the expense fast-path.
      // If a horizon WAS parsed but the description is missing, skip the
      // horizon question and wait for the goal text directly.
      if (typeof _objPendSet_ === 'function') {
        _objPendSet_(clean, horizon ? ('desc:' + horizon) : 'horizon');
      }
      if (horizon && !rest) {
        return { handled: true, replyText:
          'рҹҺҜ ЧһЧўЧ•ЧңЧ”! Ч•ЧһЧ” Ч”ЧҷЧўЧ“ ЧўЧҰЧһЧ•?\n\n' +
          'ЧӣЧӘЧ•Ч‘ ЧңЧҷ Ч‘ЧһЧ©ЧӨЧҳ ЧҗЧ—Ч“ ЧһЧ” ЧӘЧЁЧҰЧ” ЧңЧ”Ч©ЧҷЧ’ вҖ”\n' +
          'ЧңЧ“Ч•Ч’ЧһЧ”: "ЧңЧ—ЧЎЧ•Чҡ 1000 ЧңЧҳЧҷЧ•Чң Ч‘ЧҷЧ•Ч Чҷ".'
        };
      }
      return { handled: true, replyText:
        'рҹҺҜ Ч©ЧҗЧңЧ” ЧҗЧ—ЧЁЧ•Ч Ч” вҖ” ЧһЧ” Ч”ЧҷЧўЧ“ Ч”ЧӨЧҷЧ Ч ЧЎЧҷ Ч©ЧңЧҡ?\n\n' +
        '1пёҸвғЈ ЧңЧ—Ч•Ч“Ч© Ч”Ч§ЧЁЧ•Ч‘   вҖ” Ч§ЧҰЧЁ, ЧһЧһЧ•Ч§Ч“\n' +
        '2пёҸвғЈ Чң-6 Ч—Ч•Ч“Ч©ЧҷЧқ   вҖ” Ч‘ЧҷЧ Ч•Ч Чҷ (ЧЎЧ’ЧҷЧЁЧӘ Ч—Ч•Ч‘, Ч§ЧЁЧҹ Ч—ЧҷЧЁЧ•Чқ)\n' +
        '3пёҸвғЈ ЧңЧ©Ч Ч” Ч”Ч§ЧЁЧ•Ч‘Ч”  вҖ” Ч’Ч“Ч•Чң (ЧһЧ©ЧӣЧ ЧӘЧҗ, Ч”Ч©Ч§ЧўЧ”, ЧһЧҳЧЁЧӘ Ч—ЧҷЧҷЧқ)\n' +
        '4пёҸвғЈ ЧҗЧҷЧҹ ЧңЧҷ ЧҷЧўЧ“   вҖ” Ч Ч“Ч‘ЧЁ Ч‘Ч”ЧһЧ©Чҡ\n\n' +
        'ЧўЧ Ч” Ч‘ЧһЧЎЧӨЧЁ 1/2/3/4, ЧҗЧ• Ч©ЧңЧ— Ч‘Ч©Ч•ЧЁЧ” ЧҗЧ—ЧӘ:\n' +
        '"ЧҷЧўЧ“ Ч—Ч“Ч© Ч—Ч•Ч“Ч© ЧңЧ—ЧЎЧ•Чҡ 1000 ЧңЧҳЧҷЧ•Чң Ч‘ЧҷЧ•Ч Чҷ"'
      };
    }
    var r5 = _api_({ phone: clean, action: 'set', horizon: horizon, description: rest });
    if (r5.code !== 200) {
      var j5e = _parseJ_(r5);
      return { handled: true, replyText: 'рҹҳ¬ ' + (j5e.error || ('Ч©Ч’ЧҷЧҗЧ” ' + r5.code)) };
    }
    var j5 = _parseJ_(r5);
    var horizonHe = { month: 'ЧңЧ—Ч•Ч“Ч© Ч”Ч§ЧЁЧ•Ч‘', six_months: 'Чң-6 Ч—Ч•Ч“Ч©ЧҷЧқ', year: 'ЧңЧ©Ч Ч” Ч”Ч§ЧЁЧ•Ч‘Ч”' };
    return { handled: true, replyText:
      'вң… ЧҷЧўЧ“ Ч—Ч“Ч© Ч Ч§Ч‘Чў ' + horizonHe[j5.objective.horizon] + ':\n\n' +
      '"' + j5.objective.description + '"\n\n' +
      'рҹ’Ў Ч©ЧңЧ— "ЧҷЧўЧ“ Ч©ЧңЧҷ" ЧӣЧ“Чҷ ЧңЧЁЧҗЧ•ЧӘ ЧҗЧӘ Ч”ЧЎЧҳЧҳЧ•ЧЎ Ч‘ЧӣЧң Ч–ЧһЧҹ.\n' +
      '   "Ч”Ч©Ч’ЧӘЧҷ ЧҷЧўЧ“" ЧӣЧ©ЧһЧЎЧҷЧҷЧһЧҷЧқ, ЧҗЧ• "Ч”Ч©ЧӘЧ§ ЧҷЧўЧ“" ЧӣЧ“Чҷ ЧңЧ”ЧӨЧЎЧҷЧ§ ЧӘЧ–ЧӣЧ•ЧЁЧ•ЧӘ.'
    };
  }

  // Bare "ЧҷЧўЧ“ Ч—Ч“Ч©" вҖ” start the 2-step conversation
  if (/^ЧҷЧўЧ“\s+Ч—Ч“Ч©$/.test(t)) {
    // 2026-06-01 FIX: stamp pending-objective state (see helper docs) so the
    // user's "1/2/3/4" reply routes to objective-creation, not a 1вӮӘ expense.
    if (typeof _objPendSet_ === 'function') { _objPendSet_(clean, 'horizon'); }
    return { handled: true, replyText:
      'рҹҺҜ Ч©ЧҗЧңЧ” ЧҗЧ—ЧЁЧ•Ч Ч” вҖ” ЧһЧ” Ч”ЧҷЧўЧ“ Ч”ЧӨЧҷЧ Ч ЧЎЧҷ Ч©ЧңЧҡ?\n\n' +
      '1пёҸвғЈ ЧңЧ—Ч•Ч“Ч© Ч”Ч§ЧЁЧ•Ч‘   вҖ” Ч§ЧҰЧЁ, ЧһЧһЧ•Ч§Ч“\n' +
      '2пёҸвғЈ Чң-6 Ч—Ч•Ч“Ч©ЧҷЧқ   вҖ” Ч‘ЧҷЧ Ч•Ч Чҷ (ЧЎЧ’ЧҷЧЁЧӘ Ч—Ч•Ч‘, Ч§ЧЁЧҹ Ч—ЧҷЧЁЧ•Чқ)\n' +
      '3пёҸвғЈ ЧңЧ©Ч Ч” Ч”Ч§ЧЁЧ•Ч‘Ч”  вҖ” Ч’Ч“Ч•Чң (ЧһЧ©ЧӣЧ ЧӘЧҗ, Ч”Ч©Ч§ЧўЧ”, ЧһЧҳЧЁЧӘ Ч—ЧҷЧҷЧқ)\n' +
      '4пёҸвғЈ ЧҗЧҷЧҹ ЧңЧҷ ЧҷЧўЧ“   вҖ” Ч Ч“Ч‘ЧЁ Ч‘Ч”ЧһЧ©Чҡ\n\n' +
      'ЧўЧ Ч” Ч‘ЧһЧЎЧӨЧЁ 1/2/3/4, ЧҗЧ• Ч©ЧңЧ— Ч‘Ч©Ч•ЧЁЧ” ЧҗЧ—ЧӘ:\n' +
      '"ЧҷЧўЧ“ Ч—Ч“Ч© Ч—Ч•Ч“Ч© ЧңЧ—ЧЎЧ•Чҡ 1000 ЧңЧҳЧҷЧ•Чң Ч‘ЧҷЧ•Ч Чҷ"'
    };
  }

  return { handled: false };
}

// 2026-06-01 FIX: pending-objective reply dispatcher. Called from doPost
// BEFORE the expense fast-path. Handles the user's reply to the "ЧҷЧўЧ“ Ч—Ч“Ч©"
// 1/2/3/4 prompt, and the follow-up goal-description text.
//
// Returns { handled, replyText } when it consumes the message, or
// { handled:false } to let normal routing (incl. the expense fast-path)
// continue. Critically:
//   - reply "1".."4" (END-ANCHORED) when state == "horizon" -> pick horizon
//     (1/2/3) or decline (4); NEVER books an expense.
//   - "1 Ч§ЧӨЧ”" is NOT end-anchored, so this returns {handled:false} and the
//     message books an expense exactly as before.
//   - cancel words (Ч‘ЧҷЧҳЧ•Чң / ЧңЧҗ / Ч‘ЧҳЧң) clear the pending state.
//   - while waiting for the goal text (state "desc:<h>"), a NEW expense
//     (text starting with a digit) drops the pending state and falls through
//     so the user isn't trapped.
function _handleObjectivePendingReply_(fromPhone, text) {
  if (!fromPhone || !text) return { handled: false };
  var clean = String(fromPhone).replace(/[^0-9]/g, '');
  if (!clean) return { handled: false };
  var state = (typeof _objPendGet_ === 'function') ? _objPendGet_(clean) : null;
  if (!state) return { handled: false };
  var t = String(text).trim();
  if (!t) return { handled: false };

  // Cancel words clear the flow from any stage.
  if (/^(Ч‘ЧҷЧҳЧ•Чң|Ч‘ЧҳЧң|ЧңЧҗ|ЧўЧ–Ч•Ч‘|ЧӘЧўЧ–Ч•Ч‘|cancel)$/i.test(t)) {
    if (typeof _objPendClear_ === 'function') { _objPendClear_(clean); }
    return { handled: true, replyText: 'рҹ‘Ң Ч‘Ч•ЧҳЧң. ЧӣЧ©ЧӘЧЁЧҰЧ” ЧңЧ§Ч‘Ч•Чў ЧҷЧўЧ“, Ч©ЧңЧ— "ЧҷЧўЧ“ Ч—Ч“Ч©".' };
  }

  // Stage 1: waiting for the 1/2/3/4 horizon pick.
  if (state === 'horizon') {
    var m = t.match(/^([1-4])$/);
    if (!m) {
      // Not an end-anchored 1-4 pick (e.g. "1 Ч§ЧӨЧ”", or free text). Let it
      // fall through so it books as an expense / hits other routers. We keep
      // the pending state until TTL so a clean "1" right after still works.
      return { handled: false };
    }
    var pick = m[1];
    if (pick === '4') {
      if (typeof _objPendClear_ === 'function') { _objPendClear_(clean); }
      return { handled: true, replyText:
        'рҹ‘Қ ЧҗЧҷЧҹ Ч‘ЧўЧҷЧ”, Ч Ч“Ч‘ЧЁ ЧўЧң ЧҷЧўЧ“ Ч‘Ч”ЧһЧ©Чҡ.\n' +
        'ЧһЧӘЧҷ Ч©ЧӘЧЁЧҰЧ” вҖ” Ч©ЧңЧ— "ЧҷЧўЧ“ Ч—Ч“Ч©".'
      };
    }
    var horizonByPick = { '1': 'month', '2': 'six_months', '3': 'year' };
    var horizon = horizonByPick[pick];
    if (typeof _objPendSet_ === 'function') { _objPendSet_(clean, 'desc:' + horizon); }
    var horizonHe = { month: 'ЧңЧ—Ч•Ч“Ч© Ч”Ч§ЧЁЧ•Ч‘', six_months: 'Чң-6 Ч—Ч•Ч“Ч©ЧҷЧқ', year: 'ЧңЧ©Ч Ч” Ч”Ч§ЧЁЧ•Ч‘Ч”' };
    return { handled: true, replyText:
      'рҹҺҜ ЧһЧўЧ•ЧңЧ” вҖ” ЧҷЧўЧ“ ' + horizonHe[horizon] + '.\n\n' +
      'Ч•ЧһЧ” Ч”ЧҷЧўЧ“ ЧўЧҰЧһЧ•? ЧӣЧӘЧ•Ч‘ ЧңЧҷ Ч‘ЧһЧ©ЧӨЧҳ ЧҗЧ—Ч“ вҖ”\n' +
      'ЧңЧ“Ч•Ч’ЧһЧ”: "ЧңЧ—ЧЎЧ•Чҡ 1000 ЧңЧҳЧҷЧ•Чң Ч‘ЧҷЧ•Ч Чҷ".'
    };
  }

  // Stage 2: a horizon was picked; this message is the goal description.
  var dm = String(state).match(/^desc:(month|six_months|year)$/);
  if (dm) {
    var h = dm[1];
    // A new expense (leading digit) drops the pending objective so the user
    // isn't trapped mid-flow вҖ” mirrors the pending-category hijack guard.
    if (/^\s*\d/.test(t)) {
      if (typeof _objPendClear_ === 'function') { _objPendClear_(clean); }
      return { handled: false };
    }
    var desc = t.slice(0, 200);
    // Reuse the same API the rest of _handleObjectiveCommand_ uses.
    var base = (typeof KESEFLE_API_BASE !== 'undefined') ? KESEFLE_API_BASE : '';
    var secret = '';
    try { secret = String(PropertiesService.getScriptProperties().getProperty('KESEFLE_BOT_SECRET') || ''); } catch (_se) {}
    if (!base || !secret) {
      if (typeof _objPendClear_ === 'function') { _objPendClear_(clean); }
      return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧӘ Ч§Ч•Ч ЧӨЧҷЧ’Ч•ЧЁЧҰЧҷЧ” (ЧҷЧўЧ“ЧҷЧқ).' };
    }
    var resp;
    try {
      resp = UrlFetchApp.fetch(base + '/api/objectives/action', {
        method: 'post', contentType: 'application/json',
        headers: { 'x-kesefle-bot-secret': secret },
        payload: JSON.stringify({ phone: clean, action: 'set', horizon: h, description: desc }),
        muteHttpExceptions: true,
      });
    } catch (e) {
      // Keep state so the user can retry the description.
      return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ” Ч–ЧһЧ ЧҷЧӘ. Ч ЧЎЧ” ЧңЧ©ЧңЧ•Ч— ЧҗЧӘ Ч”ЧҷЧўЧ“ Ч©Ч•Ч‘.' };
    }
    var code = resp.getResponseCode();
    if (code !== 200) {
      var je = {};
      try { je = JSON.parse(resp.getContentText() || '{}'); } catch (_) {}
      return { handled: true, replyText: 'рҹҳ¬ ' + (je.error || ('Ч©Ч’ЧҷЧҗЧ” ' + code)) };
    }
    if (typeof _objPendClear_ === 'function') { _objPendClear_(clean); }
    var j = {};
    try { j = JSON.parse(resp.getContentText() || '{}'); } catch (_) {}
    var horizonHe2 = { month: 'ЧңЧ—Ч•Ч“Ч© Ч”Ч§ЧЁЧ•Ч‘', six_months: 'Чң-6 Ч—Ч•Ч“Ч©ЧҷЧқ', year: 'ЧңЧ©Ч Ч” Ч”Ч§ЧЁЧ•Ч‘Ч”' };
    var savedDesc = (j.objective && j.objective.description) || desc;
    var savedHor = (j.objective && j.objective.horizon) || h;
    return { handled: true, replyText:
      'вң… ЧҷЧўЧ“ Ч—Ч“Ч© Ч Ч§Ч‘Чў ' + horizonHe2[savedHor] + ':\n\n' +
      '"' + savedDesc + '"\n\n' +
      'рҹ’Ў Ч©ЧңЧ— "ЧҷЧўЧ“ Ч©ЧңЧҷ" ЧӣЧ“Чҷ ЧңЧЁЧҗЧ•ЧӘ ЧҗЧӘ Ч”ЧЎЧҳЧҳЧ•ЧЎ Ч‘ЧӣЧң Ч–ЧһЧҹ.\n' +
      '   "Ч”Ч©Ч’ЧӘЧҷ ЧҷЧўЧ“" ЧӣЧ©ЧһЧЎЧҷЧҷЧһЧҷЧқ, ЧҗЧ• "Ч”Ч©ЧӘЧ§ ЧҷЧўЧ“" ЧӣЧ“Чҷ ЧңЧ”ЧӨЧЎЧҷЧ§ ЧӘЧ–ЧӣЧ•ЧЁЧ•ЧӘ.'
    };
  }

  // Unknown state вҖ” clear it defensively and let routing continue.
  if (typeof _objPendClear_ === 'function') { _objPendClear_(clean); }
  return { handled: false };
}

// Helper вҖ” same shape as lib/objectives.js formatObjective(). Duplicated
// here because Apps Script can't import ES modules.
function _formatObjectiveReply_(o) {
  var horizonHe = { month: 'ЧңЧ—Ч•Ч“Ч©', six_months: 'ЧңЧ—ЧҰЧҷ Ч©Ч Ч”', year: 'ЧңЧ©Ч Ч” Ч”Ч§ЧЁЧ•Ч‘Ч”' };
  var MS = 24 * 60 * 60 * 1000;
  var daysLeft = Math.max(0, Math.round((o.horizonEndsAt - Date.now()) / MS));
  var status = o.achieved ? 'вң… Ч”Ч•Ч©Ч’!' : (o.muted ? 'рҹ”• ЧһЧ•Ч©ЧӘЧ§' : 'рҹ”Ҙ ЧӨЧўЧҷЧң');
  var lines = [
    'рҹҺҜ *Ч”ЧҷЧўЧ“ Ч©ЧңЧҡ* ' + (horizonHe[o.horizon] || ''),
    '',
    '"' + o.description + '"',
    '',
    'ЧЎЧҳЧҳЧ•ЧЎ: ' + status,
  ];
  if (!o.achieved) lines.push('Ч Ч©ЧҗЧЁЧ•: ' + daysLeft + ' ЧҷЧһЧҷЧқ');
  lines.push('');
  if (o.achieved) lines.push('рҹ’Ў ЧЁЧ•ЧҰЧ” ЧҷЧўЧ“ Ч—Ч“Ч©? Ч©ЧңЧ— "ЧҷЧўЧ“ Ч—Ч“Ч©"');
  else if (o.muted) lines.push('рҹ’Ў ЧӣЧ“Чҷ ЧңЧ§Ч‘Чң ЧӘЧ–ЧӣЧ•ЧЁЧ•ЧӘ Ч©Ч•Ч‘, Ч©ЧңЧ— "ЧҷЧўЧ“ Ч—Ч“Ч©"');
  else lines.push('рҹ’Ў "Ч”Ч©Ч’ЧӘЧҷ ЧҷЧўЧ“" / "Ч”Ч©ЧӘЧ§ ЧҷЧўЧ“" / "Ч©Ч Ч” ЧҷЧўЧ“ <ЧӘЧҷЧҗЧ•ЧЁ>"');
  return lines.join('\n');
}
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

function _handleGoalCommand_(fromPhone, text) {
  if (!fromPhone || !text) return { handled: false };
  var t = String(text).trim();

  // Quick reject вҖ” must contain "ЧҷЧўЧ“" or "ЧҷЧўЧ“ЧҷЧқ" to be worth parsing.
  if (t.indexOf('ЧҷЧўЧ“') === -1) return { handled: false };

  // Match shape. Same grammar as lib/goals.js parseGoalCommand.
  var mDel  = t.match(/^ЧһЧ—Ч§\s+ЧҷЧўЧ“\s+(.+)$/i);
  var mList = /^ЧҷЧўЧ“ЧҷЧқ$/i.test(t);
  var mMute = /^ЧҷЧўЧ“ЧҷЧқ\s*ЧӣЧ‘Ч•Чҷ$/i.test(t);
  var mSet  = t.match(/^(?:Ч§Ч‘Чў|Ч”Ч’Ч“ЧЁ)\s+ЧҷЧўЧ“\s+(.+)$/i);
  if (!mDel && !mList && !mMute && !mSet) return { handled: false };

  var base = (typeof KESEFLE_API_BASE !== 'undefined') ? KESEFLE_API_BASE : '';
  var secret = '';
  try { secret = String(PropertiesService.getScriptProperties().getProperty('KESEFLE_BOT_SECRET') || ''); } catch (_se) {}
  if (!base || !secret) {
    return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧӘ Ч§Ч•Ч ЧӨЧҷЧ’Ч•ЧЁЧҰЧҷЧ” (ЧҷЧўЧ“ЧҷЧқ).' };
  }
  var clean = String(fromPhone).replace(/[^0-9]/g, '');
  var commonHeaders = { 'x-kesefle-bot-secret': secret };

  // в”Җв”Җ LIST в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if (mList) {
    try {
      var resp = UrlFetchApp.fetch(base + '/api/goals/list?phone=' + encodeURIComponent(clean), {
        method: 'get', headers: commonHeaders, muteHttpExceptions: true,
      });
      var code = resp.getResponseCode();
      if (code === 404) return { handled: true, replyText: 'рҹӨ” ЧңЧҗ ЧһЧҰЧҗЧӘЧҷ ЧҗЧӘ Ч”Ч—Ч©Ч‘Ч•Чҹ Ч©ЧңЧҡ. Ч•Ч“Чҗ/Чҷ Ч©ЧһЧЎЧӨЧЁ Ч”ЧҳЧңЧӨЧ•Чҹ ЧһЧ§Ч•Ч©ЧЁ.' };
      if (code < 200 || code >= 300) return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧӘ ЧЁЧ©ЧӘ (ЧҷЧўЧ“ЧҷЧқ). Ч ЧЎЧ”/Чҷ Ч©Ч•Ч‘ Ч‘ЧўЧ•Ч“ Ч“Ч§Ч”.' };
      var j = JSON.parse(resp.getContentText() || '{}');
      var goals = (j && j.goals) || [];
      if (!goals.length) {
        return { handled: true, replyText:
          'рҹҺҜ ЧҗЧҷЧҹ ЧҷЧўЧ“ЧҷЧқ ЧӨЧўЧҷЧңЧҷЧқ.\n\nЧңЧ”Ч•ЧЎЧҷЧЈ ЧҷЧўЧ“:\nвҖў "Ч§Ч‘Чў ЧҷЧўЧ“ <Ч§ЧҳЧ’Ч•ЧЁЧҷЧ”> <ЧЎЧӣЧ•Чқ>" вҖ” ЧңЧһЧ©Чң "Ч§Ч‘Чў ЧҷЧўЧ“ ЧҗЧ•ЧӣЧң 3000"\nвҖў "Ч§Ч‘Чў ЧҷЧўЧ“ <ЧЎЧӣЧ•Чқ>" вҖ” ЧҷЧўЧ“ Ч—ЧҷЧЎЧӣЧ•Чҹ Ч—Ч•Ч“Ч©Чҷ'
        };
      }
      var lines = ['рҹҺҜ *Ч”ЧҷЧўЧ“ЧҷЧқ Ч©ЧңЧҡ:*', ''];
      for (var i = 0; i < goals.length; i++) {
        var g = goals[i];
        var amt = 'вӮӘ' + Number(g.amountILS).toLocaleString('he-IL');
        if (g.type === 'savings') lines.push('рҹ’° Ч—ЧҷЧЎЧӣЧ•Чҹ Ч—Ч•Ч“Ч©Чҷ вҖ” ' + amt);
        else lines.push('рҹ“Ҡ ' + g.category + ' вҖ” ' + amt + '/Ч—Ч•Ч“Ч©');
      }
      lines.push('');
      lines.push('рҹ’Ў ЧңЧһЧ—Ч•Ч§: "ЧһЧ—Ч§ ЧҷЧўЧ“ <Ч§ЧҳЧ’Ч•ЧЁЧҷЧ”>"');
      return { handled: true, replyText: lines.join('\n') };
    } catch (e) {
      Logger.log('_handleGoalCommand_ list err: ' + (e && e.message));
      return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ” Ч–ЧһЧ ЧҷЧӘ (ЧҷЧўЧ“ЧҷЧқ). Ч ЧЎЧ”/Чҷ Ч©Ч•Ч‘.' };
    }
  }

  // в”Җв”Җ MUTE в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if (mMute) {
    // PR-bot-fix-lies (2026-05-27): was "Ч”ЧӘЧЁЧҗЧ•ЧӘ ЧҷЧўЧ“ЧҷЧқ ЧҷЧ•ЧӨЧўЧңЧ• Ч‘-PR Ч”Ч‘Чҗ"
    // which lied -- there's no scheduled reminder cron yet. Rewritten
    // to honest copy. Mute still records the intent in KV so when the
    // cron does land, the user's preference is already there.
    return { handled: true, replyText: 'рҹ”• ЧЁЧ©ЧһЧӘЧҷ Ч©ЧңЧҗ ЧңЧ©ЧңЧ•Ч— ЧңЧҡ ЧӘЧ–ЧӣЧ•ЧЁЧ•ЧӘ ЧўЧң ЧҷЧўЧ“ЧҷЧқ. ЧӘЧһЧҷЧ“ ЧҗЧӨЧ©ЧЁ ЧңЧ‘Ч“Ч•Ч§ ЧЎЧҳЧҳЧ•ЧЎ ЧўЧқ "ЧҷЧўЧ“ Ч©ЧңЧҷ".' };
  }

  // в”Җв”Җ DELETE в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if (mDel) {
    var delCat = mDel[1].trim().slice(0, 60);
    try {
      var dresp = UrlFetchApp.fetch(base + '/api/goals/delete', {
        method: 'post', contentType: 'application/json', headers: commonHeaders,
        payload: JSON.stringify({ phone: clean, category: delCat }),
        muteHttpExceptions: true,
      });
      var dcode = dresp.getResponseCode();
      if (dcode === 404) return { handled: true, replyText: 'рҹӨ” ЧңЧҗ ЧһЧҰЧҗЧӘЧҷ ЧҗЧӘ Ч”Ч—Ч©Ч‘Ч•Чҹ.' };
      if (dcode < 200 || dcode >= 300) return { handled: true, replyText: 'рҹҳ¬ ЧңЧҗ Ч”ЧҰЧңЧ—ЧӘЧҷ ЧңЧһЧ—Ч•Ч§ (' + dcode + ').' };
      var dj = JSON.parse(dresp.getContentText() || '{}');
      if (dj && dj.deleted) return { handled: true, replyText: 'вң… Ч ЧһЧ—Ч§ ЧҷЧўЧ“: ' + delCat };
      return { handled: true, replyText: 'рҹӨ” ЧңЧҗ ЧһЧҰЧҗЧӘЧҷ ЧҷЧўЧ“ ЧӨЧўЧҷЧң Ч‘Ч§ЧҳЧ’Ч•ЧЁЧҷЧ” "' + delCat + '".\nЧ©ЧңЧ— "ЧҷЧўЧ“ЧҷЧқ" ЧңЧЁЧҗЧ•ЧӘ ЧһЧ” ЧӨЧўЧҷЧң.' };
    } catch (e) {
      Logger.log('_handleGoalCommand_ delete err: ' + (e && e.message));
      return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ” Ч–ЧһЧ ЧҷЧӘ (ЧҷЧўЧ“ЧҷЧқ). Ч ЧЎЧ”/Чҷ Ч©Ч•Ч‘.' };
    }
  }

  // в”Җв”Җ SET (the spend_cap / savings command) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if (mSet) {
    var tail = mSet[1].trim();
    // Pull the LAST number off the tail. Anything before it is the category.
    var amtMatch = tail.match(/^(.*?)\s*([0-9][0-9,]*(?:\.[0-9]+)?)\s*вӮӘ?\s*$/);
    if (!amtMatch) {
      return { handled: true, replyText:
        'рҹӨ” ЧңЧҗ Ч”Ч‘Ч ЧӘЧҷ. Ч ЧЎЧ”:\nвҖў "Ч§Ч‘Чў ЧҷЧўЧ“ ЧҗЧ•ЧӣЧң 3000"\nвҖў "Ч§Ч‘Чў ЧҷЧўЧ“ 2000" (Ч—ЧҷЧЎЧӣЧ•Чҹ Ч—Ч•Ч“Ч©Чҷ)'
      };
    }
    var amount = Number(String(amtMatch[2]).replace(/,/g, ''));
    if (!isFinite(amount) || amount < 1 || amount > 10000000) {
      return { handled: true, replyText: 'рҹӨ” Ч”ЧЎЧӣЧ•Чқ Ч—ЧҷЧҷЧ‘ ЧңЧ”ЧҷЧ•ЧӘ Ч‘ЧҷЧҹ вӮӘ1 Чң-вӮӘ10,000,000.' };
    }
    var sCategory = (amtMatch[1] || '').trim();
    var stype = sCategory ? 'spend_cap' : 'savings';
    var payload = {
      phone: clean,
      type: stype,
      amountILS: amount,
    };
    if (sCategory) payload.category = sCategory.slice(0, 60);

    try {
      var sresp = UrlFetchApp.fetch(base + '/api/goals/upsert', {
        method: 'post', contentType: 'application/json', headers: commonHeaders,
        payload: JSON.stringify(payload), muteHttpExceptions: true,
      });
      var scode = sresp.getResponseCode();
      if (scode === 404) return { handled: true, replyText: 'рҹӨ” ЧңЧҗ ЧһЧҰЧҗЧӘЧҷ ЧҗЧӘ Ч”Ч—Ч©Ч‘Ч•Чҹ Ч©ЧңЧҡ.' };
      if (scode === 400) {
        var berr = JSON.parse(sresp.getContentText() || '{}');
        return { handled: true, replyText: 'рҹӨ” ' + (berr.detail || berr.error || 'Ч§ЧңЧҳ ЧңЧҗ ЧӘЧ§ЧҷЧҹ') };
      }
      if (scode < 200 || scode >= 300) return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ” Ч–ЧһЧ ЧҷЧӘ (' + scode + ').' };
      var sj = JSON.parse(sresp.getContentText() || '{}');
      var savedGoal = sj && sj.goal;
      if (!savedGoal) return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ” Ч–ЧһЧ ЧҷЧӘ.' };
      var sav_amt = 'вӮӘ' + Number(savedGoal.amountILS).toLocaleString('he-IL');
      var reply;
      if (savedGoal.type === 'savings') {
        reply = 'вң… ЧҷЧўЧ“ Ч—ЧҷЧЎЧӣЧ•Чҹ Ч—Ч•Ч“Ч©Чҷ Ч Ч§Ч‘Чў: ' + sav_amt +
          '\nрҹ’Ў Ч©ЧңЧ— "ЧЎЧҷЧӣЧ•Чқ" ЧӣЧ“Чҷ ЧңЧЁЧҗЧ•ЧӘ ЧҗЧӘ Ч”Ч”ЧӘЧ§Ч“ЧһЧ•ЧӘ.';
      } else {
        // PR-bot-fix-lies (2026-05-27): removed "Ч”ЧӘЧЁЧҗЧ•ЧӘ ЧҷЧҷЧ©ЧңЧ—Ч• ЧҗЧ•ЧҳЧ•ЧһЧҳЧҷЧӘ
        // Ч‘-50%, 80% Ч•-100% (Ч Ч“ЧңЧ§ Ч‘-PR-2)" -- those alerts don't exist
        // yet. Honest copy: tell the user to check status manually.
        reply = 'вң… ЧҷЧўЧ“ Ч Ч§Ч‘Чў: ' + savedGoal.category + ' вҖ” ' + sav_amt + '/Ч—Ч•Ч“Ч©' +
          '\nрҹ’Ў Ч©ЧңЧ— "ЧЎЧҷЧӣЧ•Чқ" ЧҗЧ• "ЧӣЧһЧ” Ч”Ч•ЧҰЧҗЧӘЧҷ ЧўЧң ' + savedGoal.category + '" Ч‘ЧӣЧң Ч–ЧһЧҹ ЧӣЧ“Чҷ ЧңЧЁЧҗЧ•ЧӘ Ч”ЧӘЧ§Ч“ЧһЧ•ЧӘ.';
      }
      return { handled: true, replyText: reply };
    } catch (e) {
      Logger.log('_handleGoalCommand_ set err: ' + (e && e.message));
      return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ” Ч–ЧһЧ ЧҷЧӘ (ЧҷЧўЧ“ЧҷЧқ). Ч ЧЎЧ”/Чҷ Ч©Ч•Ч‘.' };
    }
  }

  return { handled: false };
}
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

function _handleCategoryCorrection_(fromPhone, text) {
  if (!fromPhone || !text) return null;
  var trimmed = String(text).trim();
  var cache = CacheService.getScriptCache();

  // Bare "Ч§ЧҳЧ’Ч•ЧЁЧҷЧ”" / "category" вҖ” show the picker against the last
  // expense (if any). Previously this fell through to Gemini, which
  // could leak raw ``` ```json {вҖҰ} ``` markdown back to the user.
  if (trimmed === 'Ч§ЧҳЧ’Ч•ЧЁЧҷЧ”' || /^category$/i.test(trimmed)) {
    var phoneClean = String(fromPhone).replace(/[^0-9]/g, '');
    var lastRaw = cache.get('lastTenantExp:' + phoneClean) || cache.get('lastExp:' + fromPhone);
    if (!lastRaw) {
      return {
        handled: true,
        replyText: 'рҹӨ” ЧҗЧҷЧҹ Ч”Ч•ЧҰЧҗЧ” ЧҗЧ—ЧЁЧ•Ч Ч” ЧңЧӘЧҷЧ§Ч•Чҹ.\nЧ©ЧңЧ— Ч§Ч•Ч“Чқ Ч”Ч•ЧҰЧҗЧ” (ЧңЧһЧ©Чң "50 Ч§ЧӨЧ”") Ч•ЧҗЧ– Ч©ЧңЧ— Ч©Ч•Ч‘ "Ч§ЧҳЧ’Ч•ЧЁЧҷЧ”" ЧӣЧ“Чҷ ЧңЧ‘Ч—Ч•ЧЁ.'
      };
    }
    var le = null; try { le = JSON.parse(lastRaw); } catch (_) {}
    var curCat = (le && le.category) || '';
    try { _sendChangeCategoryPicker_(fromPhone, curCat); } catch (_pkErr) {
      Logger.log('bare-Ч§ЧҳЧ’Ч•ЧЁЧҷЧ” picker err: ' + (_pkErr && _pkErr.message));
    }
    return { handled: true, replyText: 'рҹ‘Ү Ч‘Ч—ЧЁ Ч§ЧҳЧ’Ч•ЧЁЧҷЧ” Ч—Ч“Ч©Ч” ЧһЧ”ЧЁЧ©ЧҷЧһЧ” ЧңЧһЧҳЧ”.' };
  }

  var corMatch = trimmed.match(/^Ч§ЧҳЧ’Ч•ЧЁЧҷЧ”\s+(.+)$/i) || trimmed.match(/^category\s+(.+)$/i);
  if (corMatch) {
    var newCategory = corMatch[1].trim();
    if (!newCategory) return null;
    var lastExpStr = cache.get('lastExp:' + fromPhone);
    if (!lastExpStr) {
      return { handled: true, replyText: 'рҹӨ” ЧҗЧҷЧҹ Ч”Ч•ЧҰЧҗЧ” ЧҗЧ—ЧЁЧ•Ч Ч” ЧңЧӘЧҷЧ§Ч•Чҹ.\nЧҗЧӨЧ©ЧЁ ЧңЧӘЧ§Чҹ ЧЁЧ§ Ч”Ч•ЧҰЧҗЧ•ЧӘ Чһ-10 Ч”Ч“Ч§Ч•ЧӘ Ч”ЧҗЧ—ЧЁЧ•Ч Ч•ЧӘ.\nЧ©ЧңЧ— ЧҗЧӘ Ч”Ч”Ч•ЧҰЧҗЧ” ЧһЧ—Ч“Ч© Ч•ЧҗЧ– ЧҗЧӘ Ч”ЧӘЧҷЧ§Ч•Чҹ.' };
    }
    var lastExp;
    try { lastExp = JSON.parse(lastExpStr); } catch (_) { return null; }
    cache.put('pendingCor:' + fromPhone, JSON.stringify({
      rowNumber: lastExp.rowNumber,
      originalText: lastExp.originalText,
      oldCategory: lastExp.category,
      oldSubcategory: lastExp.subcategory,
      newCategory: newCategory,
      amount: lastExp.amount
    }), 300);
    return {
      handled: true,
      replyText: 'рҹӨ” ЧңЧӘЧ§Чҹ ЧҗЧӘ:\n"' + lastExp.originalText + '" (вӮӘ' + lastExp.amount + ')\n\nЧһ-рҹ“Ӯ ' + lastExp.category + ' Чң-рҹ“Ӯ ' + newCategory + '?\n\nЧўЧ Ч”: ЧӣЧҹ / ЧңЧҗ'
    };
  }

  var isYes = /^(ЧӣЧҹ|yes|y|ЧҗЧҷЧ©Ч•ЧЁ|вң“)$/i.test(trimmed);
  var isNo = /^(ЧңЧҗ|no|n|Ч‘ЧҷЧҳЧ•Чң|вң—)$/i.test(trimmed);
  if (!isYes && !isNo) return null;

  var pendStr = cache.get('pendingCor:' + fromPhone);
  if (!pendStr) return null;
  var pend;
  try { pend = JSON.parse(pendStr); } catch (_) { return null; }
  cache.remove('pendingCor:' + fromPhone);

  if (isNo) {
    return { handled: true, replyText: 'вң“ Ч‘ЧҷЧҳЧңЧӘЧҷ. Ч”Ч”Ч•ЧҰЧҗЧ” Ч Ч©ЧҗЧЁЧ” ЧӣЧһЧ• Ч©Ч–Ч”.' };
  }

  try {
    var ss = SpreadsheetApp.openById(SHEET_ID);
    var sheet = ss.getSheetByName(TRANSACTIONS_SHEET);
    if (!sheet) return { handled: true, replyText: 'рҹҳ¬ ЧңЧҗ ЧһЧҰЧҗЧӘЧҷ ЧҗЧӘ Ч’ЧҷЧңЧҷЧ•Чҹ Ч”ЧӘЧ Ч•ЧўЧ•ЧӘ.' };
    // The new value the user typed may be a top-level category, a
    // sub-category, or "category/subcategory" pair. Resolve it through
    // matchCategory so we never overwrite both columns with the same
    // string (which would corrupt SUMIFS in the dashboard) and never
    // poison the learning cache with category == subcategory.
    var __resolved = _resolveCorrectionPair_(pend.newCategory);
    sheet.getRange(pend.rowNumber, 4).setValue(sanitizeForSheet(__resolved.category));
    sheet.getRange(pend.rowNumber, 5).setValue(sanitizeForSheet(__resolved.subcategory));

    // Append a correction line to the row's existing original-text note.
    try {
      var __corStamp = Utilities.formatDate(new Date(), 'Asia/Jerusalem', 'HH:mm');
      _kfl_appendOriginalNoteLine(sheet, pend.rowNumber,
        'Corrected from "' + (pend.oldCategory || '?') + '" to "' + pend.newCategory + '" at ' + __corStamp);
    } catch (__corNoteErr) { Logger.log('correction note err: ' + (__corNoteErr && __corNoteErr.message)); }

    _learnedSave(pend.originalText, { category: __resolved.category, subcategory: __resolved.subcategory }, 'user-correction');

    // TASK 1 + 4: audit log + anti-degradation guard
    var __needsReviewCor = false;
    try {
      var __priorCor = _countCorrectionsForText_(pend.originalText);
      if (__priorCor >= 2) __needsReviewCor = true;
      _logMLAudit_({
        user_text: pend.originalText,
        amount: pend.amount,
        final_category: pend.newCategory,
        final_subcategory: pend.newCategory,
        via: 'manual_correction',
        user_correction: pend.newCategory,
        needs_review: __needsReviewCor,
        from_phone: fromPhone
      });
      if (__needsReviewCor) {
        _adminAlertOnce_('рҹҡЁ ЧҰЧЁЧҷЧҡ Ч‘Ч“ЧҷЧ§Ч” ЧҷЧ“Ч ЧҷЧӘ вҖ” "' + pend.originalText + '" ЧӘЧ•Ч§Чҹ ' + (__priorCor + 1) + ' ЧӨЧўЧһЧҷЧқ.', fromPhone);
      }
    } catch (_auditErr2) { Logger.log('_handleCategoryCorrection_ audit: ' + _auditErr2.message); }

    var llmTail = '';
    try {
      // Pass the ALREADY-RESOLVED (category, subcategory) so learned rows carry
      // the real subcategory (col E) вҖ” re-resolving pend.newCategory inside
      // would double-match and corrupt the pair (AUDIT_BOT_LLM_SAFETY F1).
      var extracted = _learnExpandedKeywords_(pend.originalText, __resolved.category, __resolved.subcategory);
      if (extracted && extracted.length) {
        llmTail = '\nрҹ§  ЧңЧһЧ“ЧӘЧҷ Ч’Чқ: ' + extracted.join(', ');
      }
    } catch (eL) { Logger.log('_learnExpandedKeywords_ failed: ' + eL.message); }

    return {
      handled: true,
      replyText: 'вң… ЧӘЧ•Ч§Чҹ Чң-рҹ“Ӯ ' + pend.newCategory + '\nрҹ§  Ч©ЧһЧЁЧӘЧҷ ЧҗЧӘ "' + pend.originalText + '" ЧңЧ–ЧҷЧӣЧЁЧ•Чҹ, ЧһЧ”ЧӨЧўЧқ Ч”Ч‘ЧҗЧ” ЧҗЧ–ЧӣЧ•ЧЁ.' + llmTail
    };
  } catch (e) {
    Logger.log('apply correction err: ' + (e && e.stack || e));
    return { handled: true, replyText: 'рҹҳ¬ ЧһЧ©Ч”Ч• Ч”Ч©ЧӘЧ‘Ч© Ч‘ЧўЧ“ЧӣЧ•Чҹ Ч”Ч©Ч•ЧЁЧ”: ' + (e && e.message || '') + '\nрҹ’Ў Ч Ч ЧЎЧ” Ч©Ч•Ч‘ Ч‘ЧўЧ•Ч“ Ч“Ч§Ч”?' };
  }
}

// 2026-05-31 (AUDIT_BOT_LLM_SAFETY Finding 1): canonical top-level category
// whitelist. Derived at runtime from CATEGORY_MAP (the same source the ЧӘЧ Ч•ЧўЧ•ЧӘ
// data-validation dropdown uses, line ~11170) + DEFAULT_CATEGORY + the static
// list _aiCategorizeRich already validates against. Anything NOT in this set
// is a category the dashboard SUMIFS can't sum, so the learned-keyword writers
// must refuse to persist it (when unsure, do NOT write). Cached per execution.
var _CANON_CATS_ = null;
function _isCanonicalCategory_(cat) {
  var c = String(cat || '').trim();
  if (!c) return false;
  if (!_CANON_CATS_) {
    var set = {};
    try {
      if (typeof CATEGORY_MAP !== 'undefined' && Array.isArray(CATEGORY_MAP)) {
        CATEGORY_MAP.forEach(function (e) { if (e && e.category) set[String(e.category).trim()] = true; });
      }
    } catch (_e) {}
    try { if (typeof DEFAULT_CATEGORY !== 'undefined' && DEFAULT_CATEGORY.category) set[String(DEFAULT_CATEGORY.category).trim()] = true; } catch (_e2) {}
    // Belt-and-suspenders: the same list _aiCategorizeRich gates AI output on.
    ['Ч”ЧӣЧ ЧЎЧ•ЧӘ','ЧҗЧ•ЧӣЧң','ЧӘЧ—Ч‘Ч•ЧЁЧ”','Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч§Ч‘Ч•ЧўЧ•ЧӘ','Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч–ЧһЧ ЧҷЧ•ЧӘ','Ч§Ч ЧҷЧ•ЧӘ','Ч‘ЧЁЧҷЧҗЧ•ЧӘ','ЧўЧЎЧ§','Ч©ЧҷЧЁЧ•ЧӘЧҷЧқ','Ч‘ЧҷЧ“Ч•ЧЁ','Ч—ЧҷЧ Ч•Чҡ','ЧҷЧңЧ“ЧҷЧқ','ЧһЧһЧ©ЧңЧ” Ч•ЧһЧҷЧЎЧҷЧқ','ЧӨЧҷЧ Ч ЧЎЧҷЧқ','Ч‘ЧңЧӘЧҷ ЧһЧ–Ч•Ч”Ч”']
      .forEach(function (x) { set[x] = true; });
    _CANON_CATS_ = set;
  }
  return _CANON_CATS_[c] === true;
}

// 2026-05-31 fix (AUDIT_BOT_LLM_SAFETY Finding 1): `subcategoryArg` is the
// ALREADY-RESOLVED subcategory (col E) from the correction flow. The caller
// resolves the (category, subcategory) pair ONCE via _resolveCorrectionPair_
// and passes both in вҖ” we must NOT re-run matchCategory on a value that is
// already a chosen top-level category (that double-resolve substring-matches
// junk like "category" вҶ’ ЧўЧЎЧ§). If a caller omits it (legacy), fall back to
// resolving here, but never to subcategory==category.
function _learnExpandedKeywords_(text, category, subcategoryArg) {
  var apiKey = PropertiesService.getScriptProperties().getProperty('ANTHROPIC_API_KEY');
  if (!apiKey) return [];

  // 2026-05-31 fix (AUDIT_BOT_LLM_SAFETY Finding 1):
  // (a) Write the REAL subcategory, never subcategory==category (which broke
  //     dashboard SUMIFS that key on the real subcategory string).
  // (b) Validate the category against the canonical set; if the correction
  //     target isn't a category the dashboard can sum, refuse to learn
  //     keywords from it вҖ” a poisoned learned row would silently mis-route
  //     every future message that hits the keyword (when unsure, do NOT write).
  var learnCategory = category;
  var learnSubcategory = subcategoryArg;
  if (learnSubcategory == null || learnSubcategory === '') {
    // Legacy/standalone call: resolve the pair, but only from a raw freeform
    // value (not an already-chosen category вҖ” caller should pass both).
    var rp = (typeof _resolveCorrectionPair_ === 'function') ? _resolveCorrectionPair_(category) : null;
    if (rp && rp.category) { learnCategory = rp.category; learnSubcategory = rp.subcategory; }
  }
  if (!learnSubcategory) learnSubcategory = learnCategory; // last resort, still better than nothing
  if (!_isCanonicalCategory_(learnCategory)) {
    Logger.log('_learnExpandedKeywords_: skip вҖ” non-canonical category "' + learnCategory + '" (from "' + category + '")');
    return [];
  }

  var prompt = 'ЧһЧ©ЧӘЧһЧ© ЧӣЧӘЧ‘ Ч”Ч•ЧҰЧҗЧ” Ч‘ЧўЧ‘ЧЁЧҷЧӘ: "' + text + '"\n' +
    'Ч”Ч•Чҗ ЧӘЧҷЧ§Чҹ ЧҗЧӘ Ч”Ч§ЧҳЧ’Ч•ЧЁЧҷЧ” Чң-"' + category + '".\n' +
    'Ч”Ч•ЧҰЧҗ 1-3 ЧһЧҷЧңЧ•ЧӘ ЧһЧӨЧӘЧ— Ч§ЧҰЧЁЧ•ЧӘ (ЧһЧҷЧңЧ” ЧҗЧ—ЧӘ ЧҗЧ• ЧҰЧҷЧЁЧ•ЧЈ Ч§ЧҰЧЁ) ЧһЧ”ЧҳЧ§ЧЎЧҳ Ч©Ч”Чҹ Ч”ЧңЧҷЧ‘Ч” Ч”ЧЎЧһЧ ЧҳЧҷЧӘ, ' +
    'Ч•Ч©ЧҰЧЁЧҷЧӣЧ•ЧӘ ЧңЧһЧӨЧ•ЧӘ Ч‘ЧўЧӘЧҷЧ“ ЧңЧ§ЧҳЧ’Ч•ЧЁЧҷЧ” Ч”Ч–ЧҗЧӘ.\n' +
    'Ч“Ч•Ч’ЧһЧ” 1: "ЧһЧ•Ч‘ЧҷЧң Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч‘ЧҷЧӘ" вҶ’ ["ЧһЧ•Ч‘ЧҷЧң", "Ч”Ч•Ч‘ЧңЧ”"]\n' +
    'Ч“Ч•Ч’ЧһЧ” 2: "ЧҗЧЁЧ Ч•Ч Ч” ЧңЧўЧҷЧЁЧҷЧҷЧ”" вҶ’ ["ЧҗЧЁЧ Ч•Ч Ч”"]\n' +
    'Ч“Ч•Ч’ЧһЧ” 3: "Ч—Ч•Ч’Чҷ ЧҷЧңЧ“ЧҷЧқ ЧһЧҳЧЁЧҷЧқ" вҶ’ ["Ч—Ч•Ч’", "ЧһЧҳЧЁЧҷЧқ"]\n' +
    'ЧҗЧң ЧӘЧӣЧңЧ•Чң ЧһЧҷЧңЧ•ЧӘ Ч§ЧҷЧ©Ч•ЧЁ (Ч©Чң, Чң, ЧҗЧӘ, Ч•ЧӣЧ•).\n' +
    'Ч”Ч—Ч–ЧЁ JSON Ч‘ЧңЧ‘Ч“ ЧңЧңЧҗ Ч”ЧЎЧ‘ЧЁ: {"keywords":["..."]}';

  var response;
  try {
    response = UrlFetchApp.fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      contentType: 'application/json',
      headers: { 'x-api-key': apiKey, 'anthropic-version': '2023-06-01' },
      payload: JSON.stringify({
        model: 'claude-haiku-4-5-20251001',
        max_tokens: 200,
        messages: [{ role: 'user', content: prompt }]
      }),
      muteHttpExceptions: true
    });
  } catch (e) {
    Logger.log('Claude learn fetch err: ' + e.message);
    return [];
  }

  if (response.getResponseCode() !== 200) {
    Logger.log('Claude learn API ' + response.getResponseCode() + ': ' + response.getContentText());
    return [];
  }

  try {
    var data = JSON.parse(response.getContentText());
    var txt = data && data.content && data.content[0] && data.content[0].text || '';
    var m = txt.match(/\{[\s\S]*\}/);
    if (!m) return [];
    var rule = JSON.parse(m[0]);
    if (!rule.keywords || !Array.isArray(rule.keywords)) return [];

    var saved = [];
    rule.keywords.forEach(function (kw) {
      var k = String(kw || '').toLowerCase().trim();
      if (k.length < 2 || k.length > 30) return;
      // 2026-05-31 fix: real subcategory (resolved above), not category==subcategory.
      _learnedSave(k, { category: learnCategory, subcategory: learnSubcategory }, 'llm-extracted');
      saved.push(k);
    });
    return saved;
  } catch (e) {
    Logger.log('Claude learn parse err: ' + e.message);
    return [];
  }
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// LEARNING DASHBOARD + MANUAL OVERRIDE COMMANDS
//
//   ЧңЧҷЧһЧ•Ч“                            вҖ” list last 10 learned terms
//   ЧңЧһЧ“: "ЧҳЧ§ЧЎЧҳ" = Ч§ЧҳЧ’Ч•ЧЁЧҷЧ”            вҖ” direct teach (skips confirmation flow)
//   ЧһЧ—Ч§ ЧңЧҷЧһЧ•Ч“ <index>                вҖ” delete entry N from the list
//   ЧҗЧҷЧӨЧ•ЧЎ ЧңЧҷЧһЧ•Ч“                      вҖ” clear ALL learned data (asks for ЧӣЧҹ/ЧңЧҗ)
//
// Indices come from the most recent "ЧңЧҷЧһЧ•Ч“" listing, so the user just numbers
// from the screen and replies "ЧһЧ—Ч§ ЧңЧҷЧһЧ•Ч“ 3" without thinking about row IDs.
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

function _handleLearningCommand_(fromPhone, text) {
  if (!fromPhone || !text) return null;
  var trimmed = String(text).trim();

  if (/^(ЧңЧҷЧһЧ•Ч“|learning)$/i.test(trimmed)) {
    return { handled: true, replyText: _learningListMessage_(fromPhone) };
  }

  var teachMatch = trimmed.match(/^(?:ЧңЧһЧ“|learn)\s*:\s*["ЧҙЧҙЧҙвҖқ'](.+?)["ЧҙвҖқ']\s*[=:]\s*(.+)$/i)
    || trimmed.match(/^(?:ЧңЧһЧ“|learn)\s+(.+?)\s*=\s*(.+)$/i);
  if (teachMatch) {
    var phrase = String(teachMatch[1] || '').trim();
    var category = String(teachMatch[2] || '').trim();
    if (!phrase || !category) {
      return { handled: true, replyText: 'рҹӨ” Ч©ЧҷЧһЧ•Ч©: ЧңЧһЧ“: "ЧһЧ•Ч‘ЧҷЧң" = Ч©ЧҷЧЁЧ•ЧӘЧҷЧқ' };
    }
    try {
      _learnedSave(phrase.toLowerCase(), { category: category, subcategory: category }, 'user-direct');
      var tail = '';
      try {
        var ext = _learnExpandedKeywords_(phrase, category);
        if (ext && ext.length) tail = '\nрҹ§  Ч’Чқ Ч”ЧЁЧ—Ч‘ЧӘЧҷ Чң: ' + ext.join(', ');
      } catch (_e) {}
      return { handled: true, replyText: 'вң… ЧңЧһЧ“ЧӘЧҷ: "' + phrase + '" вҶ’ рҹ“Ӯ ' + category + tail };
    } catch (e) {
      return { handled: true, replyText: 'рҹҳ¬ ЧһЧ©Ч”Ч• Ч”Ч©ЧӘЧ‘Ч© Ч‘ЧңЧһЧҷЧ“Ч”: ' + (e && e.message || '') + '\nрҹ’Ў Ч Ч ЧЎЧ” Ч©Ч•Ч‘ Ч‘ЧўЧ•Ч“ Ч“Ч§Ч”?' };
    }
  }

  var delMatch = trimmed.match(/^(?:ЧһЧ—Ч§\s+ЧңЧҷЧһЧ•Ч“|delete\s+learning)\s+(\d+)$/i);
  if (delMatch) {
    var idx = parseInt(delMatch[1], 10);
    return { handled: true, replyText: _learningDelete_(fromPhone, idx) };
  }

  if (/^(ЧҗЧҷЧӨЧ•ЧЎ\s+ЧңЧҷЧһЧ•Ч“|reset\s+learning)$/i.test(trimmed)) {
    CacheService.getScriptCache().put('pendingReset:' + fromPhone, '1', 120);
    return { handled: true, replyText: 'вҡ пёҸ ЧңЧһЧ—Ч•Ч§ ЧҗЧӘ ЧӣЧң Ч”Ч–ЧҷЧӣЧЁЧ•Чҹ Ч©Чң Ч”Ч‘Ч•Чҳ?\nЧӣЧң Ч”ЧһЧҷЧңЧҷЧқ Ч©ЧңЧһЧ“ ЧҷЧҷЧһЧ—Ч§Ч•.\nЧўЧ Ч”: ЧӣЧҹ / ЧңЧҗ' };
  }

  // Confirmation for reset (intercepted before general ЧӣЧҹ/ЧңЧҗ)
  if (/^(ЧӣЧҹ|yes|y)$/i.test(trimmed)) {
    var pendingReset = CacheService.getScriptCache().get('pendingReset:' + fromPhone);
    if (pendingReset) {
      CacheService.getScriptCache().remove('pendingReset:' + fromPhone);
      return { handled: true, replyText: _learningReset_() };
    }
  }
  if (/^(ЧңЧҗ|no|n)$/i.test(trimmed)) {
    var pendingReset2 = CacheService.getScriptCache().get('pendingReset:' + fromPhone);
    if (pendingReset2) {
      CacheService.getScriptCache().remove('pendingReset:' + fromPhone);
      return { handled: true, replyText: 'вң“ Ч‘ЧҷЧҳЧңЧӘЧҷ. Ч”Ч–ЧҷЧӣЧЁЧ•Чҹ Ч Ч©ЧҗЧЁ.' };
    }
  }

  return null;
}

function _learningListMessage_(fromPhone) {
  try {
    var ss = SpreadsheetApp.openById(SHEET_ID);
    var sh = ss.getSheetByName(_LEARNED_TAB_NAME);
    if (!sh || sh.getLastRow() < 2) {
      return 'рҹ§  Ч”Ч‘Ч•Чҳ ЧўЧ•Ч“ ЧңЧҗ ЧңЧһЧ“ ЧӣЧңЧ•Чқ.\nЧ©ЧңЧ— "ЧңЧһЧ“: <ЧҳЧ§ЧЎЧҳ> = <Ч§ЧҳЧ’Ч•ЧЁЧҷЧ”>" ЧҗЧ• ЧӘЧ§Чҹ Ч”Ч•ЧҰЧҗЧ” ЧўЧқ "Ч§ЧҳЧ’Ч•ЧЁЧҷЧ” <Ч©Чқ>".';
    }
    var n = Math.min(10, sh.getLastRow() - 1);
    var data = sh.getRange(sh.getLastRow() - n + 1, 1, n, 5).getValues();
    var lines = ['рҹ§  10 Ч”Ч“Ч‘ЧЁЧҷЧқ Ч”ЧҗЧ—ЧЁЧ•Ч ЧҷЧқ Ч©ЧңЧһЧ“ЧӘЧҷ:\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ'];
    // Track the indexвҶ’row mapping for "ЧһЧ—Ч§ ЧңЧҷЧһЧ•Ч“ N"
    var idxMap = {};
    for (var i = 0; i < data.length; i++) {
      var displayIdx = data.length - i;
      var actualRow = sh.getLastRow() - i;
      idxMap[displayIdx] = actualRow;
      var src = data[i][3] || '';
      var srcEmoji = src === 'user-correction' ? 'рҹ‘Ө' : src === 'user-direct' ? 'рҹҺҜ' : src === 'llm-extracted' ? 'рҹ§ ' : src === 'global' ? 'рҹ“ҡ' : 'вҖў';
      lines.push(displayIdx + '. ' + srcEmoji + ' "' + data[i][0] + '" вҶ’ ' + data[i][1]);
    }
    lines.push('в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ');
    lines.push('рҹ—‘пёҸ ЧңЧһЧ—Ч•Ч§? Ч©ЧңЧ— "ЧһЧ—Ч§ ЧңЧҷЧһЧ•Ч“ N"');
    lines.push('вҷ»пёҸ ЧңЧһЧ—Ч•Ч§ Ч”ЧӣЧ•Чң? Ч©ЧңЧ— "ЧҗЧҷЧӨЧ•ЧЎ ЧңЧҷЧһЧ•Ч“"');
    CacheService.getScriptCache().put('learnIdxMap:' + fromPhone, JSON.stringify(idxMap), 600);
    return lines.join('\n');
  } catch (e) {
    Logger.log('_learningListMessage_: ' + e.message);
    return 'рҹҳ¬ ЧңЧҗ Ч”ЧҰЧңЧ—ЧӘЧҷ ЧңЧҳЧўЧ•Чҹ ЧҗЧӘ Ч”Ч–ЧҷЧӣЧЁЧ•Чҹ\nрҹ’Ў Ч Ч ЧЎЧ” Ч©Ч•Ч‘ Ч‘ЧўЧ•Ч“ Ч“Ч§Ч”?';
  }
}

function _learningDelete_(fromPhone, idx) {
  if (!idx || idx < 1) return 'рҹӨ” ЧҰЧЁЧҷЧҡ ЧһЧЎЧӨЧЁ Ч‘ЧҷЧҹ 1 Чң-10\nрҹ’Ў Ч©ЧңЧ— "ЧңЧҷЧһЧ•Ч“" ЧӣЧ“Чҷ ЧңЧЁЧҗЧ•ЧӘ ЧҗЧӘ Ч”ЧЁЧ©ЧҷЧһЧ”';
  try {
    var mapStr = CacheService.getScriptCache().get('learnIdxMap:' + fromPhone);
    if (!mapStr) return 'рҹӨ” Ч§Ч•Ч“Чқ Ч©ЧңЧ— "ЧңЧҷЧһЧ•Ч“" ЧӣЧ“Чҷ ЧңЧЁЧҗЧ•ЧӘ ЧҗЧӘ Ч”ЧЁЧ©ЧҷЧһЧ”\nрҹ’Ў Ч•ЧҗЧ– "ЧһЧ—Ч§ ЧңЧҷЧһЧ•Ч“ N"';
    var idxMap = JSON.parse(mapStr);
    var rowNumber = idxMap[String(idx)];
    if (!rowNumber) return 'рҹӨ” ЧҗЧҷЧҹ ЧӨЧЁЧҷЧҳ ' + idx + ' Ч‘ЧЁЧ©ЧҷЧһЧ”\nрҹ’Ў Ч©ЧңЧ— "ЧңЧҷЧһЧ•Ч“" ЧңЧЁЧҗЧ•ЧӘ ЧҗЧӘ Ч”ЧЁЧ©ЧҷЧһЧ” Ч”ЧһЧўЧ•Ч“ЧӣЧ ЧӘ';
    var ss = SpreadsheetApp.openById(SHEET_ID);
    var sh = ss.getSheetByName(_LEARNED_TAB_NAME);
    if (!sh) return 'рҹҳ¬ ЧҗЧҷЧҹ Ч’ЧҷЧңЧҷЧ•Чҹ Ч–ЧҷЧӣЧЁЧ•Чҹ\nрҹ’Ў Ч©ЧңЧ— "ЧңЧҷЧһЧ•Ч“" ЧӣЧ“Чҷ Ч©Ч ЧҷЧҷЧҰЧЁ ЧҗЧ—Ч“';
    var deletedTerm = sh.getRange(rowNumber, 1).getValue();
    sh.deleteRow(rowNumber);
    _learnedCacheLoadedAt = 0;
    return 'вң… ЧһЧ—Ч§ЧӘЧҷ: "' + deletedTerm + '"\nрҹ’Ў Ч©ЧңЧ— "ЧңЧҷЧһЧ•Ч“" ЧңЧЁЧ©ЧҷЧһЧ” ЧһЧўЧ•Ч“ЧӣЧ ЧӘ.';
  } catch (e) {
    return 'рҹҳ¬ ЧһЧ©Ч”Ч• Ч”Ч©ЧӘЧ‘Ч© Ч‘ЧһЧ—ЧҷЧ§Ч”: ' + (e && e.message || '') + '\nрҹ’Ў Ч Ч ЧЎЧ” Ч©Ч•Ч‘ Ч‘ЧўЧ•Ч“ Ч“Ч§Ч”?';
  }
}

function _learningReset_() {
  try {
    var ss = SpreadsheetApp.openById(SHEET_ID);
    var sh = ss.getSheetByName(_LEARNED_TAB_NAME);
    if (!sh) return 'рҹ§  ЧҗЧҷЧҹ ЧһЧ” ЧңЧһЧ—Ч•Ч§.';
    var count = Math.max(0, sh.getLastRow() - 1);
    if (count === 0) return 'рҹ§  Ч”Ч–ЧҷЧӣЧЁЧ•Чҹ ЧӣЧ‘ЧЁ ЧЁЧҷЧ§.';
    sh.deleteRows(2, count);
    _learnedCacheLoadedAt = 0;
    return 'вң… Ч ЧҷЧ§ЧҷЧӘЧҷ ' + count + ' ЧӨЧЁЧҷЧҳЧҷЧқ. Ч”Ч‘Ч•Чҳ ЧһЧӘЧ—ЧҷЧң ЧңЧңЧһЧ•Ч“ ЧһЧҗЧӨЧЎ.';
  } catch (e) {
    return 'рҹҳ¬ ЧһЧ©Ч”Ч• Ч”Ч©ЧӘЧ‘Ч© Ч‘ЧҗЧҷЧӨЧ•ЧЎ: ' + (e && e.message || '') + '\nрҹ’Ў Ч Ч ЧЎЧ” Ч©Ч•Ч‘ Ч‘ЧўЧ•Ч“ Ч“Ч§Ч”?';
  }
}

// Public: user can manually teach the bot via WhatsApp:
// "ЧӘЧңЧһЧ“: Ч§ЧӨЧ” ЧҗЧЁЧ•ЧһЧ” вҶ’ ЧҗЧ•ЧӣЧң / ЧҗЧ•ЧӣЧң Ч‘Ч—Ч•ЧҘ"
function teachCategory(text, category, subcategory) {
  _learnedSave(text, { category: category, subcategory: subcategory }, 'user');
  return 'Ч ЧңЧһЧ“: "' + text + '" вҶ’ ' + category + ' / ' + subcategory;
}

