function matchCategory(text) {
  if (!text) return _matchCategory_long(text);
  var t = String(text).toLowerCase().trim();
  t = t.replace(/[В вҖҜвҖүвҖӢ]/g, ' ').replace(/\s+/g, ' ');
  // 2026-06-02: accept the clitic prefix forms (Ч‘ЧўЧЎЧ§ / ЧңЧўЧЎЧ§ / ЧһЧўЧЎЧ§ / Ч”ЧўЧЎЧ§ /
  // Ч•ЧўЧЎЧ§) in addition to the standalone ЧўЧЎЧ§, so a natural sentence like
  // "...Ч”ЧӣЧ ЧЎЧ” Ч‘ЧўЧЎЧ§..." routes business (e.g. "Ч”ЧӣЧ ЧЎЧ”" -> ЧһЧ—Ч–Ч•ЧЁ income). The
  // boundary anchors ((^|\s) before the optional clitic, ($|\s) after ЧўЧЎЧ§)
  // keep this tight: "ЧһЧўЧЎЧҷЧ§" (employer) and "Ч‘ЧўЧЎЧ§ЧҷЧқ" do NOT match.
  var hasBusinessPrefix = /(^|\s)[Ч‘ЧңЧһЧ”Ч•]?ЧўЧЎЧ§($|\s)/.test(t);
  if (hasBusinessPrefix) {
    var entries = [];
    for (var cat in BUSINESS_CATEGORY_MAP) {
      var subs = BUSINESS_CATEGORY_MAP[cat];
      for (var sub in subs) {
        var kws = subs[sub];
        for (var k = 0; k < kws.length; k++) {
          entries.push({ kw: String(kws[k]).toLowerCase(), category: cat, subcategory: sub });
        }
      }
    }
    entries.sort(function(a, b) { return b.kw.length - a.kw.length; });
    for (var i = 0; i < entries.length; i++) {
      var kw = entries[i].kw;
      if (_kflKwHit_(t, kw)) {
        // BUGFIX B1 (2026-05-28): BUSINESS_CATEGORY_MAP doesn't carry an
        // isIncome flag per-row, but the "ЧһЧ—Ч–Ч•ЧЁ" subcategory is by definition
        // income (revenue). Without this, "ЧўЧЎЧ§ Ч”ЧӣЧ ЧЎЧ” 10000" matched ЧһЧ—Ч–Ч•ЧЁ
        // but the downstream col-H assignment got TRUE (expense) anyway.
        var bizIncome = (entries[i].subcategory === 'ЧһЧ—Ч–Ч•ЧЁ');
        return { category: entries[i].category, subcategory: entries[i].subcategory, isIncome: bizIncome };
      }
    }
    return { category: "ЧўЧЎЧ§", subcategory: "Ч”Ч•ЧҰЧҗЧ•ЧӘ ЧӘЧӨЧўЧ•ЧңЧҷЧ•ЧӘ", isIncome: false };
  }
  return _matchCategory_long(text);
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// BARE BUSINESS EXPENSE DETECTOR (2026-06-01)
//
// Steven's bug: a natural business expense like "Ч”Ч•ЧҰЧҗЧ” ЧўЧЎЧ§ ЧӘЧһЧ•Ч Ч•ЧӘ 288 Ч©ЧҷЧ•Ч•Ч§"
// (or "ЧўЧЎЧ§ ЧӘЧһЧ•Ч Ч•ЧӘ 288 Ч©ЧҷЧ•Ч•Ч§", "ЧўЧЎЧ§ 1200 Ч—Ч•ЧһЧЁЧҷЧқ", "ЧўЧЎЧ§ 2500 Ч©ЧӣЧЁ") sometimes
// fell through to the BLOCKING numbered picker ("рҹҸў ЧўЧЎЧ§ вҖ” Ч‘Ч—ЧЁ Ч§ЧҳЧ’Ч•ЧЁЧҷЧ”") with
// no row written, or вҖ” for "ЧўЧ•Ч‘Ч“ЧҷЧқ" вҖ” got mis-bucketed. The owner runs a SINGLE
// business that writes col D='ЧўЧЎЧ§', so any "ЧўЧЎЧ§ [name] [amount] [token]" message
// should be classified into a canonical business bucket and written immediately,
// NOT held behind a picker and NOT routed to the personal classifier.
//
// This helper is the SINGLE authority for that shape. It runs ONLY after the
// numbered-business route ("ЧўЧЎЧ§ 2 ...", handled in doPost) and the rich-order
// route ("ЧўЧЎЧ§Ч” ЧҷЧ•ЧЎЧҷ Ч”ЧӣЧ ЧЎЧ” ...", parseBusinessOrder_) have both been ruled out.
//
// Returns { amount, category:'ЧўЧЎЧ§', subcategory, cleanedDesc, isIncome } when it
// can confidently treat the message as a bare business expense; else null.
//
// Subcategory is emitted as a CANONICAL dashboard bucket name (one of the keys
// _normalizeBizSub_ recognizes) so the row both (a) writes col E the company
// dashboard SUMIFS can sum and (b) lets _updateBusinessDashboard_ mirror it into
// the ЧўЧЎЧ§ ЧӘЧһЧ•Ч Ч•ЧӘ marketing/shipping/raw-materials/operations rows. Labor tokens
// (ЧўЧ•Ч‘Ч“/Ч©ЧӣЧЁ) and tax tokens (ЧһЧЎ/ЧһЧҷЧЎЧҷЧқ) map to Ч”Ч•ЧҰЧҗЧ•ЧӘ ЧӘЧӨЧўЧ•ЧңЧҷЧ•ЧӘ вҖ” the company
// dashboard's catch-all overhead bucket вҖ” because there is no dedicated labor or
// tax dashboard row (verified against _BIZ_DASH_SUBS). Mapping them to a
// non-existent bucket would silently drop the money, which we must never do.
function _classifyBareBusinessExpense_(text) {
  var raw = String(text || '').trim();
  if (!raw) return null;

  // Normalize odd whitespace (NBSP / narrow-NBSP / zero-width) to plain spaces.
  var t = raw.replace(/[  вҖӢ]/g, ' ').replace(/\s+/g, ' ').trim();

  // Must contain the Hebrew word ЧўЧЎЧ§, standalone OR in a clitic prefix form
  // (Ч‘ЧўЧЎЧ§ / ЧңЧўЧЎЧ§ / ЧһЧўЧЎЧ§ / Ч”ЧўЧЎЧ§ / Ч•ЧўЧЎЧ§), optionally directly preceded by
  // Ч”Ч•ЧҰЧҗЧ” / Ч”Ч•ЧҰЧҗЧӘ. The trailing boundary keeps the suffix forms out: "ЧўЧЎЧ§Ч”"
  // / "ЧўЧЎЧ§Чҷ" / "ЧўЧЎЧ§ЧҷЧқ" still do NOT trigger (those are order / adjective /
  // list-command words). 2026-06-02: clitic prefix added so "Ч‘ЧўЧЎЧ§ 288 Ч©ЧҷЧ•Ч•Ч§"
  // is recognised as a bare business expense too.
  if (!/(^|\s)[Ч‘ЧңЧһЧ”Ч•]?ЧўЧЎЧ§(\s|$)/.test(t)) return null;

  // GUARD 1: numbered business ("ЧўЧЎЧ§ 2 Ч©ЧҷЧ•Ч•Ч§ 300"). That route writes to its own
  // tab and MUST win. Never hijack it here.
  try {
    if (typeof _parseBusinessNumberPrefix_ === 'function' && _parseBusinessNumberPrefix_(t)) return null;
  } catch (_bnErr) {}

  // GUARD 2: rich order ("ЧўЧЎЧ§Ч” ЧҷЧ•ЧЎЧҷ Ч”ЧӣЧ ЧЎЧ” 10000 ЧўЧ•Ч‘Ч“ЧҷЧқ 2500 Ч—Ч•ЧһЧЁЧҷЧқ 1200"). That
  // route writes a structured multi-row order and MUST win.
  try {
    if (typeof parseBusinessOrder_ === 'function' && parseBusinessOrder_(t)) return null;
  } catch (_boErr) {}

  // First positive amount anywhere in the message (integer or decimal). We use
  // the same lenient scan the ЧўЧЎЧ§ block uses so word order is irrelevant
  // ("ЧўЧЎЧ§ ЧӘЧһЧ•Ч Ч•ЧӘ 288 Ч©ЧҷЧ•Ч•Ч§" and "ЧўЧЎЧ§ ЧӘЧһЧ•Ч Ч•ЧӘ Ч©ЧҷЧ•Ч•Ч§ 288" both work).
  var amM = t.replace(/,/g, '').match(/(?:^|[\s:\-])([0-9]+(?:\.[0-9]+)?)(?=$|[\s,.])/);
