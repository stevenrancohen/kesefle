function getEngineStatus() {
  try {
    var sheet = SpreadsheetApp.openById(SHEET_ID).getSheetByName('ЧһЧҷЧңЧ•Чҹ ЧңЧҷЧһЧ•Ч“');
    var learnedCount = sheet ? Math.max(0, sheet.getLastRow() - 1) : 0;
    var _aiProv = null;
    try { _aiProv = _aiProviderResolve_(); } catch (_aiPErr) {}
    var aiEnabled = !!_aiProv;
    var keywordCount = (typeof CATEGORY_MAP !== 'undefined') ? CATEGORY_MAP.reduce(function(a,b){ return a + (b.keywords ? b.keywords.length : 0); }, 0) : 0;
    var categoryCount = (typeof CATEGORY_MAP !== 'undefined') ? CATEGORY_MAP.length : 0;
    return 'вҡЎ *ЧһЧҰЧ‘ Ч”ЧһЧ Ч•Чў*\n' +
      'в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n' +
      'рҹҘҮ *Ч©ЧӣЧ‘Ч” 1 вҖ” Cache*\n' +
      '   ' + learnedCount + ' ЧһЧҷЧңЧҷЧқ Ч©Ч ЧңЧһЧ“Ч• ЧҗЧҷЧ©ЧҷЧӘ\n' +
      '   ~50ms вҖў Ч—ЧҷЧ Чқ\n\n' +
      'рҹҘҲ *Ч©ЧӣЧ‘Ч” 2 вҖ” Keywords*\n' +
      '   ' + keywordCount + ' ЧһЧҷЧңЧҷЧқ ЧӨЧЁЧ•Ч©Ч•ЧӘ ЧўЧң ' + categoryCount + ' Ч§ЧҳЧ’Ч•ЧЁЧҷЧ•ЧӘ\n' +
      '   ~5ms вҖў Ч—ЧҷЧ Чқ\n\n' +
      'рҹҘү *Ч©ЧӣЧ‘Ч” 3 вҖ” AI*\n' +
      '   ' + (aiEnabled ? 'вң… ЧһЧ•ЧӨЧўЧң (' + _aiProv.provider + ')' : 'вҡ пёҸ ЧңЧҗ ЧһЧ•ЧӨЧўЧң (Ч—ЧЎЧЁ API key)') + '\n' +
      '   ~800ms\n\n' +
      'рҹ”’ Ч”ЧӣЧң Ч Ч©ЧһЧЁ Ч‘-Drive Ч©ЧңЧҡ. ЧңЧҗ ЧҗЧҰЧңЧ Ч•.';
  } catch (e) {
    return 'рҹҳ¬ ЧңЧҗ Ч”ЧҰЧңЧ—ЧӘЧҷ ЧңЧ§ЧЁЧ•Чҗ ЧһЧҰЧ‘ ЧһЧ Ч•Чў: ' + (e && e.message || '') + '\nрҹ’Ў Ч Ч ЧЎЧ” Ч©Ч•Ч‘ Ч‘ЧўЧ•Ч“ Ч“Ч§Ч”?';
  }
}

// Multi-tenant account linking handler.
// Called when the bot sees "Ч§Ч•Ч“ XXXXXX" / "code XXXXXX" / "link XXXXXX" from a sender.
// Sends the code + sender phone to /api/whatsapp/link?action=confirm on Vercel.
// The Vercel side resolves the code вҶ’ userSub, then permanently stores phone:<E164> вҶ’ userSub
// in KV, which the webhook + every future bot message uses to route to the right sheet.
function handleLinkCode_(code, fromPhone) {
  if (!fromPhone) {
    return 'рҹҳ¬ ЧңЧҗ Ч”ЧҰЧңЧ—ЧӘЧҷ ЧңЧ–Ч”Ч•ЧӘ ЧҗЧӘ Ч”ЧһЧЎЧӨЧЁ Ч©ЧңЧҡ ЧһЧ”Ч”Ч•Ч“ЧўЧ”\nрҹ’Ў Ч ЧЎЧ” ЧңЧ©ЧңЧ•Ч— Ч©Ч•Ч‘ ЧһЧҗЧ•ЧӘЧ• Ч•Ч•ЧҗЧҳЧЎЧҗЧӨ';
  }
  // If this number is ALREADY linked, say so вҖ” no need to process a code (and
  // avoid a confusing "code expired" reply when an old code is re-sent).
  try {
    var __statusUrl = KESEFLE_API_BASE + '/api/whatsapp/link?phone=' + encodeURIComponent(String(fromPhone));
    // Anonymous response is enough here: we only need { linked }.
    var __sResp = UrlFetchApp.fetch(__statusUrl, { method: 'get', muteHttpExceptions: true });
    if (__sResp.getResponseCode() === 200) {
      var __sBody = {};
      try { __sBody = JSON.parse(__sResp.getContentText() || '{}'); } catch (_pe) {}
      if (__sBody.ok && __sBody.linked) {
        return 'вң… *ЧҗЧӘЧ” ЧӣЧ‘ЧЁ ЧһЧ—Ч•Ч‘ЧЁ!*\n' +
          'в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n' +
          'ЧҗЧҷЧҹ ЧҰЧ•ЧЁЧҡ Ч‘Ч§Ч•Ч“ вҖ” Ч”ЧһЧЎЧӨЧЁ Ч”Ч–Ч” ЧӣЧ‘ЧЁ ЧһЧ§Ч•Ч©ЧЁ ЧңЧ—Ч©Ч‘Ч•Чҹ Ч©ЧңЧҡ.\n' +
          'ЧӨЧ©Ч•Чҳ Ч©ЧңЧ— Ч”Ч•ЧҰЧҗЧ” вҖ” ЧңЧһЧ©Чң "45 Ч§ЧӨЧ”" ЧҗЧ• "245 ЧЎЧ•ЧӨЧЁ" вҖ” Ч•ЧҗЧ Чҷ ЧҗЧӣЧ ЧҷЧЎ ЧҗЧ•ЧӘЧ” ЧңЧ’ЧҷЧңЧҷЧ•Чҹ. рҹ“Ҡ';
      }
    }
  } catch (_statusErr) { /* best-effort вҖ” fall through to the normal confirm */ }

  var url = KESEFLE_API_BASE + '/api/whatsapp/link?action=confirm';
  var botSecret = PropertiesService.getScriptProperties().getProperty('KESEFLE_BOT_SECRET') || '';
  var payload = { code: String(code), phone: String(fromPhone) };
  try {
    var resp = UrlFetchApp.fetch(url, {
      method: 'post',
      contentType: 'application/json',
      headers: botSecret ? { 'x-kesefle-bot-secret': botSecret } : {},
      payload: JSON.stringify(payload),
      muteHttpExceptions: true
    });
    var status = resp.getResponseCode();
    var body = {};
    try { body = JSON.parse(resp.getContentText() || '{}'); } catch (e) {}
    if (status === 200 && body.ok) {
      return 'вң… *Ч”Ч§ЧҷЧ©Ч•ЧЁ Ч”Ч•Ч©ЧңЧқ!*\n' +
        'в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n' +
        'ЧһЧ”ЧЁЧ’Чў Ч”Ч–Ч”, ЧӣЧң Ч”Ч•ЧҰЧҗЧ” Ч©ЧӘЧ©ЧңЧ— ЧӘЧҷЧӣЧӘЧ‘ ЧҗЧ•ЧҳЧ•ЧһЧҳЧҷЧӘ ЧңЧ’ЧҷЧңЧҷЧ•Чҹ Ч©ЧңЧҡ.\n\n' +
        'рҹ’Ў *ЧңЧ“Ч•Ч’ЧһЧ” вҖ” Ч ЧЎЧ”/Чҷ:*\n' +
        '  вҖў "245 ЧЎЧ•ЧӨЧЁ"\n' +
        '  вҖў "42 Ч§ЧӨЧ”"\n' +
        '  вҖў "8500 ЧһЧ©ЧӣЧ•ЧЁЧӘ"\n\n' +
        'ЧӣЧӘЧ•Ч‘ "ЧўЧ–ЧЁЧ”" ЧңЧЁЧ©ЧҷЧһЧӘ Ч”ЧӨЧ§Ч•Ч“Ч•ЧӘ Ч”ЧһЧңЧҗЧ”.';
    }
    if (status === 404) {
      return 'рҹҳ¬ Ч”Ч§Ч•Ч“ ЧӨЧ’ ЧӘЧ•Ч§ЧЈ ЧҗЧ• ЧңЧҗ ЧӘЧ§ЧҷЧҹ\nрҹ’Ў Ч—Ч–ЧЁЧҷ Чң-https://kesefle.com/account Ч•ЧҰЧЁЧҷ Ч§Ч•Ч“ Ч—Ч“Ч© (ЧӘЧ§ЧЈ Чң-10 Ч“Ч§Чі)';
    }
    if (status === 409) {
      return 'вҡ пёҸ Ч”ЧһЧЎЧӨЧЁ Ч”Ч–Ч” ЧӣЧ‘ЧЁ ЧһЧ—Ч•Ч‘ЧЁ ЧңЧ—Ч©Ч‘Ч•Чҹ ЧҗЧ—ЧЁ.\nрҹ’Ў ЧҗЧқ Ч–Ч” Ч”Ч—Ч©Ч‘Ч•Чҹ Ч©ЧңЧҡ вҖ” Ч”ЧӘЧ—Ч‘ЧЁ ЧңЧҗЧ•ЧӘЧ• Ч—Ч©Ч‘Ч•Чҹ Google Ч©ЧҗЧҷЧӘЧ• Ч ЧЁЧ©ЧһЧӘ.';
    }
    if (status === 401) {
      return 'рҹҳ¬ ЧңЧҗ Ч”ЧҰЧңЧ—ЧӘЧҷ ЧңЧҗЧһЧӘ ЧҗЧӘ Ч”Ч‘Ч§Ч©Ч” (ЧЎЧ•Ч“ Ч‘Ч•Чҳ Ч©Ч’Ч•Чҷ)\nрҹ’Ў ЧӨЧ Ч” ЧңЧӘЧһЧҷЧӣЧ” Ч“ЧЁЧҡ https://kesefle.com';
    }
    Logger.log('handleLinkCode_: unexpected status=' + status + ' body=' + JSON.stringify(body));
    return 'рҹҳ¬ ЧһЧ©Ч”Ч• Ч”Ч©ЧӘЧ‘Ч© Ч‘Ч§ЧҷЧ©Ч•ЧЁ\nрҹ’Ў Ч ЧЎЧ” Ч©Ч•Ч‘ ЧҗЧ• ЧҰЧ•ЧЁ Ч§Ч•Ч“ Ч—Ч“Ч© Ч‘-https://kesefle.com/account';
  } catch (e) {
    Logger.log('handleLinkCode_ error: ' + (e && e.stack || e));
    return 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧӘ ЧЁЧ©ЧӘ\nрҹ’Ў Ч Ч ЧЎЧ” Ч©Ч•Ч‘ Ч‘ЧўЧ•Ч“ ЧЁЧ’Чў?';
  }
}

