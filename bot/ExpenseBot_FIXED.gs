// рҹҺҜ GOAL TRACKING вҖ” let users set savings/spending goals + nudge them
// ============================================================
// Examples:
//   "ЧһЧҳЧЁЧ”: Ч—ЧҷЧЎЧӣЧ•Чҹ 5000 ЧңЧ—Ч•ЧӨЧ©Ч” ЧўЧ“ ЧҗЧ•Ч’Ч•ЧЎЧҳ"  вҶ’ set savings goal
//   "ЧһЧҳЧЁЧ”: ЧўЧ“ 800 Ч©Ч— ЧўЧң ЧҗЧ•ЧӣЧң Ч‘Ч—Ч•ЧҘ Ч‘Ч—Ч•Ч“Ч©"  вҶ’ set spending cap
//   "ЧһЧҳЧЁЧ•ЧӘ"                              вҶ’ list active goals + progress
//   "ЧһЧ—Ч§ ЧһЧҳЧЁЧ” X"                          вҶ’ remove goal
//
// Goals are stored as JSON in Script Properties (key: goals:active).
// Each goal: { id, type:'save'|'cap', target, category?, deadline?, createdAt, current }
function getGoalsMessage() {
  try {
    var goals = _loadGoals_();
    if (!goals.length) {
      return 'рҹҺҜ *Ч”ЧһЧҳЧЁЧ•ЧӘ Ч©ЧңЧҡ*\n' +
        'в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n' +
        'ЧўЧ“ЧҷЧҷЧҹ ЧҗЧҷЧҹ ЧңЧҡ ЧһЧҳЧЁЧ•ЧӘ ЧӨЧўЧҷЧңЧ•ЧӘ.\n\n' +
        'рҹ’Ў *Ч“Ч•Ч’ЧһЧҗЧ•ЧӘ ЧңЧ”Ч’Ч“ЧЁЧӘ ЧһЧҳЧЁЧ”:*\n' +
        '  вҖў "ЧһЧҳЧЁЧ”: Ч—ЧҷЧЎЧӣЧ•Чҹ 5000 ЧңЧ—Ч•ЧӨЧ©Ч” ЧўЧ“ ЧҗЧ•Ч’Ч•ЧЎЧҳ"\n' +
        '  вҖў "ЧһЧҳЧЁЧ”: ЧўЧ“ 800 Ч©Ч— ЧўЧң ЧҗЧ•ЧӣЧң Ч‘Ч—Ч•ЧҘ Ч‘Ч—Ч•Ч“Ч©"\n' +
        '  вҖў "ЧһЧҳЧЁЧ”: ЧңЧҗ ЧңЧ”Ч•ЧҰЧҷЧҗ ЧўЧң Ч§ЧӨЧ” Ч”Ч©Ч‘Ч•Чў"';
    }
    var lines = ['рҹҺҜ *Ч”ЧһЧҳЧЁЧ•ЧӘ Ч©ЧңЧҡ*', 'в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ', ''];
    for (var i = 0; i < goals.length; i++) {
      var g = goals[i];
      var pct = g.target > 0 ? Math.round((g.current / g.target) * 100) : 0;
      var bar = _progressBar_(pct);
      var emoji = g.type === 'save' ? 'рҹ’°' : 'рҹҺҜ';
      var label = g.type === 'save' ? 'Ч—ЧҷЧЎЧӣЧ•Чҹ' : 'ЧһЧ§ЧЎЧҷЧһЧ•Чқ';
      lines.push(emoji + ' *' + g.title + '*');
      lines.push('   ' + label + ': вӮӘ' + g.target.toLocaleString());
      lines.push('   ' + bar + ' ' + pct + '%');
      lines.push('   вӮӘ' + g.current.toLocaleString() + ' / вӮӘ' + g.target.toLocaleString());
      if (g.deadline) lines.push('   рҹ“… ЧўЧ“: ' + g.deadline);
      lines.push('');
    }
    lines.push('рҹ’Ў ЧӣЧӘЧ•Ч‘ "ЧһЧ—Ч§ ЧһЧҳЧЁЧ” X" ЧӣЧ“Чҷ ЧңЧ”ЧЎЧҷЧЁ');
    return lines.join('\n');
  } catch (e) {
    Logger.log('getGoalsMessage error: ' + e);
    return 'рҹҳ¬ ЧһЧ©Ч”Ч• Ч”Ч©ЧӘЧ‘Ч© Ч‘ЧҳЧўЧҷЧ ЧӘ ЧһЧҳЧЁЧ•ЧӘ\nрҹ’Ў Ч Ч ЧЎЧ” Ч©Ч•Ч‘ Ч‘ЧўЧ•Ч“ Ч“Ч§Ч”?';
  }
}

function _progressBar_(pct) {
  var filled = Math.min(10, Math.floor(pct / 10));
  var empty = 10 - filled;
  return 'в–°'.repeat(filled) + 'в–ұ'.repeat(empty);
}

function _loadGoals_() {
  try {
    var raw = PropertiesService.getScriptProperties().getProperty('goals:active');
    if (!raw) return [];
    var goals = JSON.parse(raw);
    // Recompute current values from sheet
    return goals.map(_refreshGoalProgress_);
  } catch (e) {
    return [];
  }
}

function _saveGoals_(goals) {
  PropertiesService.getScriptProperties().setProperty('goals:active', JSON.stringify(goals));
}

function _refreshGoalProgress_(goal) {
  try {
    var sheet = SpreadsheetApp.openById(SHEET_ID).getSheetByName(TRANSACTIONS_SHEET);
    if (!sheet) return goal;
    var data = sheet.getDataRange().getValues();
    var current = 0;
    var startDate = goal.startDate ? new Date(goal.startDate) : new Date(new Date().getFullYear(), new Date().getMonth(), 1);
    for (var i = 1; i < data.length; i++) {
      var d = data[i][0] instanceof Date ? data[i][0] : new Date(data[i][0]);
      if (isNaN(d.getTime()) || d < startDate) continue;
      var cat = String(data[i][3] || '');
      var sub = String(data[i][4] || '');
      if (goal.category && !cat.includes(goal.category) && !sub.includes(goal.category)) continue;
      if (goal.type === 'save' && /Ч”ЧӣЧ ЧЎЧ•ЧӘ|Ч”ЧӣЧ ЧЎЧ”/i.test(cat)) {
        current += Number(data[i][2]) || 0;
      } else if (goal.type === 'cap' && !/Ч”ЧӣЧ ЧЎЧ•ЧӘ|Ч”ЧӣЧ ЧЎЧ”/i.test(cat)) {
        current += Number(data[i][2]) || 0;
      }
    }
    goal.current = current;
    return goal;
  } catch (e) {
    return goal;
  }
}

// Parser: "ЧһЧҳЧЁЧ”: Ч—ЧҷЧЎЧӣЧ•Чҹ 5000 ЧңЧ—Ч•ЧӨЧ©Ч” ЧўЧ“ ЧҗЧ•Ч’Ч•ЧЎЧҳ" or "ЧһЧҳЧЁЧ”: ЧўЧ“ 800 Ч©Ч— ЧўЧң ЧҗЧ•ЧӣЧң"
function parseGoalCommand(text) {
  var t = String(text || '').trim();
  // Match "ЧһЧҳЧЁЧ”: <anything>"
  var m = t.match(/^ЧһЧҳЧЁЧ”\s*[:\-]?\s*(.+)$/i);
  if (!m) return null;
  var body = m[1].trim();
  // Extract amount
  var amountM = body.match(/(\d+(?:[.,]\d+)?)\s*(?:Ч©Ч—|вӮӘ|Ч©"Ч—)?/);
  if (!amountM) return null;
  var amount = parseFloat(amountM[1].replace(',', ''));
  // Detect type
  var isCapMode = /^ЧўЧ“\s|ЧһЧ§ЧЎЧҷЧһЧ•Чқ|ЧңЧҗ ЧҷЧ•ЧӘЧЁ/i.test(body);
  var isSaveMode = /Ч—ЧҷЧЎЧӣЧ•Чҹ|ЧңЧ—ЧЎЧ•Чҡ/i.test(body) || !isCapMode;
  // Extract category (optional)
  var catM = body.match(/(?:ЧўЧң|Ч‘Ч§ЧҳЧ’Ч•ЧЁЧҷЧ”|Чң)\s+([Цҗ-Чҝa-zA-Z]+(?:\s+[Цҗ-Чҝa-zA-Z]+){0,2})/);
  var category = catM ? catM[1].trim() : null;
  // Extract deadline (optional)
  var deadlineM = body.match(/ЧўЧ“\s+([Цҗ-Чҝa-zA-Z\d\s\/\-\.]+?)(?:\s|$)/);
  var deadline = deadlineM ? deadlineM[1].trim() : null;
  return {
    type: isCapMode ? 'cap' : 'save',
    target: amount,
    category: category,
    deadline: deadline,
    title: body.slice(0, 60),
    id: Date.now().toString(36)
  };
}

function addGoal(parsed) {
  var goals = _loadGoals_();
  // Limit: 5 active goals
  if (goals.length >= 5) {
    return 'рҹҳ¬ Ч”Ч’ЧўЧӘ ЧңЧӘЧ§ЧЁЧӘ 5 ЧһЧҳЧЁЧ•ЧӘ\nрҹ’Ў Ч©ЧңЧ— "ЧһЧҳЧЁЧ•ЧӘ" ЧңЧЁЧҗЧ•ЧӘ ЧҗЧӘ Ч”ЧЁЧ©ЧҷЧһЧ” Ч•ЧһЧ—Ч§ ЧҗЧ—ЧӘ ЧңЧӨЧ Чҷ Ч©ЧӘЧ•ЧЎЧҷЧЈ Ч—Ч“Ч©Ч”';
  }
  parsed.createdAt = new Date().toISOString();
  parsed.startDate = new Date(new Date().getFullYear(), new Date().getMonth(), 1).toISOString();
  parsed.current = 0;
  goals.push(parsed);
  _saveGoals_(goals);
  var emoji = parsed.type === 'save' ? 'рҹ’°' : 'рҹҺҜ';
  return emoji + ' *ЧһЧҳЧЁЧ” Ч Ч•ЧЎЧӨЧ” Ч‘Ч”ЧҰЧңЧ—Ч”!*\n\n' +
    parsed.title + '\n' +
    'ЧҷЧўЧ“: вӮӘ' + parsed.target.toLocaleString() + '\n' +
    (parsed.category ? 'Ч§ЧҳЧ’Ч•ЧЁЧҷЧ”: ' + parsed.category + '\n' : '') +
    (parsed.deadline ? 'ЧӘЧҗЧЁЧҷЧҡ ЧҷЧўЧ“: ' + parsed.deadline + '\n' : '') +
    // HONESTY (2026-05-24): there's no cron that nudges goal progress вҖ”
    // the user has to ask. Don't promise updates we don't send.
    '\nЧ©ЧңЧ— *"ЧһЧҳЧЁЧ•ЧӘ"* Ч‘ЧӣЧң ЧўЧӘ ЧӣЧ“Чҷ ЧңЧЁЧҗЧ•ЧӘ Ч”ЧӘЧ§Ч“ЧһЧ•ЧӘ.';
}

function deleteGoal(idOrIndex) {
  var goals = _loadGoals_();
  var idx = -1;
  // Try by index (1-based for user-friendliness)
  var asNum = parseInt(idOrIndex, 10);
  if (!isNaN(asNum) && asNum >= 1 && asNum <= goals.length) {
    idx = asNum - 1;
  } else {
    // Try by ID
    for (var i = 0; i < goals.length; i++) {
      if (goals[i].id === idOrIndex) { idx = i; break; }
    }
  }
  if (idx < 0) return 'рҹҳ¬ ЧңЧҗ ЧһЧҰЧҗЧӘЧҷ ЧҗЧӘ Ч”ЧһЧҳЧЁЧ”\nрҹ’Ў Ч©ЧңЧ— "ЧһЧҳЧЁЧ•ЧӘ" ЧңЧЁЧҗЧ•ЧӘ ЧҗЧӘ Ч”ЧЁЧ©ЧҷЧһЧ”';
  var removed = goals.splice(idx, 1)[0];
  _saveGoals_(goals);
  return 'рҹ—‘пёҸ Ч ЧһЧ—Ч§Ч” ЧһЧҳЧЁЧ”: "' + removed.title + '"';
}

