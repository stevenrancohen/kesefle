  return false;
}

var _CANONICAL_CAT_BY_SUB = {
  'ЧҗЧ•ЧӣЧң ЧңЧ‘ЧҷЧӘ': 'ЧҗЧ•ЧӣЧң',
  'ЧҗЧ•ЧӣЧң Ч‘Ч—Ч•ЧҘ': 'ЧҗЧ•ЧӣЧң',
  'ЧһЧЎЧўЧ“Ч•ЧӘ': 'ЧҗЧ•ЧӣЧң',
  'ЧЎЧ•ЧӨЧЁ': 'ЧҗЧ•ЧӣЧң'
