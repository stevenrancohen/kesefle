function _groupRecordExpense_(fromPhone, body) {
  var a = _groupAPI_('getactive', { phone: fromPhone });
  if (!a || !a.ok || !a.active) {
    return { handled: true, replyText: 'ЧҗЧӘЧ” ЧңЧҗ Ч‘Ч§Ч‘Ч•ЧҰЧ” ЧӣЧЁЧ’Чў. Ч©ЧңЧ— "ЧӣЧЎЧӨЧңЧ” ЧҰЧ•ЧЁ <Ч©Чқ>" ЧҗЧ• "ЧӣЧЎЧӨЧңЧ” Ч”ЧҰЧҳЧЁЧЈ <Ч§Ч•Ч“>".' };
  }
  // Parse amount + description from the body. Reuse the bot's existing
  // Israeli-format number parser so "1,200" works correctly.
  var parsed = (typeof parseAmountAndDescription === 'function') ? parseAmountAndDescription(body) : null;
  if (!parsed || !parsed.items || !parsed.items.length) {
    return { handled: true, replyText: 'рҹҳ¬ ЧңЧҗ Ч–ЧҷЧ”ЧҷЧӘЧҷ ЧЎЧӣЧ•Чқ. Ч“Ч•Ч’ЧһЧ”: "ЧӣЧЎЧӨЧңЧ” 245 ЧЎЧ•ЧӨЧЁ"' };
  }
  var first = parsed.items[0];
  var matched = null;
  try { matched = typeof matchCategory === 'function' ? matchCategory(body) : null; } catch (_) {}
  var category = (matched && matched.category) || '';
  var subcategory = (matched && matched.subcategory && matched.subcategory !== matched.category) ? matched.subcategory : '';

  var senderName = _groupSenderName_(fromPhone);
  var r = _groupAPI_('addexpense', {
    code: a.active,
    payerPhone: fromPhone,
    requesterPhone: fromPhone,
    payerName: senderName,
    amount: first.amount,
    description: first.description,
    category: category,
    subcategory: subcategory,
    splitMode: 'equal',
  });
  if (!r || !r.ok) {
    if (r && r.error === 'not_a_member') {
      return { handled: true, replyText: 'рҹҳ¬ ЧҗЧӘЧ” ЧңЧҗ Ч—Ч‘ЧЁ Ч‘Ч§Ч‘Ч•ЧҰЧ” Ч”Ч–ЧҗЧӘ. Ч©ЧңЧ— "ЧӣЧЎЧӨЧңЧ” Ч”ЧҰЧҳЧЁЧЈ <Ч§Ч•Ч“>" Ч§Ч•Ч“Чқ.' };
    }
    return { handled: true, replyText: 'рҹҳ¬ ЧӣЧӘЧҷЧ‘ЧӘ Ч”Ч”Ч•ЧҰЧҗЧ” Ч ЧӣЧ©ЧңЧ”: ' + (r && r.error || 'unknown') };
  }
  var perShare = (first.amount / (r.memberCount || 1)).toFixed(2);
  return { handled: true, replyText:
    'вң… Ч ЧЁЧ©Чқ: вӮӘ' + first.amount.toLocaleString('he-IL') + ' В· ' + (first.description || category || 'Ч”Ч•ЧҰЧҗЧ”') + '\n' +
    'рҹ‘Ө Ч©Ч•ЧңЧқ Чў"Чҷ: ' + senderName + '\n' +
    'рҹ‘Ҙ ЧӨЧҷЧҰЧ•Чң Ч©Ч•Ч•Ч” Ч‘ЧҷЧҹ ' + r.memberCount + ' Ч—Ч‘ЧЁЧҷЧқ (вӮӘ' + perShare + ' ЧӣЧң ЧҗЧ—Ч“)' };
}

function _groupBalances_(fromPhone, mode) {
  var a = _groupAPI_('getactive', { phone: fromPhone });
  if (!a || !a.ok || !a.active) {
    return { handled: true, replyText: 'ЧҗЧӘЧ” ЧңЧҗ Ч‘Ч§Ч‘Ч•ЧҰЧ”. Ч©ЧңЧ— "ЧӣЧЎЧӨЧңЧ” ЧҰЧ•ЧЁ" ЧҗЧ• "ЧӣЧЎЧӨЧңЧ” Ч”ЧҰЧҳЧЁЧЈ <Ч§Ч•Ч“>".' };
  }
  var b = _groupAPI_('balances', { code: a.active, requesterPhone: fromPhone });
  if (!b || !b.ok) return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ” Ч‘Ч§ЧЁЧҷЧҗЧӘ Ч”ЧҷЧӘЧЁЧ•ЧӘ.' };
  if (!b.totalExpenses) return { handled: true, replyText: 'ЧҗЧҷЧҹ Ч”Ч•ЧҰЧҗЧ•ЧӘ ЧўЧ“ЧҷЧҷЧҹ Ч‘Ч§Ч‘Ч•ЧҰЧ”. Ч©ЧңЧ— "ЧӣЧЎЧӨЧңЧ” 245 ЧЎЧ•ЧӨЧЁ" ЧӣЧ“Чҷ ЧңЧ”ЧӘЧ—ЧҷЧң.' };

  var lines = [];
  if (mode !== 'settle') {
    lines.push('рҹ“Ҡ *ЧҷЧӘЧЁЧ•ЧӘ (' + a.active + ')*');
    lines.push('в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ');
    lines.push('');
    b.balances.forEach(function(m){
      var arrow = m.net > 0 ? 'рҹҹў' : (m.net < 0 ? 'рҹ”ҙ' : 'вҡӘ');
      var verb = m.net > 0 ? 'ЧһЧ§Ч‘Чң' : (m.net < 0 ? 'Ч—ЧҷЧҷЧ‘' : 'ЧһЧҗЧ•Ч–Чҹ');
      var amt = Math.abs(m.net).toLocaleString('he-IL');
      lines.push('  ' + arrow + ' ' + m.name + ': ' + verb + ' вӮӘ' + amt);
    });
    lines.push('');
  }
  if (b.settlements && b.settlements.length) {
    lines.push('рҹ’ё *Ч”ЧўЧ‘ЧЁЧ•ЧӘ ЧһЧ•ЧһЧңЧҰЧ•ЧӘ:*');
    b.settlements.forEach(function(t){
      lines.push('  ' + t.fromName + ' вҶ’ ' + t.toName + '  вӮӘ' + t.amount.toLocaleString('he-IL'));
    });
  } else {
    lines.push('вң… Ч”Ч§Ч‘Ч•ЧҰЧ” ЧһЧҗЧ•Ч–Ч ЧӘ вҖ” ЧҗЧҷЧҹ ЧҰЧ•ЧЁЧҡ Ч‘Ч”ЧўЧ‘ЧЁЧ•ЧӘ.');
  }
  return { handled: true, replyText: lines.join('\n') };
}

