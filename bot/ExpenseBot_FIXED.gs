// ============ HTTP helper for /api/group ============
function _groupAPI_(action, payload) {
  var secret = '';
  try { secret = String(PropertiesService.getScriptProperties().getProperty('KESEFLE_BOT_SECRET') || ''); } catch (_e) {}
  if (!secret) {
    Logger.log('_groupAPI_: KESEFLE_BOT_SECRET not set in Script Properties');
    return { ok: false, error: 'bot_secret_not_set' };
  }
  payload = payload || {};
  payload.action = action;
  payload.botSecret = secret;
  try {
    var resp = UrlFetchApp.fetch(KESEFLE_API_BASE + '/api/group', {
      method: 'post',
      contentType: 'application/json',
      headers: { 'x-kesefle-bot-secret': secret },
      payload: JSON.stringify(payload),
      muteHttpExceptions: true,
    });
    var code = resp.getResponseCode();
    var body = resp.getContentText();
    if (code < 200 || code >= 300) {
      Logger.log('_groupAPI_ ' + action + ' HTTP ' + code + ': ' + body.slice(0, 300));
      try { return JSON.parse(body); } catch (_je) { return { ok: false, error: 'http_' + code }; }
    }
    return JSON.parse(body);
  } catch (e) {
    Logger.log('_groupAPI_ ' + action + ' threw: ' + (e && e.message));
    return { ok: false, error: 'fetch_threw', detail: e && e.message };
  }
}

// ============ command implementations ============

function _groupCreate_(fromPhone, name) {
  var groupName = name && name.length > 0 ? name : 'Ч”Ч§Ч‘Ч•ЧҰЧ” Ч©ЧңЧҷ';
  var senderName = _groupSenderName_(fromPhone);
  var r = _groupAPI_('create', { creatorPhone: fromPhone, creatorName: senderName, groupName: groupName });
  if (!r || !r.ok) {
    return { handled: true, replyText: 'рҹҳ¬ ЧңЧҗ Ч”ЧҰЧңЧ—ЧӘЧҷ ЧңЧҷЧҰЧ•ЧЁ Ч§Ч‘Ч•ЧҰЧ”: ' + (r && r.error || 'Ч©Ч’ЧҷЧҗЧ”') };
  }
  // HONESTY: server creates the KV record either way, but the SHARED SHEET
  // creation is best-effort and depends on the creator having an OAuth-linked
  // account. We must NOT lie that "group created" if the user can't actually
  // use it. Tell the user the true state.
  var sheetCreated = !!(r.group && (r.group.sheetUrl || r.group.sheetId));
  var sheetLine = sheetCreated
    ? 'рҹ“Ҡ Ч’ЧҷЧңЧҷЧ•Чҹ ЧһЧ©Ч•ЧӘЧЈ Ч Ч•ЧҰЧЁ Ч‘-Drive Ч©ЧңЧҡ:\n' + (r.group.sheetUrl || ('https://docs.google.com/spreadsheets/d/' + r.group.sheetId)) + '\n\n'
    : 'вҡ пёҸ  *Ч”Ч§Ч‘Ч•ЧҰЧ” ЧЁЧ©Ч•ЧһЧ” ЧҗЧ‘Чң Ч‘ЧңЧҷ Ч’ЧҷЧңЧҷЧ•Чҹ ЧһЧ©Ч•ЧӘЧЈ ЧўЧ“ЧҷЧҷЧҹ.* ЧӣЧ“Чҷ Ч©ЧҗЧ Чҷ ЧҗЧ•ЧӣЧң ЧңЧҷЧҰЧ•ЧЁ ЧҗЧӘ Ч”Ч’ЧҷЧңЧҷЧ•Чҹ:\n' +
      '1. ЧӣЧ ЧЎ/Чҷ Чң-kesefle.com/account ЧўЧқ Ч”ЧһЧЎЧӨЧЁ Ч”Ч–Ч”\n' +
      '2. Ч”ЧӘЧ—Ч‘ЧЁ ЧўЧқ Google\n' +
      '3. Ч©ЧңЧ— Ч©Ч•Ч‘ "ЧӣЧЎЧӨЧңЧ” ЧҰЧ•ЧЁ ЧһЧ©ЧӨЧ—Ч” ' + groupName + '"\n\n';
  return { handled: true, replyText:
    'вң… Ч Ч•ЧҰЧЁЧ” Ч§Ч‘Ч•ЧҰЧ”: *' + groupName + '*\n' +
    'рҹ”‘ Ч§Ч•Ч“ Ч”Ч–ЧһЧ Ч”: *' + r.code + '*\n\n' +
    sheetLine +
    'Ч©ЧӘЧЈ/Чҷ ЧҗЧӘ Ч”Ч§Ч•Ч“ ЧўЧқ Ч—Ч‘ЧЁЧҷ Ч”Ч§Ч‘Ч•ЧҰЧ” ЧӣЧ“Чҷ Ч©ЧҷЧҰЧҳЧЁЧӨЧ•:\n' +
    '"ЧӣЧЎЧӨЧңЧ” Ч”ЧҰЧҳЧЁЧЈ ' + r.code + '"\n\n' +
    'ЧҗЧ• Ч”Ч–ЧһЧҹ/Чҷ ЧҗЧ•ЧӘЧқ Ч‘-https://kesefle.com/family-invite\n\n' +
    (sheetCreated ? 'ЧўЧӣЧ©ЧҷЧ• ЧҗЧӨЧ©ЧЁ ЧңЧЁЧ©Ч•Чқ Ч”Ч•ЧҰЧҗЧ”: "ЧӣЧЎЧӨЧңЧ” 245 ЧЎЧ•ЧӨЧЁ"' : '(ЧңЧҗЧ—ЧЁ Ч©ЧӘЧ©ЧңЧҷЧқ/Чҷ ЧҗЧӘ Ч”Ч—ЧҷЧ‘Ч•ЧЁ, Ч”Ч•ЧҰЧҗЧ•ЧӘ ЧҷЧ–Ч•Ч”Ч• ЧҗЧ•ЧҳЧ•ЧһЧҳЧҷЧӘ)') };
}

function _groupJoin_(fromPhone, code) {
  var senderName = _groupSenderName_(fromPhone);
  var r = _groupAPI_('join', { phone: fromPhone, name: senderName, code: code });
  if (!r || !r.ok) {
    if (r && r.error === 'group_not_found') {
      return { handled: true, replyText: 'рҹҳ¬ ЧңЧҗ ЧһЧҰЧҗЧӘЧҷ Ч§Ч‘Ч•ЧҰЧ” ЧўЧқ Ч§Ч•Ч“ "' + code + '". Ч‘Ч“Ч•Ч§ ЧҗЧӘ Ч”Ч§Ч•Ч“ Ч•Ч ЧЎЧ” Ч©Ч•Ч‘.' };
    }
    return { handled: true, replyText: 'рҹҳ¬ ЧңЧҗ Ч”ЧҰЧңЧ—ЧӘЧҷ ЧңЧ”ЧҰЧҳЧЁЧЈ: ' + (r && r.error || 'Ч©Ч’ЧҷЧҗЧ”') };
  }
  var memberCount = r.group && r.group.members ? r.group.members.length : '?';
  return { handled: true, replyText:
    'вң… Ч”ЧҰЧҳЧЁЧӨЧӘ Чң-*' + (r.group && r.group.name || 'Ч”Ч§Ч‘Ч•ЧҰЧ”') + '* (' + memberCount + ' Ч—Ч‘ЧЁЧҷЧқ).\n\n' +
    'ЧһЧўЧӣЧ©ЧҷЧ• "ЧӣЧЎЧӨЧңЧ” <ЧЎЧӣЧ•Чқ> <ЧӨЧҷЧЁЧ•Чҳ>" ЧҷЧҷЧЁЧ©Чқ Ч‘Ч§Ч‘Ч•ЧҰЧ” Ч”Ч–ЧҗЧӘ.\n' +
    'Ч ЧЎЧ”: "ЧӣЧЎЧӨЧңЧ” 50 Ч§ЧӨЧ”"' };
}

function _groupSetActive_(fromPhone, code) {
  var r = _groupAPI_('setactive', { phone: fromPhone, code: code });
  if (!r || !r.ok) return { handled: true, replyText: 'рҹҳ¬ ЧңЧҗ Ч”ЧҰЧңЧ—ЧӘЧҷ ЧңЧ”Ч—ЧңЧҷЧЈ: ' + (r && r.error || 'Ч©Ч’ЧҷЧҗЧ”') };
  return { handled: true, replyText: 'вң… ЧўЧ‘ЧЁЧӘ ЧңЧ§Ч‘Ч•ЧҰЧ” ' + code + '.' };
}

function _groupLeave_(fromPhone, personalMode) {
  var r = _groupAPI_('leave', { phone: fromPhone });
  if (!r || !r.ok) return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ”: ' + (r && r.error || 'unknown') };
  if (personalMode) {
    return { handled: true, replyText: 'рҹҸ  Ч—Ч–ЧЁЧӘ ЧңЧһЧҰЧ‘ ЧҗЧҷЧ©Чҷ. Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч‘ЧңЧҷ "ЧӣЧЎЧӨЧңЧ”" ЧҷЧҷЧЁЧ©ЧһЧ• Ч‘Ч’ЧҷЧңЧҷЧ•Чҹ Ч”ЧҗЧҷЧ©Чҷ Ч©ЧңЧҡ.' };
  }
  return { handled: true, replyText: 'рҹ‘Ӣ ЧўЧ–Ч‘ЧӘ ЧҗЧӘ Ч”Ч§Ч‘Ч•ЧҰЧ” Ч”ЧӨЧўЧҷЧңЧ”. Ч©ЧңЧ— "ЧӣЧЎЧӨЧңЧ” Ч”ЧҰЧҳЧЁЧЈ <Ч§Ч•Ч“>" ЧҗЧ• "ЧӣЧЎЧӨЧңЧ” Ч”Ч—ЧңЧЈ <Ч§Ч•Ч“>" ЧӣЧ“Чҷ ЧңЧ”ЧҰЧҳЧЁЧЈ ЧңЧҗЧ—ЧЁЧӘ.' };
}

function _groupContext_(fromPhone) {
  var r = _groupAPI_('mygroups', { phone: fromPhone });
  if (!r || !r.ok) return { handled: true, replyText: 'рҹҳ¬ ЧңЧҗ Ч”ЧҰЧңЧ—ЧӘЧҷ ЧңЧ‘Ч“Ч•Ч§.' };
  if (!r.groups || !r.groups.length) {
    return { handled: true, replyText: 'рҹҸ  *ЧһЧҰЧ‘ ЧҗЧҷЧ©Чҷ* вҖ” ЧҗЧӘЧ” ЧңЧҗ Ч—Ч‘ЧЁ Ч‘ЧҗЧЈ Ч§Ч‘Ч•ЧҰЧ”.\n\nЧ©ЧңЧ— "ЧӣЧЎЧӨЧңЧ” ЧҰЧ•ЧЁ <Ч©Чқ>" ЧӣЧ“Чҷ ЧңЧҷЧҰЧ•ЧЁ ЧҗЧ—ЧӘ.' };
  }
  var lines = ['рҹ“Ӣ *Ч”Ч§Ч‘Ч•ЧҰЧ•ЧӘ Ч©ЧңЧҷ*', 'в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ', ''];
  r.groups.forEach(function(g){
    var marker = (r.active === g.code) ? 'рҹҹў ЧӨЧўЧҷЧңЧ”' : 'вҡӘ';
    lines.push('  ' + marker + ' *' + g.name + '* В· ' + g.code + ' В· ' + g.memberCount + ' Ч—Ч‘ЧЁЧҷЧқ В· ' + g.expenseCount + ' Ч”Ч•ЧҰЧҗЧ•ЧӘ');
  });
  lines.push('');
  lines.push('ЧңЧ”Ч—ЧңЧӨЧ”: "ЧӣЧЎЧӨЧңЧ” Ч”Ч—ЧңЧЈ <Ч§Ч•Ч“>"');
  lines.push('ЧңЧһЧҰЧ‘ ЧҗЧҷЧ©Чҷ: "ЧӣЧЎЧӨЧңЧ” ЧҗЧҷЧ©Чҷ"');
  return { handled: true, replyText: lines.join('\n') };
}

function _groupResync_(fromPhone) {
  var a = _groupAPI_('getactive', { phone: fromPhone });
  if (!a || !a.ok || !a.active) return { handled: true, replyText: 'ЧҗЧӘЧ” ЧңЧҗ Ч‘Ч§Ч‘Ч•ЧҰЧ”.' };
  var r = _groupAPI_('resync', { code: a.active });
  if (!r || !r.ok) {
    if (r && r.error === 'creator_not_oauth') {
      return { handled: true, replyText: 'рҹҳ¬ ЧҷЧ•ЧҰЧЁ Ч”Ч§Ч‘Ч•ЧҰЧ” ЧўЧ•Ч“ ЧңЧҗ Ч—ЧҷЧ‘ЧЁ ЧҗЧӘ Ч—Ч©Ч‘Ч•Чҹ Google. Ч”Ч•Чҗ ЧҰЧЁЧҷЧҡ ЧңЧ”ЧҷЧЁЧ©Чқ Ч‘-https://kesefle.com/account Ч§Ч•Ч“Чқ.' };
    }
    return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ”: ' + (r && r.error || 'unknown') };
  }
  if (r.already) {
    return { handled: true, replyText: 'вң“ Ч”Ч§Ч‘Ч•ЧҰЧ” ЧӣЧ‘ЧЁ ЧһЧЎЧ•Ч ЧӣЧЁЧ ЧӘ.\nрҹ“„ Ч”Ч’ЧҷЧңЧҷЧ•Чҹ: ' + r.sheetUrl };
  }
  return { handled: true, replyText: 'вң… Ч Ч•ЧҰЧЁ Ч’ЧҷЧңЧҷЧ•Чҹ ЧһЧ©Ч•ЧӘЧЈ Ч‘-Google Drive Ч©Чң ЧҷЧ•ЧҰЧЁ Ч”Ч§Ч‘Ч•ЧҰЧ”.\nрҹ“„ ' + r.sheetUrl + '\n\n' + (r.mirrored || 0) + ' Ч”Ч•ЧҰЧҗЧ•ЧӘ ЧЎЧ•Ч ЧӣЧЁЧ Ч• ЧңЧ’ЧҷЧңЧҷЧ•Чҹ.' };
}

function _groupAddRecurring_(fromPhone, rest) {
  var a = _groupAPI_('getactive', { phone: fromPhone });
  if (!a || !a.ok || !a.active) return { handled: true, replyText: 'ЧҗЧӘЧ” ЧңЧҗ Ч‘Ч§Ч‘Ч•ЧҰЧ”. Ч©ЧңЧ— "ЧӣЧЎЧӨЧңЧ” Ч”ЧҰЧҳЧЁЧЈ <Ч§Ч•Ч“>" Ч§Ч•Ч“Чқ.' };
  // Parse "<amount> <description> [interval]"
  var m = rest.match(/^([0-9]+(?:[.,][0-9]+)?)\s+(.+?)(?:\s+(Ч—Ч•Ч“Ч©Чҷ|Ч©Ч‘Ч•ЧўЧҷ|Ч“Ч•-Ч©Ч‘Ч•ЧўЧҷ|ЧҷЧ•ЧһЧҷ|monthly|weekly|biweekly|daily))?$/i);
  if (!m) return { handled: true, replyText: 'рҹҳ¬ ЧӨЧ•ЧЁЧһЧҳ: "ЧӣЧЎЧӨЧңЧ” Ч§Ч‘Ч•Чў 3000 Ч©ЧӣЧҷЧЁЧ•ЧӘ Ч—Ч•Ч“Ч©Чҷ"' };
  var amount = parseFloat(m[1].replace(',', '.'));
  var description = m[2].trim();
  var ilabel = (m[3] || 'Ч—Ч•Ч“Ч©Чҷ').toLowerCase();
  var interval = 'monthly';
  if (/Ч©Ч‘Ч•ЧўЧҷ|weekly/i.test(ilabel)) interval = 'weekly';
  if (/Ч“Ч•-Ч©Ч‘Ч•ЧўЧҷ|biweekly/i.test(ilabel)) interval = 'biweekly';
  if (/ЧҷЧ•ЧһЧҷ|daily/i.test(ilabel)) interval = 'daily';
  var r = _groupAPI_('addrecurring', {
    code: a.active, payerPhone: fromPhone, amount: amount, description: description, interval: interval,
  });
  if (!r || !r.ok) return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ”: ' + (r && r.error || 'unknown') };
  // HONESTY (2026-05-24): cronGroupRecurring runs only on the bot owner's
  // Apps Script project, so the "auto-reminders" line only applies to
  // owner-installed setups. For everyone else the recurring item is stored
  // but no cron fires it. Be honest about that.
  var reminderLine = (typeof _isOwnerPhone_ === 'function' && _isOwnerPhone_(fromPhone))
    ? 'Ч”Ч‘Ч•Чҳ ЧҷЧ–ЧӣЧҷЧЁ ЧңЧҡ ЧҗЧ•ЧҳЧ•ЧһЧҳЧҷЧӘ Ч‘ЧӣЧң ЧһЧ—Ч–Ч•ЧЁ.'
    : 'Ч”Ч§Ч‘Ч•Чў Ч Ч©ЧһЧЁ Ч•ЧҷЧ•ЧӨЧҷЧў Ч‘ЧЁЧ©ЧҷЧһЧ”. ЧӘЧ–ЧӣЧ•ЧЁЧ•ЧӘ ЧҗЧ•ЧҳЧ•ЧһЧҳЧҷЧ•ЧӘ ЧңЧӣЧң Ч”Ч§Ч‘Ч•ЧҰЧ•ЧӘ Ч‘ЧӨЧҷЧӘЧ•Ч—.';
  return { handled: true, replyText:
    'рҹ”Ғ Ч§Ч‘Ч•Чў Ч Ч•ЧЎЧЈ:\n' +
    '  вӮӘ' + amount.toLocaleString('he-IL') + ' В· ' + description + '\n' +
    '  ЧӣЧң ' + ilabel + '\n\n' +
    reminderLine + ' Ч©ЧңЧ— "ЧӣЧЎЧӨЧңЧ” Ч§Ч‘Ч•ЧўЧҷЧқ" ЧңЧЁЧ©ЧҷЧһЧ” Ч”ЧһЧңЧҗЧ”.' };
}

function _groupListRecurring_(fromPhone) {
  var a = _groupAPI_('getactive', { phone: fromPhone });
  if (!a || !a.ok || !a.active) return { handled: true, replyText: 'ЧҗЧӘЧ” ЧңЧҗ Ч‘Ч§Ч‘Ч•ЧҰЧ”.' };
  var r = _groupAPI_('listrecurring', { code: a.active });
  if (!r || !r.ok) return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ”.' };
  if (!r.recurring || !r.recurring.length) return { handled: true, replyText: 'рҹ“ӯ ЧҗЧҷЧҹ Ч§Ч‘Ч•ЧўЧҷЧқ Ч‘Ч§Ч‘Ч•ЧҰЧ”. Ч”Ч•ЧЎЧЈ ЧўЧқ "ЧӣЧЎЧӨЧңЧ” Ч§Ч‘Ч•Чў 3000 Ч©ЧӣЧҷЧЁЧ•ЧӘ Ч—Ч•Ч“Ч©Чҷ".' };
  var lines = ['рҹ”Ғ *Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч§Ч‘Ч•ЧўЧ•ЧӘ Ч‘Ч§Ч‘Ч•ЧҰЧ”*', 'в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ', ''];
  r.recurring.forEach(function(rec){
    lines.push('  вҖў вӮӘ' + Number(rec.amount).toLocaleString('he-IL') + ' В· ' + rec.description + ' В· ' + rec.intervalLabel);
  });
  return { handled: true, replyText: lines.join('\n') };
}

// Build a CSV of the active group's expenses and email it to the
// requester. Uses Apps Script's MailApp (free 100 emails/day quota).
// The recipient address is the requester's Google account (whoever
// runs the script вҖ” which for the owner-installed bot is Steven).
// Tenants on /api/group can request a CSV via a future web export.
function _groupExport_(fromPhone) {
  var a = _groupAPI_('getactive', { phone: fromPhone });
  if (!a || !a.ok || !a.active) return { handled: true, replyText: 'ЧҗЧӘЧ” ЧңЧҗ Ч‘Ч§Ч‘Ч•ЧҰЧ”.' };
  var info = _groupAPI_('info', { code: a.active, requesterPhone: fromPhone });
  if (!info || !info.ok) return { handled: true, replyText: 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ”.' };
  var group = info.group;
  var lines = ['date,amount,category,description,paidBy,participants,splitMode,shares'];
  (group.expenses || []).forEach(function(e) {
    var shares = e.shares ? Object.entries(e.shares).map(function(kv){ return kv[0] + ':' + kv[1]; }).join('|') : '';
    var participants = e.shares ? Object.keys(e.shares).join('|') : '';
    var safe = function(v) { return '"' + String(v || '').replace(/"/g, '""') + '"'; };
    lines.push([
      e.timestamp || '',
      e.amount || 0,
      safe(e.category),
      safe(e.description),
      e.payerPhone || '',
      safe(participants),
      e.splitMode || '',
      safe(shares),
    ].join(','));
  });
  var csv = lines.join('\n');
  // HONESTY + PRIVACY (2026-05-24 audit): Session.getActiveUser().getEmail()
  // returns the BOT OWNER's Gmail (Steven), not the requester. The old
  // reply lied to non-owners that their CSV was emailed to them вҖ” it was
  // actually emailed to the owner. Two problems: privacy leak + lying.
  //
  // Fix: only auto-email when the requester IS the owner. Everyone else
  // gets directed to the web export at /dashboard which is the real,
  // authenticated download path for their own data.
  try {
    var addr = '';
    try { addr = Session.getActiveUser().getEmail(); } catch (_e) {}
    var isOwner = (typeof _isOwnerPhone_ === 'function') && _isOwnerPhone_(fromPhone);
    if (!isOwner || !addr) {
      return { handled: true, replyText:
        'рҹ“Ҙ ЧҷЧҷЧҰЧ•Чҗ CSV Ч©Чң Ч”Ч§Ч‘Ч•ЧҰЧ”:\n' +
        '1. ЧӣЧ ЧЎ/Чҷ Чң-' + KESEFLE_API_BASE.replace(/^https?:\/\//, '') + '/dashboard\n' +
        '2. Ч”ЧӘЧ—Ч‘ЧЁ ЧўЧқ Google\n' +
        '3. ЧңЧ—ЧҰ/Чҷ ЧўЧң "ЧҷЧҷЧҰЧ•Чҗ" вҶ’ CSV\n\n' +
        'Ч”Ч§Ч•Ч‘ЧҘ ЧҷЧЁЧ“ ЧҷЧ©ЧҷЧЁЧ•ЧӘ ЧҗЧңЧҷЧҡ Ч‘ЧҗЧ•ЧӨЧҹ ЧһЧҗЧ•Ч‘ЧҳЧ— (' + (group.expenses || []).length + ' Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч‘Ч§Ч‘Ч•ЧҰЧ”).' };
    }
    MailApp.sendEmail({
      to: addr,
      subject: 'ЧӣЧЎЧӨЧңЧ” вҖ” ЧҷЧҷЧҰЧ•Чҗ Ч§Ч‘Ч•ЧҰЧ” ' + group.code,
      body: 'ЧһЧҰЧ•ЧЁЧЈ ЧҷЧҷЧҰЧ•Чҗ CSV Ч©Чң Ч”Ч§Ч‘Ч•ЧҰЧ” "' + group.name + '" (' + group.code + ').\n\n' +
            'ЧЎЧ”"Чӣ ' + (group.expenses || []).length + ' Ч”Ч•ЧҰЧҗЧ•ЧӘ.\n\n' +
            'Ч Ч©ЧңЧ— ЧўЧң-ЧҷЧ“Чҷ Ч”Ч‘Ч•Чҳ Ч‘ЧўЧ§Ч‘Ч•ЧӘ ЧӨЧ§Ч•Ч“ЧӘ "ЧӣЧЎЧӨЧңЧ” ЧҷЧҷЧҰЧҗ" Чһ-' + fromPhone + '.',
      attachments: [Utilities.newBlob(csv, 'text/csv', group.code + '-' + new Date().toISOString().slice(0,10) + '.csv')],
    });
    return { handled: true, replyText: 'рҹ“§ Ч©ЧңЧ—ЧӘЧҷ ЧңЧҡ CSV ЧңЧһЧҷЧҷЧң ' + addr + ' (' + (group.expenses || []).length + ' Ч”Ч•ЧҰЧҗЧ•ЧӘ).' };
  } catch (e) {
    Logger.log('_groupExport_ err: ' + (e && e.message));
    return { handled: true, replyText: 'рҹҳ¬ ЧңЧҗ Ч”ЧҰЧңЧ—ЧӘЧҷ ЧңЧ©ЧңЧ•Ч—: ' + (e && e.message || '') };
  }
}

// Daily cron вҖ” fires recurring group expenses whose intervalDays has
// elapsed since lastFiredAt (or createdAt). Posts to the same Vercel
// /api/group?action=addexpense so the regular split + sheet-mirror
// pipeline runs. The payer gets a WhatsApp message confirming.
function cronGroupRecurring() {
  var secret = '';
  try { secret = String(PropertiesService.getScriptProperties().getProperty('KESEFLE_BOT_SECRET') || ''); } catch (_e) {}
  if (!secret) {
    Logger.log('cronGroupRecurring: KESEFLE_BOT_SECRET not set');
    return;
  }
  // We need to know which groups to scan. The Vercel endpoint doesn't
  // expose a "list all groups" action (and we shouldn't вҖ” that's a
  // privacy footgun). Instead the cron iterates the bot owner's own
  // groups via mygroups, which covers Steven's own roommates/family
  // for now. Multi-tenant cron is a future enhancement that requires
  // a server-side scheduler instead of Apps Script.
  var ownerPhone = '';
  try { ownerPhone = String(PropertiesService.getScriptProperties().getProperty('SHEET_OWNER_PHONE') || ''); } catch (_e) {}
  ownerPhone = ownerPhone.replace(/[^0-9]/g, '');
  if (!ownerPhone) {
    Logger.log('cronGroupRecurring: SHEET_OWNER_PHONE not set, skipping');
    return;
  }

  var groups = _groupAPI_('mygroups', { phone: ownerPhone });
  if (!groups || !groups.ok || !groups.groups || !groups.groups.length) return;

  var now = Date.now();
  groups.groups.forEach(function(g) {
    var info = _groupAPI_('listrecurring', { code: g.code });
    if (!info || !info.ok || !info.recurring) return;
    info.recurring.forEach(function(rec) {
      if (!rec.active) return;
      var lastFired = rec.lastFiredAt ? new Date(rec.lastFiredAt).getTime() : new Date(rec.createdAt).getTime();
      var elapsedDays = (now - lastFired) / 86400000;
      if (elapsedDays < rec.intervalDays - 0.1) return; // not due yet
      // Fire the expense.
      var fireRes = _groupAPI_('addexpense', {
        code: g.code,
        payerPhone: rec.payerPhone,
        requesterPhone: rec.payerPhone,
        payerName: '(ЧҗЧ•ЧҳЧ•ЧһЧҳЧҷ)',
        amount: rec.amount,
        description: '[Ч§Ч‘Ч•Чў] ' + rec.description,
        category: 'Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч§Ч‘Ч•ЧўЧ•ЧӘ',
        splitMode: 'equal',
      });
      if (fireRes && fireRes.ok) {
        // Persist lastFiredAt SERVER-SIDE so the recurring item doesn't
        // re-fire tomorrow. The old local "rec.lastFiredAt = ..." was a
        // no-op (the mutation never reached KV), so every recurring
        // expense fired daily instead of on its interval. The cron
        // secret authorizes this cron-only write.
        try {
          var __cronSecret = String(PropertiesService.getScriptProperties().getProperty('KESEFLE_CRON_SECRET') || '');
          _groupAPI_('markrecurringfired', { code: g.code, recurringId: rec.id, cronSecret: __cronSecret });
        } catch (_mfErr) { Logger.log('markrecurringfired err: ' + (_mfErr && _mfErr.message)); }
        // Notify the payer in WhatsApp.
        if (typeof sendWhatsAppMessage === 'function') {
          try {
            sendWhatsAppMessage('+' + rec.payerPhone,
              'рҹ”Ғ Ч”Ч•ЧҰЧҗЧ” Ч§Ч‘Ч•ЧўЧ” Ч ЧЁЧ©ЧһЧ” ЧҗЧ•ЧҳЧ•ЧһЧҳЧҷЧӘ:\n' +
              'вӮӘ' + Number(rec.amount).toLocaleString('he-IL') + ' В· ' + rec.description + '\n' +
              'Ч‘Ч§Ч‘Ч•ЧҰЧ”: ' + g.name + ' (' + g.code + ')');
          } catch (_e) {}
        }
      } else {
        Logger.log('cronGroupRecurring: addexpense failed for ' + g.code + '/' + rec.id);
      }
    });
  });
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Bill reminders вҖ” per-user date-scheduled WhatsApp pings
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function _remindersAPI_(action, payload) {
  var secret = '';
  try { secret = String(PropertiesService.getScriptProperties().getProperty('KESEFLE_BOT_SECRET') || ''); } catch (_e) {}
  if (!secret) return { ok: false, error: 'bot_secret_not_set' };
  payload = payload || {};
  payload.action = action;
  payload.botSecret = secret;
  try {
    var resp = UrlFetchApp.fetch(KESEFLE_API_BASE + '/api/reminders', {
      method: 'post',
      contentType: 'application/json',
      headers: { 'x-kesefle-bot-secret': secret },
      payload: JSON.stringify(payload),
      muteHttpExceptions: true,
    });
    var code = resp.getResponseCode();
    var body = resp.getContentText();
    if (code < 200 || code >= 300) {
      Logger.log('_remindersAPI_ ' + action + ' HTTP ' + code + ': ' + body.slice(0, 200));
      try { return JSON.parse(body); } catch (_e) { return { ok: false, error: 'http_' + code }; }
    }
    return JSON.parse(body);
  } catch (e) {
    return { ok: false, error: 'fetch_threw', detail: e && e.message };
  }
}

function _addReminder_(fromPhone, when, description, amount) {
  var r = _remindersAPI_('add', { phone: fromPhone, when: when, description: description, amount: amount });
  if (!r || !r.ok) {
    if (r && r.error === 'invalid_date') {
      return 'рҹҳ¬ ЧңЧҗ Ч”Ч‘Ч ЧӘЧҷ ЧҗЧӘ Ч”ЧӘЧҗЧЁЧҷЧҡ. Ч ЧЎЧ”: "ЧӘЧ–ЧӣЧ•ЧЁЧӘ 15/6 ЧҗЧЁЧ Ч•Ч Ч”" ЧҗЧ• "ЧӘЧ–ЧӣЧ•ЧЁЧӘ ЧһЧ—ЧЁ Ч—Ч©ЧһЧң 450".';
    }
    return 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ”: ' + (r && r.error || 'unknown');
  }
  var amountTxt = amount ? ' (вӮӘ' + Number(amount).toLocaleString('he-IL') + ')' : '';
  return 'рҹ”” ЧӘЧ–ЧӣЧ•ЧЁЧӘ Ч Ч•ЧЎЧӨЧ”: ' + r.entry.when + ' вҖ” ' + description + amountTxt + '\nID: ' + r.entry.id.slice(0, 8);
}

function _listReminders_(fromPhone) {
  var r = _remindersAPI_('list', { phone: fromPhone });
  if (!r || !r.ok) return 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ”.';
  if (!r.reminders.length) return 'рҹ“ӯ ЧҗЧҷЧҹ ЧӘЧ–ЧӣЧ•ЧЁЧ•ЧӘ ЧӨЧўЧҷЧңЧ•ЧӘ.\n\nЧ”Ч•ЧЎЧЈ: "ЧӘЧ–ЧӣЧ•ЧЁЧӘ 15/6 Ч—Ч©ЧһЧң 450"';
  var lines = ['рҹ”” *ЧӘЧ–ЧӣЧ•ЧЁЧ•ЧӘ Ч§ЧЁЧ•Ч‘Ч•ЧӘ*', 'в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ', ''];
  r.reminders.forEach(function(rem) {
    var amt = rem.amount ? ' В· вӮӘ' + Number(rem.amount).toLocaleString('he-IL') : '';
    var when = rem.when.split('-').reverse().slice(0, 2).join('/');
    lines.push('  вҖў ' + when + ' В· ' + rem.description + amt + '  `' + rem.id.slice(0, 8) + '`');
  });
  lines.push('');
  lines.push('ЧңЧһЧ—ЧҷЧ§Ч”: "ЧһЧ—Ч§ ЧӘЧ–ЧӣЧ•ЧЁЧӘ <ID>"');
  return lines.join('\n');
}

function _removeReminder_(fromPhone, idPrefix) {
  // Resolve ID prefix to the full ID by listing first.
  var listing = _remindersAPI_('list', { phone: fromPhone });
  if (!listing || !listing.ok) return 'рҹҳ¬ Ч©Ч’ЧҷЧҗЧ”.';
  var match = listing.reminders.find(function(r){ return r.id.indexOf(idPrefix) === 0; });
  if (!match) return 'рҹҳ¬ ЧңЧҗ ЧһЧҰЧҗЧӘЧҷ ЧӘЧ–ЧӣЧ•ЧЁЧӘ ЧўЧқ ID "' + idPrefix + '". Ч©ЧңЧ— "ЧӘЧ–ЧӣЧ•ЧЁЧ•ЧӘ" ЧңЧЁЧ©ЧҷЧһЧ”.';
  var r = _remindersAPI_('remove', { phone: fromPhone, id: match.id });
  if (!r || !r.ok) return 'рҹҳ¬ ЧһЧ—ЧҷЧ§Ч” Ч ЧӣЧ©ЧңЧ”.';
  return 'рҹ—‘ ЧӘЧ–ЧӣЧ•ЧЁЧӘ Ч ЧһЧ—Ч§Ч”: ' + match.description;
}

