        break;
      }
    }
  }

  // (2) Fall back to the real classifier on the full message: if matchCategory
  // sees a business keyword and returns a recognized ЧўЧЎЧ§ dashboard bucket, use
  // it (covers business keywords not in the small token map, e.g. brand names
  // like "ЧӨЧҷЧҷЧЎЧ‘Ч•Ч§" / "ЧҗЧ“Ч•Ч‘Чҷ" -> Ч©ЧҷЧ•Ч•Ч§ / ЧӘЧӨЧўЧ•ЧңЧҷЧ•ЧӘ).
  if (!sub) {
    try {
      var mc = (typeof matchCategory === 'function') ? matchCategory(t) : null;
      if (mc && mc.category === 'ЧўЧЎЧ§' && mc.subcategory &&
          typeof _normalizeBizSub_ === 'function' && _normalizeBizSub_(mc.subcategory)) {
        sub = mc.subcategory;
      }
    } catch (_mcErr) {}
  }

  // (3) Last resort: nothing recognizable. Keep the cleaned token as the
  // subcategory but STILL force category=ЧўЧЎЧ§ (never fall through to personal).
  if (!sub) sub = (rest || 'Ч”Ч•ЧҰЧҗЧ•ЧӘ ЧӘЧӨЧўЧ•ЧңЧҷЧ•ЧӘ');

  var cleanedDesc = rest || sub;
  // Income only if the matched bucket is revenue (ЧһЧ—Ч–Ч•ЧЁ) вҖ” bare business
  // EXPENSES are never income here.
  var isIncome = (sub === 'ЧһЧ—Ч–Ч•ЧЁ');

  return { amount: amount, category: 'ЧўЧЎЧ§', subcategory: sub, cleanedDesc: cleanedDesc, isIncome: isIncome };
}

// A char that can be part of a word (digit, Latin, or Hebrew letter).
function _kflIsWordChar_(ch) { return !!ch && /[0-9A-Za-zЦҗ-Чҝ]/.test(ch); }
// Keyword hit test. Long keywords (>3 chars, e.g. brand names) match as
// substrings so Hebrew prefixes still work ("Ч‘Ч©Ч•ЧӨЧЁЧЎЧң"). SHORT keywords (<=3)
// must match as WHOLE WORDS вҖ” otherwise they false-positive inside unrelated
// words ("ЧһЧҷЧқ" inside "ЧӘЧ©ЧңЧ•ЧһЧҷЧқ", "Ч§ЧӨЧ”" inside "ЧһЧ§ЧӨЧ”"). Core precision guard.
function _kflKwHit_(t, kw) {
  if (!kw) return false;
  if (kw.length > 3) return t.indexOf(kw) >= 0;
  var from = 0, idx;
  while ((idx = t.indexOf(kw, from)) >= 0) {
    var b = idx === 0 ? '' : t.charAt(idx - 1);
    var a = (idx + kw.length >= t.length) ? '' : t.charAt(idx + kw.length);
    if (!_kflIsWordChar_(b) && !_kflIsWordChar_(a)) return true;
    from = idx + 1;
