      '"1800 ЧҗЧЁЧ Ч•Ч Ч”" вҶ’ {"category":"Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч§Ч‘Ч•ЧўЧ•ЧӘ","subcategory":"Ч‘ЧҷЧӘ","confidence":0.99,"reason":"ЧҗЧЁЧ Ч•Ч Ч” ЧӘЧ©ЧңЧ•Чқ ЧўЧҷЧЁЧҷЧҷЧ”"}\n' +
      '"Ч—Ч‘ЧЁЧӘ Ч—Ч©ЧһЧң" вҶ’ {"category":"Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч§Ч‘Ч•ЧўЧ•ЧӘ","subcategory":"Ч—Ч©ЧһЧң","confidence":0.99,"reason":"Ч—Ч‘ЧЁЧӘ Ч—Ч©ЧһЧң"}\n' +
      '"netflix" вҶ’ {"category":"Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч§Ч‘Ч•ЧўЧ•ЧӘ","subcategory":"ЧҗЧӨЧңЧҷЧ§ЧҰЧҷЧ•ЧӘ","confidence":0.97,"reason":"ЧһЧ Ч•Чҷ ЧЎЧҳЧЁЧҷЧһЧҷЧ Ч’"}\n' +
      '"chatgpt plus" вҶ’ {"category":"Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч§Ч‘Ч•ЧўЧ•ЧӘ","subcategory":"ЧҗЧӨЧңЧҷЧ§ЧҰЧҷЧ•ЧӘ","confidence":0.95,"reason":"ЧһЧ Ч•Чҷ ЧӘЧ•ЧӣЧ Ч”"}\n' +
      '"Ч‘Ч Ч–ЧҷЧҹ ЧЎЧ•Ч Ч•Чң" вҶ’ {"category":"ЧӘЧ—Ч‘Ч•ЧЁЧ”","subcategory":"Ч“ЧңЧ§","confidence":0.99,"reason":"ЧӘЧ“ЧңЧ•Ч§ ЧЁЧӣЧ‘"}\n' +
      '"ЧЁЧӣЧ‘ЧӘ ЧҷЧ©ЧЁЧҗЧң" вҶ’ {"category":"ЧӘЧ—Ч‘Ч•ЧЁЧ”","subcategory":"ЧӘЧ—Ч‘Ч•ЧЁЧ” ЧҰЧҷЧ‘Ч•ЧЁЧҷЧӘ","confidence":0.99,"reason":"ЧЁЧӣЧ‘ЧӘ"}\n' +
      '"ЧӨЧ Ч’Ч• Ч—Ч ЧҷЧ”" вҶ’ {"category":"ЧӘЧ—Ч‘Ч•ЧЁЧ”","subcategory":"Ч—Ч ЧҷЧ”","confidence":0.98,"reason":"Ч—Ч ЧҷЧ” ЧӨЧ Ч’Ч•"}\n' +
      '"ЧһЧ•Ч‘ЧҷЧң Ч”Ч•ЧҰЧҗЧ•ЧӘ Ч‘ЧҷЧӘ" вҶ’ {"category":"Ч©ЧҷЧЁЧ•ЧӘЧҷЧқ","subcategory":"Ч”Ч•Ч‘ЧңЧ•ЧӘ","confidence":0.9,"reason":"Ч©ЧҷЧЁЧ•ЧӘ Ч”Ч•Ч‘ЧңЧ”"}\n' +
      '"Ч—Ч©ЧһЧңЧҗЧҷ Ч“Ч—Ч•ЧЈ" вҶ’ {"category":"Ч©ЧҷЧЁЧ•ЧӘЧҷЧқ","subcategory":"Ч—Ч©ЧһЧңЧҗЧҷ","confidence":0.97,"reason":"Ч—Ч©ЧһЧңЧҗЧҷ Ч‘ЧҷЧӘ"}\n' +
      '"Ч©ЧҷЧ ЧҷЧҷЧқ ЧһЧҗЧ•Ч—Ч“ЧӘ" вҶ’ {"category":"Ч‘ЧЁЧҷЧҗЧ•ЧӘ","subcategory":"Ч©ЧҷЧ ЧҷЧҷЧқ","confidence":0.95,"reason":"ЧҳЧҷЧӨЧ•Чң Ч©ЧҷЧ ЧҷЧҷЧқ"}\n' +
      '"super pharm" вҶ’ {"category":"Ч‘ЧЁЧҷЧҗЧ•ЧӘ","subcategory":"ЧӘЧЁЧ•ЧӨЧ•ЧӘ","confidence":0.96,"reason":"Ч‘ЧҷЧӘ ЧһЧЁЧ§Ч—ЧӘ"}\n' +
      '"holmes place" вҶ’ {"category":"Ч‘ЧЁЧҷЧҗЧ•ЧӘ","subcategory":"ЧӣЧ•Ч©ЧЁ Ч•ЧһЧ Ч•ЧҷЧҷЧқ","confidence":0.97,"reason":"ЧһЧ Ч•Чҷ Ч—Ч“ЧЁ ЧӣЧ•Ч©ЧЁ"}\n' +
