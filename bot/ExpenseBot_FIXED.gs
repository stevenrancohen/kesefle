var DEFAULT_TZ = 'Asia/Jerusalem';

var COUNTRY_TZ_MAP = {
  '972': 'Asia/Jerusalem',
  '1':   'America/New_York',
  '44':  'Europe/London',
  '33':  'Europe/Paris',
  '49':  'Europe/Berlin',
