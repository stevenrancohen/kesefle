// Very small fuzzy matcher for the free-text "other" path. Returns a known
// profession id from lib/professions.js or null. We deliberately keep this
// list tight + Hebrew-first вҖ” the goal isn't to identify every profession
// in the world, it's to catch the 90% case so the user doesn't have to
// retype. Anything we don't recognize is saved as the raw cleaned text so
// the user at least sees their answer back; the LLM-boost path then
// degrades gracefully (no boost) instead of mis-classifying.
function _matchProfessionFromText_(text) {
  var t = String(text || '').toLowerCase().trim();
  if (!t) return null;
  // Order matters: more specific first so "ЧЁЧ•ЧӨЧҗ Ч©ЧҷЧ ЧҷЧҷЧқ" wins over "ЧЁЧ•ЧӨЧҗ".
  var rules = [
    { id: 'dentist',                       re: /ЧЁЧ•ЧӨЧҗ[ЧӘ]?\s*Ч©ЧҷЧ ЧҷЧҷЧқ|Ч©ЧҷЧ ЧҷЧҷЧқ|dentist/ },
    { id: 'veterinarian',                  re: /Ч•ЧҳЧЁЧҷЧ ЧЁ|veterinar/ },
    { id: 'psychologist',                  re: /ЧӨЧЎЧҷЧӣЧ•ЧңЧ•Ч’|psycholog/ },
    { id: 'physiotherapist',               re: /ЧӨЧҷЧ–ЧҷЧ•ЧӘЧЁЧӨ|ЧӨЧҷЧ–ЧҷЧ•|physiother/ },
    { id: 'doctor',                        re: /^ЧЁЧ•ЧӨЧҗ|ЧЁЧ•ЧӨЧҗЧ”|ЧЁЧ•ЧӨЧҗ\s|doctor|physician|md\b/ },
    { id: 'architect',                     re: /ЧҗЧ“ЧЁЧҷЧӣЧң|architect/ },
    { id: 'electrician',                   re: /Ч—Ч©ЧһЧңЧҗЧҷ|electrician/ },
    { id: 'plumber',                       re: /ЧҗЧҷЧ ЧЎЧҳЧң|plumber/ },
    { id: 'painter_construction',          re: /ЧҰЧ‘ЧўЧҷ|painter/ },
    { id: 'handyman',                      re: /Ч”Ч Ч“ЧҷЧһЧҹ|handyman/ },
    { id: 'gardener',                      re: /Ч’Ч Чҹ|gardener|landscape/ },
    { id: 'cleaner',                       re: /ЧһЧ Ч§Ч”|Ч ЧҷЧ§ЧҷЧ•Чҹ|cleaner|cleaning/ },
    { id: 'babysitter',                    re: /Ч‘ЧҷЧҷЧ‘ЧҷЧЎЧҷЧҳЧЁ|ЧһЧҳЧӨЧң[ЧӘ]?\s*ЧҷЧңЧ“|babysitter|nanny/ },
    { id: 'dog_walker',                    re: /ЧһЧҳЧҷЧҷЧң\s*ЧӣЧңЧ‘|dog\s*walk/ },
    // Final-form Hebrew letters (Чҹ Чқ Чҡ ЧЈ ЧҘ) only appear at word-end. When the
    // user types a plural or feminine form ("Ч§Ч‘ЧңЧ ЧҷЧқ", "Ч“ЧҷЧҗЧҳЧ ЧҷЧӘ"), the same
    // root letter shows up in its NON-final form (Ч  Чқ Чӣ ЧӨ ЧҰ). Patterns that
    // need to catch both use a char class like [ЧҹЧ ] to match either form.
    // Hebrew abbreviations use either ASCII " or the gershayim Чҙ (U+05F4);
    // patterns that include them use ["Чҙ] to accept both. Steven 2026-05-26.
    { id: 'real_estate_agent',             re: /ЧһЧӘЧ•Ч•Чҡ|Ч Ч“Чң["Чҙ]?[ЧҹЧ ]|real\s*estate|realtor/ },
