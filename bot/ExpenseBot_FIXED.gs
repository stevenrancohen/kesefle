  // Strip, in order: a leading Ч”Ч•ЧҰЧҗЧ”/Ч”Ч•ЧҰЧҗЧӘ, the ЧўЧЎЧ§ token, an OPTIONAL single
  // following business-NAME word (a Hebrew/Latin word that is NOT itself a known
  // business-category token, e.g. "ЧӘЧһЧ•Ч Ч•ЧӘ"), and the amount. Whatever remains is
  // the subcategory phrase we classify.
  var rest = t
    .replace(/^\s*(?:Ч”Ч•ЧҰЧҗЧ”|Ч”Ч•ЧҰЧҗЧӘ)\s+/, '')   // optional expense lead-in
    .replace(/(^|\s)[Ч‘ЧңЧһЧ”Ч•]?ЧўЧЎЧ§(\s|$)/, ' ')  // the business marker (+clitic prefix)
    .replace(/,/g, ' ')
    .replace(new RegExp('(^|\\s)' + amount.toString().replace('.', '\\.') + '(\\s|$)'), ' ')
    .replace(/\s+/g, ' ')
    .trim();

